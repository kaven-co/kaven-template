# ============================================
# Kaven Framework — Environment Configuration
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env with real credentials
# ============================================

# Project
PROJECT_NAME={{PROJECT_NAME}}

# Database (PostgreSQL)
DATABASE_URL={{DATABASE_URL}}

# Auth
JWT_SECRET=change-me-in-production
REFRESH_TOKEN_SECRET=change-me-in-production
NEXTAUTH_SECRET=change-me-in-production
NEXTAUTH_URL=http://localhost:3000

# Locale
DEFAULT_LOCALE={{DEFAULT_LOCALE}}
DEFAULT_CURRENCY={{DEFAULT_CURRENCY}}

# Redis (rate limiting, sessions, cache)
REDIS_URL=redis://localhost:6379

# Email (choose one provider)
# Options: ses, resend, postmark, smtp
EMAIL_PROVIDER=smtp

# AWS SES
# AWS_SES_REGION=us-east-1
# AWS_SES_ACCESS_KEY_ID=
# AWS_SES_SECRET_ACCESS_KEY=
# AWS_SES_FROM_EMAIL=noreply@yourdomain.com

# Resend
# RESEND_API_KEY=

# Postmark
# POSTMARK_API_KEY=

# SMTP (generic)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@localhost

# Payments — Stripe (international)
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Storage (S3-compatible)
# S3_BUCKET_NAME=
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# Telemetry (opt-out with 0)
KAVEN_TELEMETRY=1

# Node
NODE_ENV=development
