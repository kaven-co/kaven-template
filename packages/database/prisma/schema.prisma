// ===========================
// MARKETING MODULE
// ===========================
// Campaigns, automation, lead scoring, consent management, forms,
// UTM tracking, email templates, calendar. Multi-tenant isolated via tenantId.
// Cross-module FKs: contactId → clients.Contact, segmentId → clients.Segment, tagId → clients.Tag

// [KAVEN_MODULE:MARKETING BEGIN]

// ---------- Enums ----------

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  PAUSED
  CANCELLED
  COMPLETED
  ARCHIVED

  @@map("campaign_status")
}

enum CampaignChannel {
  EMAIL
  SMS
  WHATSAPP
  PUSH

  @@map("campaign_channel")
}

enum CampaignEventType {
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  UNSUBSCRIBED
  CONVERTED
  COMPLAINED

  @@map("campaign_event_type")
}

enum ConsentType {
  MARKETING
  TRANSACTIONAL
  ANALYTICS
  THIRD_PARTY

  @@map("consent_type")
}

enum ConsentSource {
  FORM
  IMPORT
  API
  MANUAL
  DOUBLE_OPT_IN

  @@map("consent_source")
}

enum LeadScoreEventType {
  EMAIL_OPENED
  EMAIL_CLICKED
  FORM_SUBMITTED
  PAGE_VISITED
  DEMO_REQUESTED
  CONTENT_DOWNLOADED
  WEBINAR_ATTENDED
  PROFILE_UPDATED
  MANUAL_ADJUSTMENT

  @@map("lead_score_event_type")
}

enum AutomationTriggerType {
  CONTACT_CREATED
  LIFECYCLE_CHANGED
  LEAD_SCORE_THRESHOLD
  FORM_SUBMITTED
  TAG_ADDED
  CAMPAIGN_EVENT
  MANUAL

  @@map("automation_trigger_type")
}

enum AutomationActionType {
  SEND_EMAIL
  ADD_TAG
  REMOVE_TAG
  UPDATE_FIELD
  UPDATE_LIFECYCLE
  NOTIFY_ASSIGNEE
  WAIT
  BRANCH
  WEBHOOK

  @@map("automation_action_type")
}

enum AutomationStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED

  @@map("automation_status")
}

// ----------------------------
// 1. Campaign — Marketing campaign (email, SMS, WhatsApp, push)
// ----------------------------

model Campaign {
  id               String          @id @default(cuid())
  tenantId         String          @map("tenant_id")
  name             String
  slug             String
  description      String?
  type             String?
  channel          CampaignChannel @default(EMAIL)
  status           CampaignStatus  @default(DRAFT)
  scheduledAt      DateTime?       @map("scheduled_at")
  sentAt           DateTime?       @map("sent_at")
  completedAt      DateTime?       @map("completed_at")
  timezone         String?         @default("UTC")
  budget           Float?
  goalMetric       String?         @map("goal_metric")
  goalValue        Float?          @map("goal_value")
  subject          String?
  body             String?
  htmlContent      String?         @map("html_content")
  templateId       String?         @map("template_id")
  segmentId        String?         @map("segment_id")
  audienceSize     Int?            @map("audience_size")
  audienceSnapshot Json?           @map("audience_snapshot")
  isAbTest         Boolean         @default(false) @map("is_ab_test")
  winnerVariantId  String?         @map("winner_variant_id")
  sentCount        Int             @default(0) @map("sent_count")
  deliveredCount   Int             @default(0) @map("delivered_count")
  openedCount      Int             @default(0) @map("opened_count")
  clickedCount     Int             @default(0) @map("clicked_count")
  bouncedCount     Int             @default(0) @map("bounced_count")
  unsubCount       Int             @default(0) @map("unsub_count")
  convertedCount   Int             @default(0) @map("converted_count")
  tags             String[]        @default([])
  ownerId          String          @map("owner_id")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  deletedAt        DateTime?       @map("deleted_at")

  // Relations
  tenant           Tenant             @relation("TenantCampaigns", fields: [tenantId], references: [id], onDelete: Cascade)
  owner            User               @relation("CampaignOwner", fields: [ownerId], references: [id])
  segment          Segment?           @relation("CampaignSegment", fields: [segmentId], references: [id], onDelete: SetNull)
  variants         CampaignVariant[]
  events           CampaignEvent[]
  utms             CampaignUtm[]
  calendarEntries  MarketingCalendar[]
  campaignTags     CampaignTag[]

  @@unique([tenantId, slug])
  @@index([tenantId, status])
  @@index([tenantId, channel])
  @@index([tenantId, scheduledAt])
  @@index([tenantId, deletedAt])
  @@map("campaigns")
}

// ----------------------------
// 2. CampaignVariant — A/B test variants
// ----------------------------

model CampaignVariant {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  campaignId  String   @map("campaign_id")
  name        String
  subject     String?
  body        String?
  htmlContent String?  @map("html_content")
  weight      Int      @default(50)
  isWinner    Boolean  @default(false) @map("is_winner")
  sentCount   Int      @default(0) @map("sent_count")
  openedCount Int      @default(0) @map("opened_count")
  clickedCount Int     @default(0) @map("clicked_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  tenant   Tenant   @relation("TenantCampaignVariants", fields: [tenantId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([tenantId, campaignId])
  @@map("campaign_variants")
}

// ----------------------------
