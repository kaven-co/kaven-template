// ===========================
// CURRENCIES
// ===========================

model Currency {
  id          String   @id @default(uuid())
  /// @unique -- ISO 4217 currency code; ensures no duplicate currency definitions
  code        String   @unique // BRL, USD, SATS
  name        String   // Real Brasileiro, US Dollar, Bitcoin (sats)
  symbol      String?  // R$, $, null (para sats que usa SVG)
  
  // Ícone (SVG ou texto)
  iconType      IconType      @default(TEXT) // TEXT ou SVG
  iconColorMode IconColorMode @default(MONOCHROME) // MONOCHROME ou COLORED
  iconSvgPath   String?       @db.Text // Path do SVG (para sats)
  iconSvgViewBox String?      @default("0 0 24 24") // ViewBox do SVG original
  
  // Formatação
  decimals    Int      @default(2) // BRL=2, USD=2, SATS=0
  
  // Configurações
  isActive    Boolean  @default(true)
  isCrypto    Boolean  @default(false)
  sortOrder   Int      @default(0)
  
  // Metadata (para configurações futuras)
  metadata    Json?
  
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  @@index([code])
  @@index([isActive])
  @@index([isCrypto])
  @@map("currencies")
}

// ===========================
// PLATFORM CONFIGURATION
// ===========================

model PlatformConfig {
  id           String  @id @default(uuid())

  // Tenant que possui esta configuração (nullable para compatibilidade com config global)
  tenantId     String?
  tenant       Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  companyName  String  @default("Kaven SaaS")
  description  String?
  primaryColor String  @default("#00A76F")
  logoUrl      String? // URL do logo principal (sidebar, auth, emails)
  faviconUrl   String? // URL do favicon (ícone do navegador)

  // Configurações Regionais
  // NOTE: These defaults reflect the initial target market (Brazil).
  // They are overridden at runtime when creating a new tenant/config:
  //   - The Tenant App onboarding wizard sets locale based on user selection
  //   - Admin Panel allows changing these per-tenant at any time
  //   - For non-Brazilian deployments, override via seed script or API
  // Accepted values for language: BCP-47 tags (e.g., "en-US", "pt-BR", "es-AR")
  language     String @default("en-US")
  // Accepted values for currency: ISO 4217 codes (e.g., "USD", "BRL", "EUR")
  currency     String @default("USD")
  // Number format pattern: "1,000.00" (US/intl) or "1.000,00" (BR/EU)
  numberFormat String @default("1,000.00")
  
  // Configurações de Timezone e Formatos
  timezone     String @default("UTC") // IANA timezone (GMT+0)
  dateFormat   String @default("Y-m-d") // Y-m-d, d/m/Y, m/d/Y, j \\de F \\de Y
  timeFormat   String @default("g:i A")   // H:i (24h) ou g:i A (12h)
  
  // SEO & Social
  twitterHandle String?
  ogImageUrl    String?

  // Theme Overrides (JSON blob — custom tokens per tenant/platform)
  themeOverrides Json?

  // Configurações de Email/SMTP
  smtpHost     String? @default("localhost")
  smtpPort     Int?    @default(1025)
  smtpSecure   Boolean @default(false)
  smtpUser     String?
  /// @encrypted — SMTP password, encrypted at application layer before storage
  smtpPassword String?
  emailFrom    String? @default("Kaven <noreply@kaven.com>")

  updatedAt DateTime @updatedAt
}

// ===========================
// CORE MODELS
// ===========================

