// ===========================
// CLIENTS + CRM MODULE
// ===========================
// Gestão de contatos, organizações, lifecycle, segmentação,
// interações, timeline, feedback (NPS/CSAT) e health scoring.
// Multi-tenant isolado via tenantId em todos os models.

// [KAVEN_MODULE:CLIENTS_CRM BEGIN]

enum ContactLifecycleStage {
  LEAD
  MQL
  SQL
  OPPORTUNITY
  ACTIVE_CLIENT
  AT_RISK
  CHURNED
  ADVOCATE
}

enum ContactStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum ContactType {
  PERSON
  COMPANY
  PARTNER
  VENDOR
}

enum HealthCategory {
  HEALTHY
  AT_RISK
  CRITICAL
}

enum TrendDirection {
  UP
  DOWN
  STABLE
}

// ----------------------------
// 1. Contact — Core entity (person/company/partner/vendor)
// ----------------------------

model Contact {
  id             String                 @id @default(cuid())
  tenantId       String                 @map("tenant_id")

  // Identification
  contactType    ContactType            @default(PERSON) @map("contact_type")
  fullName       String                 @map("full_name")
  email          String?
  phone          String?
  phoneAlt       String?                @map("phone_alt")
  linkedinUrl    String?                @map("linkedin_url")
  avatarUrl      String?                @map("avatar_url")

  // Organization (B2B)
  organizationId String?                @map("organization_id")
  jobTitle       String?                @map("job_title")
  department     String?

  // Lifecycle & Status
  lifecycleStage ContactLifecycleStage  @default(LEAD) @map("lifecycle_stage")
  status         ContactStatus          @default(ACTIVE)
  source         String?
  sourceDetail   String?                @map("source_detail")

  // Location
  country        String?                @default("BR")
  state          String?
  city           String?
  address        String?
  postalCode     String?                @map("postal_code")

  // Qualification (lead scoring base)
  leadScore      Int?                   @default(0) @map("lead_score")
  qualifiedAt    DateTime?              @map("qualified_at")
  assignedToId   String?                @map("assigned_to_id")

  // AI Enrichment
  enrichedAt       DateTime?            @map("enriched_at")
  enrichmentData   Json?                @map("enrichment_data")
  enrichmentStatus String?              @map("enrichment_status")

  // Custom fields per industry
  customFields   Json?                  @map("custom_fields")

  // Preferences & Communication
  preferredChannel String?              @map("preferred_channel")
  unsubscribed     Boolean              @default(false)
  unsubscribedAt   DateTime?            @map("unsubscribed_at")
  doNotContact     Boolean              @default(false) @map("do_not_contact")

  // NPS / Satisfaction
  npsScore       Int?                   @map("nps_score")
  npsLastAt      DateTime?              @map("nps_last_at")

  // Internal
  notes          String?
  ownerId        String?                @map("owner_id")

  // Soft delete
  deletedAt      DateTime?              @map("deleted_at")
  deletedById    String?                @map("deleted_by_id")

  createdById    String                 @map("created_by_id")
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")

  // Relations
  tenant           Tenant               @relation("TenantContacts", fields: [tenantId], references: [id], onDelete: Cascade)
  organization     CrmOrganization?     @relation(fields: [organizationId], references: [id])
  assignedTo       User?                @relation("ContactAssignee", fields: [assignedToId], references: [id])
  createdBy        User                 @relation("ContactCreator", fields: [createdById], references: [id])

  interactions     CrmInteraction[]
  timelineEvents   CrmTimelineEvent[]
  contactTags      ContactTag[]
  segments         ContactSegment[]
  feedback         CustomerFeedback[]
  lifecycleHistory LifecycleHistory[]
  healthScores     ClientHealthScore[]
  healthHistory    ClientHealthHistory[]
  sharedContacts    SharedContact[]
  financialEntries  FinancialEntry[]  @relation("FinancialEntryClient")

  @@index([tenantId, lifecycleStage])
  @@index([tenantId, status])
  @@index([tenantId, email])
  @@index([tenantId, leadScore])
  @@index([tenantId, deletedAt])
  @@index([tenantId, contactType])
  @@index([tenantId, assignedToId])
  @@index([tenantId, organizationId])
  @@map("contacts")
}

// ----------------------------
// 2. CrmOrganization — B2B company entity
// ----------------------------

model CrmOrganization {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")

  name           String
  domain         String?
  cnpj           String?
  website        String?
  linkedinUrl    String?  @map("linkedin_url")
  industry       String?
  size           String?
  revenue        String?
  country        String?  @default("BR")
  state          String?
  city           String?

  // AI Enrichment
  enrichedAt     DateTime? @map("enriched_at")
  enrichmentData Json?     @map("enrichment_data")

  // Status
  status         String    @default("active")
  tags           String[]
  customFields   Json?     @map("custom_fields")

  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  // Relations
  tenant         Tenant    @relation("TenantCrmOrganizations", fields: [tenantId], references: [id], onDelete: Cascade)
  contacts       Contact[]

  @@index([tenantId, domain])
  @@index([tenantId, status])
  @@index([tenantId, industry])
  @@map("crm_organizations")
}

// ----------------------------
// 3. Tag — Reusable tags scoped by tenant + area
// ----------------------------

model Tag {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String
  color     String?
  areaSlug  String?  @map("area_slug")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  tenant    Tenant       @relation("TenantTags", fields: [tenantId], references: [id], onDelete: Cascade)
  contacts  ContactTag[]

  @@unique([tenantId, name, areaSlug])
  @@index([tenantId])
  @@map("tags")
}

// ----------------------------
// 4. ContactTag — Many-to-many contact <-> tag
// ----------------------------

model ContactTag {
  contactId String   @map("contact_id")
  tagId     String   @map("tag_id")
  addedAt   DateTime @default(now()) @map("added_at")
  addedById String?  @map("added_by_id")

  // Relations
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
  @@map("contact_tags")
}

// ----------------------------
// 5. Segment — Saved dynamic query (JSON filters)
// ----------------------------

model Segment {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  name            String
  description     String?
  color           String?
  areaSlug        String?   @map("area_slug")
  queryDef        Json      @map("query_def")
  isPublic        Boolean   @default(false) @map("is_public")
  memberCount     Int       @default(0) @map("member_count")
  lastEvaluatedAt DateTime? @map("last_evaluated_at")

  createdById     String    @map("created_by_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  tenant          Tenant           @relation("TenantSegments", fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy       User             @relation("SegmentCreator", fields: [createdById], references: [id])
  contacts        ContactSegment[]

  @@index([tenantId, areaSlug])
  @@index([tenantId, createdById])
  @@map("segments")
}

// ----------------------------
// 6. ContactSegment — Materialized segment membership
// ----------------------------

model ContactSegment {
  contactId String   @map("contact_id")
  segmentId String   @map("segment_id")
  addedAt   DateTime @default(now()) @map("added_at")

  // Relations
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  segment   Segment  @relation(fields: [segmentId], references: [id], onDelete: Cascade)

  @@id([contactId, segmentId])
  @@map("contact_segments")
}

// ----------------------------
// 7. CrmInteraction — Communication log
// ----------------------------

model CrmInteraction {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  contactId   String    @map("contact_id")
  userId      String?   @map("user_id")
  agentId     String?   @map("agent_id")

  type        String
  channel     String?
  direction   String?
  subject     String?
  body        String?
  duration    Int?
  outcome     String?

  metadata    Json?
  occurredAt  DateTime  @default(now()) @map("occurred_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  // Relations
  tenant      Tenant    @relation("TenantCrmInteractions", fields: [tenantId], references: [id], onDelete: Cascade)
  contact     Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  user        User?     @relation("CrmInteractionUser", fields: [userId], references: [id])

  @@index([tenantId, contactId])
  @@index([tenantId, type])
  @@index([contactId, occurredAt])
  @@map("crm_interactions")
}

// ----------------------------
// 8. CrmTimelineEvent — Unified cross-module history feed
// ----------------------------

model CrmTimelineEvent {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  contactId   String   @map("contact_id")

  sourceType  String   @map("source_type")
  sourceId    String?  @map("source_id")

  title       String
  description String?
  icon        String?
  metadata    Json?

  occurredAt  DateTime @default(now()) @map("occurred_at")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  tenant      Tenant   @relation("TenantCrmTimelineEvents", fields: [tenantId], references: [id], onDelete: Cascade)
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([tenantId, contactId, occurredAt])
  @@index([tenantId, sourceType])
  @@map("crm_timeline_events")
}

// ----------------------------
// 9. LifecycleHistory — Audit trail for lifecycle stage changes
// ----------------------------

model LifecycleHistory {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  contactId   String    @map("contact_id")
  fromStage   String?   @map("from_stage")
  toStage     String    @map("to_stage")
  changedById String?   @map("changed_by_id")
  reason      String?
  changedAt   DateTime  @default(now()) @map("changed_at")

  // Relations
  tenant      Tenant    @relation("TenantLifecycleHistories", fields: [tenantId], references: [id], onDelete: Cascade)
  contact     Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  changedBy   User?     @relation("LifecycleChangedBy", fields: [changedById], references: [id])

  @@index([tenantId, contactId])
  @@index([tenantId, changedAt])
  @@map("lifecycle_histories")
}

// ----------------------------
// 10. CustomerFeedback — NPS/CSAT native feedback
// ----------------------------

model CustomerFeedback {
  id           String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  contactId    String    @map("contact_id")

  feedbackType String    @map("feedback_type")
  score        Int?
  comment      String?
  sentiment    String?

  triggeredBy  String?   @map("triggered_by")
  sourceId     String?   @map("source_id")

  submittedAt  DateTime? @map("submitted_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  // Relations
  tenant       Tenant    @relation("TenantCustomerFeedbacks", fields: [tenantId], references: [id], onDelete: Cascade)
  contact      Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([tenantId, feedbackType])
  @@index([tenantId, contactId])
  @@map("customer_feedbacks")
}

// ----------------------------
// 11. LifecycleTemplate — Industry-specific lifecycle stages
// ----------------------------

model LifecycleTemplate {
  id        String    @id @default(cuid())
  tenantId  String?   @map("tenant_id")
  industry  String?
  name      String
  stages    Json
  isDefault Boolean   @default(false) @map("is_default")
  createdAt DateTime  @default(now()) @map("created_at")

  // Relations (tenantId nullable = global platform template)
  tenant    Tenant?   @relation("TenantLifecycleTemplates", fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([industry])
  @@map("lifecycle_templates")
}

// ----------------------------
// 12. ClientHealthScore — 5-dimension health scoring
// ----------------------------

model ClientHealthScore {
  id           String         @id @default(cuid())
  tenantId     String         @map("tenant_id")
  contactId    String         @map("contact_id")
  overallScore Int            @map("overall_score")
  dimensions   Json
  category     HealthCategory
  calculatedAt DateTime       @default(now()) @map("calculated_at")
  calculatedBy String?        @map("calculated_by")

  // Relations
  tenant       Tenant         @relation("TenantClientHealthScores", fields: [tenantId], references: [id], onDelete: Cascade)
  contact      Contact        @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([tenantId, contactId])
  @@index([tenantId, category])
  @@index([tenantId, calculatedAt])
  @@map("client_health_scores")
}

// ----------------------------
// 13. ClientHealthHistory — Health score change tracking
// ----------------------------

model ClientHealthHistory {
  id               String          @id @default(cuid())
  tenantId         String          @map("tenant_id")
  contactId        String          @map("contact_id")
  previousScore    Int             @map("previous_score")
  newScore         Int             @map("new_score")
  previousCategory HealthCategory  @map("previous_category")
  newCategory      HealthCategory  @map("new_category")
  delta            Int
  trigger          String
  changedAt        DateTime        @default(now()) @map("changed_at")

  // Relations
  tenant           Tenant          @relation("TenantClientHealthHistories", fields: [tenantId], references: [id], onDelete: Cascade)
  contact          Contact         @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([tenantId, contactId])
  @@index([tenantId, changedAt])
  @@map("client_health_histories")
}

// ----------------------------
// 14. SharedContact — Cross-tenant sharing
// ----------------------------

model SharedContact {
  id                 String          @id @default(cuid())
  tenantId           String          @map("tenant_id")
  contactId          String          @map("contact_id")
  sharedWithTenantId String          @map("shared_with_tenant_id")
  permission         SharePermission
  sharedBy           String          @map("shared_by")
  sharedAt           DateTime        @default(now()) @map("shared_at")
  expiresAt          DateTime?       @map("expires_at")

  // Relations
  tenant             Tenant          @relation("TenantSharedContacts", fields: [tenantId], references: [id], onDelete: Cascade)
  sharedWithTenant   Tenant          @relation("SharedWithTenantContacts", fields: [sharedWithTenantId], references: [id], onDelete: Cascade)
  contact            Contact         @relation(fields: [contactId], references: [id], onDelete: Cascade)
  sharedByUser       User            @relation("SharedContactBy", fields: [sharedBy], references: [id])

  @@unique([contactId, sharedWithTenantId])
  @@index([tenantId, contactId])
  @@index([sharedWithTenantId])
  @@map("shared_contacts")
}

// [KAVEN_MODULE:CLIENTS_CRM END]

// ===========================
// FINANCE MODULE
// ===========================
// Gestao financeira completa: plano de contas, contas bancarias,
// lancamentos com dual-date (caixa/competencia), orcamento,
// recorrencias, parcelamento, relatorios DRE/DFC, KPIs.
// Multi-tenant isolado via tenantId em todos os models.

// [KAVEN_MODULE:FINANCE BEGIN]

enum FinancialEntryStatus {
  SCHEDULED
  PENDING
  CONFIRMED
  RECONCILED
}

enum FinanceProjectStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

// ----------------------------
// 1. ChartOfAccount — Hierarchical chart of accounts
// ----------------------------

model ChartOfAccount {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")

  parentId    String?  @map("parent_id")
  code        String   // "1", "1.1", "1.1.1" — ordering and export
  name        String
  type        String   // 'revenue' | 'fixed_expense' | 'variable_expense' | 'investment' | 'financial_movement'
  subtype     String?  // 'recurring' | 'non_recurring'

  // Report mapping
  appearsInDFC Boolean @default(true) @map("appears_in_dfc")
  appearsInDRE Boolean @default(true) @map("appears_in_dre")

  // Balance sheet (future-proof, nullable)
  bsCategory  String?  @map("bs_category") // 'current_asset' | 'non_current_asset' | 'current_liability' | 'non_current_liability' | 'equity'

  isSystem    Boolean  @default(false) @map("is_system")
  isActive    Boolean  @default(true)  @map("is_active")
  sortOrder   Int      @default(0)     @map("sort_order")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")
  deletedAt   DateTime?               @map("deleted_at")

  // Relations
  tenant      Tenant             @relation("TenantChartOfAccounts", fields: [tenantId], references: [id], onDelete: Cascade)
  parent      ChartOfAccount?    @relation("AccountHierarchy", fields: [parentId], references: [id])
  children    ChartOfAccount[]   @relation("AccountHierarchy")
  entryLines  FinancialEntryLine[]
  budgetLines BudgetLine[]

  @@index([tenantId, type])
  @@index([tenantId, parentId])
  @@index([tenantId, code])
  @@map("chart_of_accounts")
}

// ----------------------------
// 2. BankAccount — Bank accounts and credit cards
// ----------------------------

model BankAccount {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")

  name           String
  bankCode       String?  @map("bank_code")
  bankName       String?  @map("bank_name")
  agency         String?
  accountNumber  String?  @map("account_number")
  type           String   // 'checking' | 'savings' | 'cash' | 'investment' | 'credit_card'
  currency       String   @default("BRL")
  initialBalance Decimal  @db.Decimal(15, 2) @default(0) @map("initial_balance")
  initialDate    DateTime @map("initial_date")
  isActive       Boolean  @default(true) @map("is_active")

  // Credit card specific fields (null for other types)
  creditLimit    Decimal?  @db.Decimal(15, 2) @map("credit_limit")
  closingDay     Int?      @map("closing_day")  // 1-31
  dueDay         Int?      @map("due_day")      // 1-31

  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt      @map("updated_at")

  // Relations
  tenant         Tenant               @relation("TenantBankAccounts", fields: [tenantId], references: [id], onDelete: Cascade)
  entryLines     FinancialEntryLine[]
  statements     CreditCardStatement[]

  @@index([tenantId, type, isActive])
  @@map("bank_accounts")
}

// ----------------------------
// 3. CreditCardStatement — Monthly credit card statement
// ----------------------------

model CreditCardStatement {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  bankAccountId  String   @map("bank_account_id")

  referenceMonth Int      @map("reference_month")  // 1-12
  referenceYear  Int      @map("reference_year")
  closingDate    DateTime @map("closing_date")
  dueDate        DateTime @map("due_date")

  totalAmount    Decimal  @db.Decimal(15, 2) @map("total_amount")
  status         String   @default("open")  // 'open' | 'closed' | 'paid'
  paidAt         DateTime? @map("paid_at")
  paidEntryId    String?  @map("paid_entry_id")

  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt      @map("updated_at")

  // Relations
  tenant         Tenant          @relation("TenantCreditCardStatements", fields: [tenantId], references: [id], onDelete: Cascade)
  bankAccount    BankAccount     @relation(fields: [bankAccountId], references: [id])
  entryLines     FinancialEntryLine[]

  @@unique([tenantId, bankAccountId, referenceYear, referenceMonth])
  @@index([tenantId, status, dueDate])
  @@map("credit_card_statements")
}

// ----------------------------
// 4. CostCenter — Cost/Profit center
// ----------------------------

model CostCenter {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")

  name      String
  type      String   // 'cost' | 'profit'
  isActive  Boolean  @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  // Relations
  tenant     Tenant              @relation("TenantCostCenters", fields: [tenantId], references: [id], onDelete: Cascade)
  entryLines FinancialEntryLine[]

  @@index([tenantId, isActive])
  @@map("cost_centers")
}

// ----------------------------
// 5. FinanceProject — Financial project with lifecycle
// ----------------------------

model FinanceProject {
  id            String               @id @default(cuid())
  tenantId      String               @map("tenant_id")
  name          String
  description   String?
  startDate     DateTime             @map("start_date")
  endDate       DateTime?            @map("end_date")
  status        FinanceProjectStatus @default(ACTIVE)
  budgetAmount  Decimal?             @db.Decimal(15, 2) @map("budget_amount")
  actualAmount  Decimal?             @db.Decimal(15, 2) @map("actual_amount")
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt      @map("updated_at")
  deletedAt     DateTime?            @map("deleted_at")

  // Relations
  tenant    Tenant           @relation("TenantFinanceProjects", fields: [tenantId], references: [id], onDelete: Cascade)
  entries   FinancialEntry[] @relation("EntryFinanceProject")

  @@index([tenantId, status])
  @@index([tenantId, startDate, endDate])
  @@map("finance_projects")
}

// ----------------------------
// 6. FinancialEntry — Root financial event
// ----------------------------

model FinancialEntry {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")

  // Dual-date: cash vs accrual
  dateDFC         DateTime @map("date_dfc")  // when money enters/leaves
  dateDRE         DateTime @map("date_dre")  // when revenue/expense is recognized

  type            String   // 'revenue' | 'expense' | 'investment' | 'financial_movement'

  // Transfer linking
  transferPairId  String?  @map("transfer_pair_id")

  description     String?
  totalAmount     Decimal  @db.Decimal(15, 2) @map("total_amount")
  currency        String   @default("BRL")
  exchangeRate    Decimal? @db.Decimal(10, 6) @map("exchange_rate")
  totalAmountBRL  Decimal? @db.Decimal(15, 2) @map("total_amount_brl")

  // Split payment (tax reform)
  taxRetained     Decimal? @db.Decimal(15, 2) @map("tax_retained")
  netAmount       Decimal? @db.Decimal(15, 2) @map("net_amount")

  // Interest/penalty and partial payments
  interestRate    Decimal? @db.Decimal(5, 4)  @map("interest_rate")
  penaltyAmount   Decimal? @db.Decimal(15, 2) @map("penalty_amount")
  paidAmount      Decimal? @db.Decimal(15, 2) @map("paid_amount")

  // Status
  status          FinancialEntryStatus @default(SCHEDULED)
  dueDate         DateTime?            @map("due_date")
  paidAt          DateTime?            @map("paid_at")

  // Period lock
  periodLocked    Boolean  @default(false) @map("period_locked")

  // Balance sheet type (future-proof)
  balanceSheetType String? @map("balance_sheet_type")

  // Recurrence/installment origin
  recurringEntryId  String? @map("recurring_entry_id")
  installmentPlanId String? @map("installment_plan_id")
  installmentNumber Int?    @map("installment_number")

  // Source (cross-module integration)
  sourceType      String?  @map("source_type")
  sourceId        String?  @map("source_id")

  // OFX import reference
  externalRef     String?  @map("external_ref")
  importedAt      DateTime? @map("imported_at")

  // Links
  clientId        String?  @map("client_id")
  entityId        String?  @map("entity_id")
  projectId       String?  @map("project_id")

  tags            String[]
  attachmentUrl   String?  @map("attachment_url")
  notes           String?

  createdById     String   @map("created_by_id")
  updatedById     String?  @map("updated_by_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt      @map("updated_at")
  deletedAt       DateTime?               @map("deleted_at")

  // Relations
  tenant          Tenant               @relation("TenantFinancialEntries", fields: [tenantId], references: [id], onDelete: Cascade)
  lines           FinancialEntryLine[]
  client          Contact?             @relation("FinancialEntryClient", fields: [clientId], references: [id])
  project         FinanceProject?      @relation("EntryFinanceProject", fields: [projectId], references: [id])
  createdBy       User                 @relation("FinancialEntryCreator", fields: [createdById], references: [id])

  @@index([tenantId, dateDFC])
  @@index([tenantId, dateDRE])
  @@index([tenantId, type, status])
  @@index([tenantId, status, dueDate])
  @@index([tenantId, clientId])
  @@index([tenantId, sourceType, sourceId])
  @@index([tenantId, transferPairId])
  @@index([tenantId, installmentPlanId])
  @@map("financial_entries")
}

// ----------------------------
// 7. FinancialEntryLine — Split entry line
// ----------------------------

model FinancialEntryLine {
  id                String   @id @default(cuid())
  tenantId          String   @map("tenant_id")
  entryId           String   @map("entry_id")

  chartOfAccountId  String   @map("chart_of_account_id")
  bankAccountId     String?  @map("bank_account_id")
  costCenterId      String?  @map("cost_center_id")
  statementId       String?  @map("statement_id")

  amount            Decimal  @db.Decimal(15, 2)
  description       String?

  // Relations
  entry         FinancialEntry       @relation(fields: [entryId], references: [id], onDelete: Cascade)
  chartOfAccount ChartOfAccount     @relation(fields: [chartOfAccountId], references: [id])
  bankAccount   BankAccount?        @relation(fields: [bankAccountId], references: [id])
  costCenter    CostCenter?         @relation(fields: [costCenterId], references: [id])
  statement     CreditCardStatement? @relation(fields: [statementId], references: [id])

  @@index([tenantId, entryId])
  @@index([tenantId, chartOfAccountId])
  @@index([tenantId, bankAccountId])
  @@index([tenantId, statementId])
  @@map("financial_entry_lines")
}

// ----------------------------
// 8. InstallmentPlan — Installment plan template
// ----------------------------

model InstallmentPlan {
  id                String   @id @default(cuid())
  tenantId          String   @map("tenant_id")

  description       String
  totalAmount       Decimal  @db.Decimal(15, 2) @map("total_amount")
  installmentCount  Int      @map("installment_count")
  installmentAmount Decimal  @db.Decimal(15, 2) @map("installment_amount")
  firstDueDate      DateTime @map("first_due_date")
  frequency         String   @default("monthly") // 'weekly' | 'monthly' | 'bimonthly'

  chartOfAccountId  String   @map("chart_of_account_id")
  bankAccountId     String?  @map("bank_account_id")
  clientId          String?  @map("client_id")

  status            String   @default("active") // 'active' | 'completed' | 'cancelled'

  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt      @map("updated_at")

  // Relations
  tenant            Tenant   @relation("TenantInstallmentPlans", fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@map("installment_plans")
}

// ----------------------------
// 9. RecurringEntry — Recurring entry template
// ----------------------------

model RecurringEntry {
  id               String    @id @default(cuid())
  tenantId         String    @map("tenant_id")

  description      String
  type             String    // 'revenue' | 'expense'
  amount           Decimal   @db.Decimal(15, 2)
  chartOfAccountId String    @map("chart_of_account_id")
  bankAccountId    String?   @map("bank_account_id")
  costCenterId     String?   @map("cost_center_id")
  clientId         String?   @map("client_id")
  frequency        String    // 'daily' | 'weekly' | 'monthly' | 'bimonthly' | 'quarterly' | 'annual'
  startDate        DateTime  @map("start_date")
  endDate          DateTime? @map("end_date")

  isActive         Boolean   @default(true) @map("is_active")
  lastGeneratedAt  DateTime? @map("last_generated_at")
  nextDueDate      DateTime? @map("next_due_date")

  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt      @map("updated_at")

  // Relations
  tenant           Tenant    @relation("TenantRecurringEntries", fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isActive, nextDueDate])
  @@map("recurring_entries")
}

// ----------------------------
// 10. Budget — Annual budget with scenarios
// ----------------------------

model Budget {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")

  year      Int
  name      String   @default("Annual Budget")
  scenario  String   @default("base") // 'base' | 'conservative' | 'optimistic'
  isActive  Boolean  @default(true)   @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  // Relations
  tenant    Tenant       @relation("TenantBudgets", fields: [tenantId], references: [id], onDelete: Cascade)
  lines     BudgetLine[]

  @@unique([tenantId, year, name, scenario])
  @@index([tenantId, year, isActive])
  @@map("budgets")
}

// ----------------------------
// 11. BudgetLine — Monthly budget per account
// ----------------------------

model BudgetLine {
  id               String   @id @default(cuid())
  budgetId         String   @map("budget_id")
  tenantId         String   @map("tenant_id")
  chartOfAccountId String   @map("chart_of_account_id")

  month            Int      // 1-12
  amount           Decimal  @db.Decimal(15, 2)

  updatedAt        DateTime @updatedAt @map("updated_at")

  // Relations
  budget           Budget         @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  chartOfAccount   ChartOfAccount @relation(fields: [chartOfAccountId], references: [id])

  @@unique([budgetId, chartOfAccountId, month])
  @@index([tenantId, budgetId])
  @@index([tenantId, chartOfAccountId])
  @@map("budget_lines")
}

// ----------------------------
// 12. FinancialProjection — Strategic 3-5 year projection
// ----------------------------

model FinancialProjection {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")

  name        String
  startYear   Int      @map("start_year")
  endYear     Int      @map("end_year")
  isActive    Boolean  @default(true) @map("is_active")

  assumptions Json     // { revenueGrowthRate, headcountGrowth, fixedCostInflation, marginTarget }
  projections Json     // { "2026": { revenue, ebitda }, "2027": {...} }

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  // Relations
  tenant      Tenant   @relation("TenantFinancialProjections", fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isActive])
  @@map("financial_projections")
}

// ----------------------------
// 13. ClosedPeriod — Closed accounting period
// ----------------------------

model ClosedPeriod {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")

  month       Int      // 1-12
  year        Int
  closedAt    DateTime @default(now()) @map("closed_at")
  closedById  String   @map("closed_by_id")

  // Relations
  tenant      Tenant   @relation("TenantClosedPeriods", fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, year, month])
  @@index([tenantId, year])
  @@map("closed_periods")
}

// ----------------------------
// 14. KPIDefinition — KPI template and custom definitions
// ----------------------------

model KPIDefinition {
  id          String   @id @default(cuid())
  tenantId    String?  @map("tenant_id")  // null = global platform KPI

  name        String
  slug        String
  description String?
  unit        String   // 'percent' | 'currency_brl' | 'days' | 'ratio' | 'count'
  formula     String   // expression in simple DSL
  industry    String?  // 'agency' | 'real_estate' | 'ecommerce' | 'law_firm' | 'saas'

  // Threshold alerts
  thresholdGood    Decimal? @db.Decimal(15, 4) @map("threshold_good")
  thresholdWarning Decimal? @db.Decimal(15, 4) @map("threshold_warning")

  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0)    @map("sort_order")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  // Relations
  tenant      Tenant?  @relation("TenantKPIDefinitions", fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([industry, isActive])
  @@index([tenantId, isActive])
  @@map("kpi_definitions")
}

// [KAVEN_MODULE:FINANCE END]
