// ----------------------------
// 1. Campaign — Marketing campaign (email, SMS, WhatsApp, push)
// ----------------------------

model Campaign {
  id               String          @id @default(cuid())
  tenantId         String          @map("tenant_id")
  name             String
  slug             String
  description      String?
  type             String?
  channel          CampaignChannel @default(EMAIL)
  status           CampaignStatus  @default(DRAFT)
  scheduledAt      DateTime?       @map("scheduled_at")
  sentAt           DateTime?       @map("sent_at")
  completedAt      DateTime?       @map("completed_at")
  timezone         String?         @default("UTC")
  budget           Float?
  goalMetric       String?         @map("goal_metric")
  goalValue        Float?          @map("goal_value")
  subject          String?
  body             String?
  htmlContent      String?         @map("html_content")
  templateId       String?         @map("template_id")
  segmentId        String?         @map("segment_id")
  audienceSize     Int?            @map("audience_size")
  audienceSnapshot Json?           @map("audience_snapshot")
  isAbTest         Boolean         @default(false) @map("is_ab_test")
  winnerVariantId  String?         @map("winner_variant_id")
  sentCount        Int             @default(0) @map("sent_count")
  deliveredCount   Int             @default(0) @map("delivered_count")
  openedCount      Int             @default(0) @map("opened_count")
  clickedCount     Int             @default(0) @map("clicked_count")
  bouncedCount     Int             @default(0) @map("bounced_count")
  unsubCount       Int             @default(0) @map("unsub_count")
  convertedCount   Int             @default(0) @map("converted_count")
  tags             String[]        @default([])
  ownerId          String          @map("owner_id")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  deletedAt        DateTime?       @map("deleted_at")

  // Relations
  tenant          Tenant              @relation("TenantCampaigns", fields: [tenantId], references: [id], onDelete: Cascade)
  owner           User                @relation("CampaignOwner", fields: [ownerId], references: [id])
  segment         Segment?            @relation("CampaignSegment", fields: [segmentId], references: [id], onDelete: SetNull)
  variants        CampaignVariant[]
  events          CampaignEvent[]
  utms            CampaignUtm[]
  calendarEntries MarketingCalendar[]
  campaignTags    CampaignTag[]

  @@unique([tenantId, slug])
  @@index([tenantId, status])
  @@index([tenantId, channel])
  @@index([tenantId, scheduledAt])
  @@index([tenantId, deletedAt])
  @@map("campaigns")
}

// ----------------------------
