  @@unique([tenantId, contactId, consentType, channel])
  @@index([tenantId, contactId])
  @@index([tenantId, revokedAt])
  @@map("consent_records")
}

// ----------------------------
// 5. LeadScore — Composite lead scoring per contact
// ----------------------------

model LeadScore {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
