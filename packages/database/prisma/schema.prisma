  @@index([scoreCategory, calculatedAt])
  @@index([overallScore])
  @@map("customer_health_scores")
}

// [KAVEN_MODULE:SAAS_OPS END]

// [KAVEN_MODULE:PROPERTY_MANAGEMENT BEGIN]

// ---------- Enums ----------

enum PropertyType {
  RESIDENTIAL
  COMMERCIAL
  LAND
  MIXED

  @@map("property_type")
}

enum PropertyStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
  UNAVAILABLE

  @@map("property_status")
}

enum UnitType {
  APARTMENT
  HOUSE
  STORE
  OFFICE
  WAREHOUSE
  STUDIO
  GARAGE
  OTHER

  @@map("unit_type")
}

enum LeaseStatus {
  DRAFT
  ACTIVE
  EXPIRING_SOON
  EXPIRED
  TERMINATED
  RENEWED

  @@map("lease_status")
}

enum RentPaymentStatus {
  PENDING
  PAID
  OVERDUE
  PARTIAL
  CANCELLED

  @@map("rent_payment_status")
}

enum GuarantorType {
  GUARANTOR_PERSON
  SURETY_BOND
  CAPITALIZATION
  DEPOSIT
  NONE

  @@map("guarantor_type")
}

enum AdjustmentIndex {
  IGPM
  IPCA
  INPC
  IVAR
  FIXED
  NONE

  @@map("adjustment_index")
}

// ---------- 1. Property ----------

model Property {
  id              String         @id @default(cuid())
  tenantId        String         @map("tenant_id")
  name            String
  type            PropertyType   @default(RESIDENTIAL)
  status          PropertyStatus @default(AVAILABLE)

  // Address
  addressStreet   String         @map("address_street")
  addressNumber   String?        @map("address_number")
  addressComplement String?      @map("address_complement")
  addressNeighborhood String?    @map("address_neighborhood")
  addressCity     String         @map("address_city")
  addressState    String         @map("address_state")
  addressZipCode  String         @map("address_zip_code")
  addressCountry  String         @default("BR") @map("address_country")

  // Details
  area            Float?         // Total area in m²
  marketValue     Float?         @map("market_value")
  registrationNumber String?     @map("registration_number") // Matrícula do imóvel
  iptuNumber      String?        @map("iptu_number")
  notes           String?

  createdById     String         @map("created_by_id")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  deletedAt       DateTime?      @map("deleted_at")

  // Relations
  tenant    Tenant @relation("TenantProperties", fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User   @relation("PropertyCreator", fields: [createdById], references: [id])
  units     PropertyUnit[]
  leases    Lease[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, type])
  @@map("properties")
}

// ---------- 2. PropertyUnit ----------

model PropertyUnit {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  propertyId   String   @map("property_id")
  unitNumber   String   @map("unit_number")
  type         UnitType @default(APARTMENT)
  floor        Int?
  area         Float?   // Area in m²
  bedrooms     Int?
  bathrooms    Int?
  parkingSpots Int?     @map("parking_spots")
  isAvailable  Boolean  @default(true) @map("is_available")
  monthlyRent  Float?   @map("monthly_rent") // Suggested rent value
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  // Relations
  tenant   Tenant   @relation("TenantPropertyUnits", fields: [tenantId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  leases   Lease[]

  @@unique([tenantId, propertyId, unitNumber])
  @@index([tenantId])
  @@index([tenantId, propertyId])
  @@index([tenantId, isAvailable])
  @@map("property_units")
}

// ---------- 3. Renter ----------

model Renter {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  name         String
  email        String?
  phone        String?
  cpf          String?  // Brazilian CPF
  rg           String?  // Brazilian RG
  birthDate    DateTime? @map("birth_date")
  profession   String?
  monthlyIncome Float?  @map("monthly_income")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  // Relations
  tenant     Tenant      @relation("TenantRenters", fields: [tenantId], references: [id], onDelete: Cascade)
  guarantors Guarantor[]
  leases     Lease[]

  @@index([tenantId])
  @@index([tenantId, cpf])
  @@index([tenantId, name])
  @@map("renters")
}

// ---------- 4. Guarantor ----------

model Guarantor {
  id           String        @id @default(cuid())
  tenantId     String        @map("tenant_id")
  renterId     String        @map("renter_id")
  type         GuarantorType @default(GUARANTOR_PERSON)
  name         String
  cpf          String?
  phone        String?
  email        String?
  // For SURETY_BOND / CAPITALIZATION
  policyNumber String?       @map("policy_number")
  insurerName  String?       @map("insurer_name")
  coverageAmount Float?      @map("coverage_amount")
  expiresAt    DateTime?     @map("expires_at")
  notes        String?
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  // Relations
  tenant Tenant @relation("TenantGuarantors", fields: [tenantId], references: [id], onDelete: Cascade)
  renter Renter @relation(fields: [renterId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, renterId])
  @@map("guarantors")
}

// ---------- 5. Lease ----------

model Lease {
  id              String          @id @default(cuid())
  tenantId        String          @map("tenant_id")
  propertyId      String          @map("property_id")
  unitId          String?         @map("unit_id")
  renterId        String          @map("renter_id")
  status          LeaseStatus     @default(DRAFT)

  // Contract terms
  startDate       DateTime        @map("start_date")
  endDate         DateTime        @map("end_date")
  monthlyRent     Float           @map("monthly_rent")
  adjustmentIndex AdjustmentIndex @default(IGPM) @map("adjustment_index")
  adjustmentMonth Int?            @map("adjustment_month") // 1-12, month for annual adjustment
  deposit         Float?          // Caução
  lateFeePercent  Float?          @default(2) @map("late_fee_percent")
  lateFeeDaily    Float?          @default(0.033) @map("late_fee_daily") // Mora diária %

  // Audit
  statusChangedAt DateTime?       @map("status_changed_at")
  statusReason    String?         @map("status_reason")
  renewedFromId   String?         @map("renewed_from_id")

  createdById     String          @map("created_by_id")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  deletedAt       DateTime?       @map("deleted_at")

  // Relations
  tenant       Tenant       @relation("TenantLeases", fields: [tenantId], references: [id], onDelete: Cascade)
  property     Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit         PropertyUnit? @relation(fields: [unitId], references: [id], onDelete: SetNull)
  renter       Renter       @relation(fields: [renterId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("LeaseCreator", fields: [createdById], references: [id])
  renewedFrom  Lease?       @relation("LeaseRenewal", fields: [renewedFromId], references: [id])
  renewals     Lease[]      @relation("LeaseRenewal")
  rentPayments RentPayment[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, propertyId])
  @@index([tenantId, renterId])
  @@index([tenantId, endDate])
  @@map("leases")
}

// ---------- 6. RentPayment ----------

model RentPayment {
  id           String            @id @default(cuid())
  tenantId     String            @map("tenant_id")
  leaseId      String            @map("lease_id")
  dueDate      DateTime          @map("due_date")
  amount       Float             // Expected amount
  paidAmount   Float?            @map("paid_amount")
  paidDate     DateTime?         @map("paid_date")
  status       RentPaymentStatus @default(PENDING)
  lateFee      Float?            @map("late_fee")
  notes        String?
  referenceMonth String?         @map("reference_month") // "2026-03"
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  // Relations
  tenant Tenant @relation("TenantRentPayments", fields: [tenantId], references: [id], onDelete: Cascade)
  lease  Lease  @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, leaseId])
  @@index([tenantId, status])
  @@index([tenantId, dueDate])
  @@map("rent_payments")
}

// [KAVEN_MODULE:PROPERTY_MANAGEMENT END]

// [KAVEN_MODULE:INVENTORY_FULFILLMENT BEGIN]

// ---------- Enums ----------

enum WarehouseType {
  MAIN
  STORE
  VIRTUAL
  TRANSIT

  @@map("warehouse_type")
}

enum StockMovementType {
  IN
  OUT
  RESERVE
  RELEASE
  ADJUST
  TRANSFER
  RETURN_SUPPLIER
  RETURN_CUSTOMER

  @@map("stock_movement_type")
}

enum SalesOrderStatus {
  DRAFT
  CONFIRMED
  PICKING
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED

  @@map("sales_order_status")
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  CONFIRMED
  PARTIAL_RECEIVED
  RECEIVED
  CANCELLED

  @@map("purchase_order_status")
}

// ---------- 1. Warehouse ----------

model Warehouse {
  id          String        @id @default(cuid())
  tenantId    String        @map("tenant_id")
  name        String
  code        String
  type        WarehouseType @default(MAIN)
  address     Json?         // Full address object
  isActive    Boolean       @default(true) @map("is_active")
  isDefault   Boolean       @default(false) @map("is_default")
  createdById String        @map("created_by_id")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  deletedAt   DateTime?     @map("deleted_at")

  // Relations
  tenant     Tenant      @relation("TenantWarehouses", fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy  User        @relation("WarehouseCreator", fields: [createdById], references: [id])
  stockItems StockItem[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@map("warehouses")
}

// ---------- 2. StockItem ----------

model StockItem {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  sku           String
  productId     String?  @map("product_id") // FK to existing Product (nullable for standalone SKUs)
  warehouseId   String   @map("warehouse_id")
  name          String   // Product/SKU name for display
  quantity      Int      @default(0)
  reservedQty   Int      @default(0) @map("reserved_qty")
  reorderPoint  Int?     @map("reorder_point")
  reorderQty    Int?     @map("reorder_qty")
  maxQty        Int?     @map("max_qty")
  location      String?  // Shelf/slot: "A1-B2-C3"
  costPrice     Float?   @map("cost_price") // Weighted average cost
  barcode       String?
  lastCountedAt DateTime? @map("last_counted_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  // Relations
  tenant           Tenant          @relation("TenantStockItems", fields: [tenantId], references: [id], onDelete: Cascade)
  warehouse        Warehouse       @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  movements        StockMovement[]
  salesOrderItems  SalesOrderItem[]
  purchaseOrderItems PurchaseOrderItem[]

  @@unique([tenantId, sku, warehouseId])
  @@index([tenantId])
  @@index([tenantId, warehouseId])
  @@index([tenantId, sku])
  @@map("stock_items")
}

// ---------- 3. StockMovement ----------

model StockMovement {
  id            String           @id @default(cuid())
  tenantId      String           @map("tenant_id")
  stockItemId   String           @map("stock_item_id")
  type          StockMovementType
  quantity      Int              // Always positive; direction implied by type
  reason        String?
  reference     String?          // External ref (PO number, SO number, etc.)
  referenceType String?          @map("reference_type") // "SALES_ORDER", "PURCHASE_ORDER", "MANUAL"
  referenceId   String?          @map("reference_id")
  costPerUnit   Float?           @map("cost_per_unit")
  createdById   String           @map("created_by_id")
  createdAt     DateTime         @default(now()) @map("created_at")

  // Relations — append-only: no updatedAt
  tenant    Tenant    @relation("TenantStockMovements", fields: [tenantId], references: [id], onDelete: Cascade)
  stockItem StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  createdBy User      @relation("StockMovementCreator", fields: [createdById], references: [id])

  @@index([tenantId])
  @@index([tenantId, stockItemId])
  @@index([tenantId, type])
  @@index([tenantId, createdAt])
  @@map("stock_movements")
}

// ---------- 4. SalesOrder ----------

model SalesOrder {
  id             String           @id @default(cuid())
  tenantId       String           @map("tenant_id")
  orderNumber    String           @map("order_number")
  status         SalesOrderStatus @default(DRAFT)
  customerName   String?          @map("customer_name")
  customerEmail  String?          @map("customer_email")
  shippingAddress Json?           @map("shipping_address")
  subtotal       Float            @default(0)
  discount       Float            @default(0)
  shippingCost   Float            @default(0) @map("shipping_cost")
  total          Float            @default(0)
  notes          String?
  statusChangedAt DateTime?       @map("status_changed_at")
  statusHistory  Json?            @map("status_history") // Array of { status, timestamp, userId }
  shippedAt      DateTime?        @map("shipped_at")
  deliveredAt    DateTime?        @map("delivered_at")
  cancelledAt    DateTime?        @map("cancelled_at")
  cancelReason   String?          @map("cancel_reason")
  trackingCode   String?          @map("tracking_code")
  createdById    String           @map("created_by_id")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  deletedAt      DateTime?        @map("deleted_at")

  // Relations
  tenant    Tenant           @relation("TenantSalesOrders", fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User             @relation("SalesOrderCreator", fields: [createdById], references: [id])
  items     SalesOrderItem[]

  @@unique([tenantId, orderNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@map("sales_orders")
}

// ---------- 5. SalesOrderItem ----------

model SalesOrderItem {
  id           String @id @default(cuid())
  tenantId     String @map("tenant_id")
  salesOrderId String @map("sales_order_id")
  stockItemId  String @map("stock_item_id")
  quantity     Int
  unitPrice    Float  @map("unit_price")
  total        Float  @default(0)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  tenant     Tenant     @relation("TenantSalesOrderItems", fields: [tenantId], references: [id], onDelete: Cascade)
  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  stockItem  StockItem  @relation(fields: [stockItemId], references: [id], onDelete: Cascade)

  @@index([tenantId, salesOrderId])
  @@map("sales_order_items")
}

// ---------- 6. PurchaseOrder ----------

model PurchaseOrder {
  id              String              @id @default(cuid())
  tenantId        String              @map("tenant_id")
  orderNumber     String              @map("order_number")
  status          PurchaseOrderStatus @default(DRAFT)
  supplierName    String              @map("supplier_name")
  supplierEmail   String?             @map("supplier_email")
  supplierPhone   String?             @map("supplier_phone")
  expectedDate    DateTime?           @map("expected_date")
  receivedDate    DateTime?           @map("received_date")
  subtotal        Float               @default(0)
  shippingCost    Float               @default(0) @map("shipping_cost")
  total           Float               @default(0)
  notes           String?
  statusChangedAt DateTime?           @map("status_changed_at")
  statusHistory   Json?               @map("status_history")
  createdById     String              @map("created_by_id")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  deletedAt       DateTime?           @map("deleted_at")

  // Relations
  tenant    Tenant              @relation("TenantPurchaseOrders", fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User                @relation("PurchaseOrderCreator", fields: [createdById], references: [id])
  items     PurchaseOrderItem[]

  @@unique([tenantId, orderNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@map("purchase_orders")
}

// ---------- 7. PurchaseOrderItem ----------

model PurchaseOrderItem {
  id               String   @id @default(cuid())
  tenantId         String   @map("tenant_id")
  purchaseOrderId  String   @map("purchase_order_id")
  stockItemId      String   @map("stock_item_id")
  quantity         Int
  unitCost         Float    @map("unit_cost")
  receivedQuantity Int      @default(0) @map("received_quantity")
  total            Float    @default(0)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Relations
  tenant        Tenant        @relation("TenantPurchaseOrderItems", fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  stockItem     StockItem     @relation(fields: [stockItemId], references: [id], onDelete: Cascade)

  @@index([tenantId, purchaseOrderId])
  @@map("purchase_order_items")
}

// [KAVEN_MODULE:INVENTORY_FULFILLMENT END]

// [KAVEN_MODULE:REMOTE_WORK BEGIN]

// ===========================
// REMOTE / HYBRID WORK MODULE
// ===========================
// Time tracking (timer + manual + timesheet approval), async standups,
// work schedules, timezone management. Async-first, zero surveillance.
// Integrates: people_hr (Employee), projects (Project/Task)

// ---------- Enums ----------

enum TimesheetStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED

  @@map("timesheet_status")
}

enum WorkScheduleType {
  FULL_TIME
  PART_TIME
  FLEXIBLE

  @@map("work_schedule_type")
}

enum StandupStatus {
  SUBMITTED
  SKIPPED

  @@map("standup_status")
}

// ---------- Models ----------

// 1. RemoteTimeEntry — Time tracking for remote workers (timer + manual)
model RemoteTimeEntry {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  employeeId      String    @map("employee_id")
  projectId       String?   @map("project_id")
  taskId          String?   @map("task_id")
  description     String?
  startTime       DateTime  @map("start_time")
  endTime         DateTime? @map("end_time")
  durationMinutes Int       @default(0) @map("duration_minutes")
  isRunning       Boolean   @default(false) @map("is_running")
  billable        Boolean   @default(true)
  notes           String?

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  tenant          Tenant    @relation("TenantRemoteTimeEntries", fields: [tenantId], references: [id], onDelete: Cascade)
  employee        Employee  @relation("EmployeeRemoteTimeEntries", fields: [employeeId], references: [id])

  @@index([tenantId, employeeId])
  @@index([tenantId, projectId])
  @@index([tenantId, isRunning])
  @@index([tenantId, startTime])
  @@map("remote_time_entries")
}

// 2. BillingRate — Hourly rate per employee/project combination
model BillingRate {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  employeeId    String   @map("employee_id")
  projectId     String?  @map("project_id")
  hourlyRate    Decimal  @db.Decimal(10, 2) @map("hourly_rate")
  currency      String   @default("BRL")
  effectiveFrom DateTime @map("effective_from")
  effectiveTo   DateTime? @map("effective_to")

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  tenant        Tenant   @relation("TenantBillingRates", fields: [tenantId], references: [id], onDelete: Cascade)
  employee      Employee @relation("EmployeeBillingRates", fields: [employeeId], references: [id])

  @@index([tenantId, employeeId])
  @@index([tenantId, employeeId, effectiveFrom])
  @@map("billing_rates")
}

// 3. TimesheetPeriod — Weekly timesheet with approval workflow
model TimesheetPeriod {
  id            String          @id @default(cuid())
  tenantId      String          @map("tenant_id")
  employeeId    String          @map("employee_id")
  startDate     DateTime        @map("start_date") @db.Date
  endDate       DateTime        @map("end_date") @db.Date
  status        TimesheetStatus @default(DRAFT)
  totalMinutes  Int             @default(0) @map("total_minutes")
  submittedAt   DateTime?       @map("submitted_at")
  approvedById  String?         @map("approved_by_id")
  approvedAt    DateTime?       @map("approved_at")
  rejectedAt    DateTime?       @map("rejected_at")
  rejectionNote String?         @map("rejection_note")

  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  // Relations
  tenant        Tenant          @relation("TenantTimesheetPeriods", fields: [tenantId], references: [id], onDelete: Cascade)
  employee      Employee        @relation("EmployeeTimesheetPeriods", fields: [employeeId], references: [id])

  @@unique([tenantId, employeeId, startDate])
  @@index([tenantId, status])
  @@index([tenantId, employeeId])
  @@map("timesheet_periods")
}

// 4. WorkSchedule — Employee work schedule configuration
model WorkSchedule {
  id            String           @id @default(cuid())
  tenantId      String           @map("tenant_id")
  employeeId    String           @map("employee_id")
  type          WorkScheduleType @default(FULL_TIME)
  effectiveFrom DateTime         @map("effective_from") @db.Date
  effectiveTo   DateTime?        @map("effective_to") @db.Date

  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  // Relations
  tenant        Tenant           @relation("TenantWorkSchedules", fields: [tenantId], references: [id], onDelete: Cascade)
  employee      Employee         @relation("EmployeeWorkSchedules", fields: [employeeId], references: [id])
  workDays      WorkDay[]

  @@index([tenantId, employeeId])
  @@map("work_schedules")
}

// 5. WorkDay — Per-day availability within a schedule
model WorkDay {
  id             String   @id @default(cuid())
  workScheduleId String   @map("work_schedule_id")
  dayOfWeek      Int      @map("day_of_week") // 0=Sunday, 6=Saturday
  isWorkDay      Boolean  @default(true) @map("is_work_day")
  availableFrom  String?  @map("available_from") // HH:mm format
  availableTo    String?  @map("available_to")   // HH:mm format

  // Relations
  workSchedule   WorkSchedule @relation(fields: [workScheduleId], references: [id], onDelete: Cascade)

  @@unique([workScheduleId, dayOfWeek])
  @@map("work_days")
}

// 6. MeetingFreeBlock — Deep work protected blocks
model MeetingFreeBlock {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  employeeId     String   @map("employee_id")
  dayOfWeek      Int      @map("day_of_week") // 0=Sunday, 6=Saturday
  startTime      String   @map("start_time") // HH:mm format
  endTime        String   @map("end_time")   // HH:mm format
  label          String?  // e.g., "Deep Work", "Focus Time"

  createdAt      DateTime @default(now()) @map("created_at")

  // Relations
  tenant         Tenant   @relation("TenantMeetingFreeBlocks", fields: [tenantId], references: [id], onDelete: Cascade)
  employee       Employee @relation("EmployeeMeetingFreeBlocks", fields: [employeeId], references: [id])

  @@index([tenantId, employeeId])
  @@map("meeting_free_blocks")
}

// 7. TimezoneConfig — Employee timezone for overlap calculation
model TimezoneConfig {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  employeeId  String   @unique @map("employee_id")
  timezone    String   // IANA timezone (e.g., "America/Sao_Paulo")
  utcOffset   String   @map("utc_offset") // e.g., "-03:00"

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  tenant      Tenant   @relation("TenantTimezoneConfigs", fields: [tenantId], references: [id], onDelete: Cascade)
  employee    Employee @relation("EmployeeTimezoneConfig", fields: [employeeId], references: [id])

  @@index([tenantId])
  @@map("timezone_configs")
}

// 8. AsyncStandup — Async standup prompt configuration
model AsyncStandup {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  name        String
  cronExpr    String   @map("cron_expr") // e.g., "0 9 * * 1-5"
  isActive    Boolean  @default(true) @map("is_active")
  prompts     Json     @default("[]") // JSON array of question strings
  channelId   String?  @map("channel_id") // FK to TeamChannel (optional)

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  tenant      Tenant   @relation("TenantAsyncStandups", fields: [tenantId], references: [id], onDelete: Cascade)
  responses   StandupResponse[]

  @@index([tenantId])
  @@map("async_standups")
}

// 9. StandupResponse — Individual standup submission
model StandupResponse {
  id           String       @id @default(cuid())
  tenantId     String       @map("tenant_id")
  standupId    String       @map("standup_id")
  employeeId   String       @map("employee_id")
  yesterday    String?
  today        String?
  blockers     String?
  videoUrl     String?      @map("video_url") // Loom link
  status       StandupStatus @default(SUBMITTED)
  submittedAt  DateTime     @default(now()) @map("submitted_at")

  createdAt    DateTime     @default(now()) @map("created_at")

  // Relations
  tenant       Tenant       @relation("TenantStandupResponses", fields: [tenantId], references: [id], onDelete: Cascade)
  standup      AsyncStandup @relation(fields: [standupId], references: [id], onDelete: Cascade)
  employee     Employee     @relation("EmployeeStandupResponses", fields: [employeeId], references: [id])

  @@index([tenantId, standupId])
  @@index([tenantId, employeeId])
  @@index([standupId, submittedAt])
  @@map("standup_responses")
}

// [KAVEN_MODULE:REMOTE_WORK END]

// [KAVEN_MODULE:TEAM_COLLABORATION BEGIN]

// ===========================
// TEAM COLLABORATION MODULE
// ===========================
// Semantic channels, async standups, meeting scheduling.
// Integration-first: messaging deferred to Slack/Teams.
// Native fallback: channels + threading + RSVP.

// ---------- Enums ----------

enum ChannelType {
  PROJECT
  DEPARTMENT
  GENERAL
  CUSTOM

  @@map("channel_type")
}

enum ChannelMemberRole {
  OWNER
  ADMIN
  MEMBER

  @@map("channel_member_role")
}

enum RSVPStatus {
  PENDING
  ACCEPTED
  DECLINED
  TENTATIVE

  @@map("rsvp_status")
}

enum TeamMeetingType {
  STANDUP
  PLANNING
  RETRO
  ONE_ON_ONE
  REVIEW
  CUSTOM

  @@map("team_meeting_type")
}

// ---------- Models ----------

// 1. TeamChannel — Semantic channel linked to project/department
model TeamChannel {
  id          String      @id @default(cuid())
  tenantId    String      @map("tenant_id")
  name        String
  description String?
  type        ChannelType @default(GENERAL)
  projectId   String?     @map("project_id") // Optional FK to Project
  isArchived  Boolean     @default(false) @map("is_archived")

  createdById String      @map("created_by_id")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  // Relations
  tenant      Tenant            @relation("TenantTeamChannels", fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy   User              @relation("ChannelCreator", fields: [createdById], references: [id])
  members     TeamChannelMember[]
  updates     TeamUpdate[]
  meetings    TeamMeeting[]

  @@unique([tenantId, name])
  @@index([tenantId, type])
  @@index([tenantId, projectId])
  @@map("team_channels")
}

// 2. TeamChannelMember — Channel membership with roles
model TeamChannelMember {
  id        String            @id @default(cuid())
  tenantId  String            @map("tenant_id")
  channelId String            @map("channel_id")
  userId    String            @map("user_id")
  role      ChannelMemberRole @default(MEMBER)
  joinedAt  DateTime          @default(now()) @map("joined_at")

  // Relations
  tenant    Tenant      @relation("TenantTeamChannelMembers", fields: [tenantId], references: [id], onDelete: Cascade)
  channel   TeamChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user      User        @relation("ChannelMemberships", fields: [userId], references: [id])

  @@unique([channelId, userId])
  @@index([tenantId, userId])
  @@map("team_channel_members")
}

// 3. TeamUpdate — Async standup/update entries
model TeamUpdate {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  channelId   String   @map("channel_id")
  authorId    String   @map("author_id")
  yesterday   String?
  today       String?
  blockers    String?
  videoUrl    String?  @map("video_url") // Loom link
  mood        String?  // emoji or keyword

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  tenant      Tenant      @relation("TenantTeamUpdates", fields: [tenantId], references: [id], onDelete: Cascade)
  channel     TeamChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author      User        @relation("TeamUpdateAuthor", fields: [authorId], references: [id])

  @@index([tenantId, channelId])
  @@index([channelId, createdAt])
  @@map("team_updates")
}

// 4. TeamMeeting — Meeting metadata with external video link
model TeamMeeting {
  id              String          @id @default(cuid())
  tenantId        String          @map("tenant_id")
  title           String
  description     String?
  type            TeamMeetingType @default(CUSTOM)
  scheduledAt     DateTime        @map("scheduled_at")
  durationMinutes Int             @default(30) @map("duration_minutes")
  externalLink    String?         @map("external_link") // Meet/Zoom/Teams URL
  channelId       String?         @map("channel_id")
  createdById     String          @map("created_by_id")

  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  // Relations
  tenant          Tenant              @relation("TenantTeamMeetings", fields: [tenantId], references: [id], onDelete: Cascade)
  channel         TeamChannel?        @relation(fields: [channelId], references: [id], onDelete: SetNull)
  createdBy       User                @relation("TeamMeetingCreator", fields: [createdById], references: [id])
  participants    TeamMeetingParticipant[]

  @@index([tenantId, scheduledAt])
  @@index([tenantId, channelId])
  @@map("team_meetings")
}

// 5. TeamMeetingParticipant — RSVP per participant
model TeamMeetingParticipant {
  id         String     @id @default(cuid())
  tenantId   String     @map("tenant_id")
  meetingId  String     @map("meeting_id")
  userId     String     @map("user_id")
  rsvpStatus RSVPStatus @default(PENDING) @map("rsvp_status")

  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  // Relations
  tenant     Tenant      @relation("TenantTeamMeetingParticipants", fields: [tenantId], references: [id], onDelete: Cascade)
  meeting    TeamMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user       User        @relation("TeamMeetingParticipations", fields: [userId], references: [id])

  @@unique([meetingId, userId])
  @@index([tenantId, userId])
  @@map("team_meeting_participants")
}

// [KAVEN_MODULE:TEAM_COLLABORATION END]

// [KAVEN_MODULE:FINANCES_BI BEGIN]

// ===========================
// FINANCES TRACKING BI MODULE
// ===========================
// BI/reporting layer on top of Finance module. DRE (income statement),
// DFC (cash flow statement), and financial KPI dashboards.
// Does NOT store transactions — transforms FinancialEntry data into intelligence.

// ---------- Enums ----------

enum DREBasis {
  ACCRUAL
  CASH

  @@map("dre_basis")
}

enum CashFlowCategory {
  OPERATING
  INVESTING
  FINANCING

  @@map("cash_flow_category")
}

enum IndicatorStatus {
  GREEN
  AMBER
  RED

  @@map("indicator_status")
}

// ---------- Models ----------

// 1. DRESnapshot — Income statement snapshot
model DRESnapshot {
  id                String   @id @default(cuid())
  tenantId          String   @map("tenant_id")
  period            DateTime @db.Date // Month reference (YYYY-MM-01)
  basis             DREBasis @default(ACCRUAL)
  grossRevenue      Decimal  @db.Decimal(15, 2) @map("gross_revenue")
  deductions        Decimal  @db.Decimal(15, 2) @default(0)
  netRevenue        Decimal  @db.Decimal(15, 2) @map("net_revenue")
  cogs              Decimal  @db.Decimal(15, 2) @default(0) // Cost of goods sold
  grossProfit       Decimal  @db.Decimal(15, 2) @map("gross_profit")
  operatingExpenses Decimal  @db.Decimal(15, 2) @default(0) @map("operating_expenses")
  ebitda            Decimal  @db.Decimal(15, 2) @default(0)
  depreciation      Decimal  @db.Decimal(15, 2) @default(0)
  financialResult   Decimal  @db.Decimal(15, 2) @default(0) @map("financial_result")
  taxExpenses       Decimal  @db.Decimal(15, 2) @default(0) @map("tax_expenses")
  netIncome         Decimal  @db.Decimal(15, 2) @map("net_income")
  metadata          Json?

  calculatedAt      DateTime @default(now()) @map("calculated_at")
  createdAt         DateTime @default(now()) @map("created_at")

  // Relations
  tenant            Tenant   @relation("TenantDRESnapshots", fields: [tenantId], references: [id], onDelete: Cascade)
  breakdowns        DRECategoryBreakdown[]

  @@unique([tenantId, period, basis])
  @@index([tenantId, period])
  @@map("dre_snapshots")
}

// 2. DRECategoryBreakdown — Per-account breakdown within DRE
model DRECategoryBreakdown {
  id            String   @id @default(cuid())
  dreSnapshotId String   @map("dre_snapshot_id")
  accountId     String   @map("account_id")
  accountName   String   @map("account_name")
  accountCode   String   @map("account_code")
  level         Int      @default(1) // Hierarchy depth (1, 2, 3)
  amount        Decimal  @db.Decimal(15, 2)
  percentage    Decimal? @db.Decimal(5, 2) // % of net revenue

  // Relations
  dreSnapshot   DRESnapshot @relation(fields: [dreSnapshotId], references: [id], onDelete: Cascade)

  @@index([dreSnapshotId, level])
  @@map("dre_category_breakdowns")
}

// 3. CashFlowSnapshot — Cash flow statement (FCO/FCI/FCF)
model CashFlowSnapshot {
  id                String   @id @default(cuid())
  tenantId          String   @map("tenant_id")
  period            DateTime @db.Date // Month reference
  operatingCashFlow Decimal  @db.Decimal(15, 2) @map("operating_cash_flow")
  investingCashFlow Decimal  @db.Decimal(15, 2) @map("investing_cash_flow")
  financingCashFlow Decimal  @db.Decimal(15, 2) @map("financing_cash_flow")
  netCashFlow       Decimal  @db.Decimal(15, 2) @map("net_cash_flow")
  openingBalance    Decimal  @db.Decimal(15, 2) @map("opening_balance")
  closingBalance    Decimal  @db.Decimal(15, 2) @map("closing_balance")
  metadata          Json?

  calculatedAt      DateTime @default(now()) @map("calculated_at")
  createdAt         DateTime @default(now()) @map("created_at")

  // Relations
  tenant            Tenant   @relation("TenantCashFlowSnapshots", fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, period])
  @@index([tenantId, period])
  @@map("cash_flow_snapshots")
}

// 4. FinancialIndicator — Cached KPI indicator
model FinancialIndicator {
  id            String          @id @default(cuid())
  tenantId      String          @map("tenant_id")
  period        DateTime        @db.Date
  indicatorKey  String          @map("indicator_key") // e.g., "gross_margin", "ebitda", "burn_rate"
  value         Decimal         @db.Decimal(15, 4)
  previousValue Decimal?        @db.Decimal(15, 4) @map("previous_value")
  delta         Decimal?        @db.Decimal(15, 4)
  status        IndicatorStatus @default(GREEN)
  unit          String          @default("percentage") // percentage, currency, months

  calculatedAt  DateTime        @default(now()) @map("calculated_at")

  // Relations
  tenant        Tenant          @relation("TenantFinancialIndicators", fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, period, indicatorKey])
  @@index([tenantId, indicatorKey])
  @@map("financial_indicators")
}

// [KAVEN_MODULE:FINANCES_BI END]

// [KAVEN_MODULE:SAAS_ANALYTICS BEGIN]

// ===========================
// SAAS ANALYTICS MODULE (extends SaaS Ops)
// ===========================
// Additional analytics views: cohort retention heatmap data,
// health score alert rules, expansion opportunity detection.
// Extends existing CohortAnalysis, CustomerHealthScore, FeatureAdoptionLog.

// ---------- Models ----------

// 1. HealthScoreAlertRule — Configurable alert rules for health scores
model HealthScoreAlertRule {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  name            String
  condition       String   // e.g., "no_login_14d", "payment_overdue_7d", "single_feature_use"
  threshold       Int      @default(0)
  severity        String   @default("warning") // info, warning, critical
  isActive        Boolean  @default(true) @map("is_active")
  notifyChannel   String?  @map("notify_channel") // email, slack, in-app
  metadata        Json?

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  tenant          Tenant   @relation("TenantHealthScoreAlertRules", fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isActive])
  @@map("health_score_alert_rules")
}

// 2. HealthScoreAlert — Triggered alert instances
model HealthScoreAlert {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  alertedTenantId String   @map("alerted_tenant_id") // The tenant being alerted about
  ruleId          String   @map("rule_id")
  ruleName        String   @map("rule_name")
  healthScore     Int      @map("health_score")
  category        String   // HEALTHY, AT_RISK, CRITICAL
  resolvedAt      DateTime? @map("resolved_at")
  metadata        Json?

  createdAt       DateTime @default(now()) @map("created_at")

  // Relations
  tenant          Tenant   @relation("TenantHealthScoreAlerts", fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([alertedTenantId])
  @@index([ruleId])
  @@map("health_score_alerts")
}

// 3. ExpansionOpportunity — Detected expansion/upsell opportunity
model ExpansionOpportunity {
  id                   String   @id @default(cuid())
  tenantId             String   @map("tenant_id")
  targetTenantId       String   @map("target_tenant_id") // Tenant that could expand
  currentPlanName      String   @map("current_plan_name")
  suggestedPlanName    String   @map("suggested_plan_name")
  expansionSignalScore Int      @map("expansion_signal_score")
  featuresThatDrove    Json?    @map("features_that_drove")
  estimatedMrrIncrease Decimal? @db.Decimal(10, 2) @map("estimated_mrr_increase")
  status               String   @default("detected") // detected, contacted, converted, dismissed
  convertedAt          DateTime? @map("converted_at")
  metadata             Json?

  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  // Relations
  tenant               Tenant   @relation("TenantExpansionOpportunities", fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([targetTenantId])
  @@index([expansionSignalScore])
  @@map("expansion_opportunities")
}

// [KAVEN_MODULE:SAAS_ANALYTICS END]

// [KAVEN_MODULE:ASSET_MANAGEMENT BEGIN]

// ===========================
// ASSET MANAGEMENT MODULE (Admin Extensions)
// ===========================
// Company equipment and asset tracking with assignment to employees.
// Extends the existing Admin module with physical/digital asset management.

// ---------- Enums ----------

enum EquipmentStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
  RETIRED
  LOST

  @@map("equipment_status")
}

enum EquipmentCategory {
  LAPTOP
  DESKTOP
  MONITOR
  PHONE
  TABLET
  PERIPHERAL
  FURNITURE
  VEHICLE
  SOFTWARE_LICENSE
  OTHER

  @@map("equipment_category")
}

enum AssetCondition {
  NEW
  GOOD
  FAIR
  POOR
  DAMAGED

  @@map("asset_condition")
}

enum AssignmentStatus {
  ACTIVE
  RETURNED
  LOST
  DAMAGED

  @@map("assignment_status")
}

// ---------- Models ----------

// 1. Equipment — Company equipment catalog
model Equipment {
  id              String            @id @default(cuid())
  tenantId        String            @map("tenant_id")
  name            String
  description     String?
  category        EquipmentCategory @default(OTHER)
  brand           String?
  model           String?
  serialNumber    String?           @map("serial_number")
  status          EquipmentStatus   @default(AVAILABLE)
  condition       AssetCondition    @default(NEW)
  purchaseDate    DateTime?         @map("purchase_date")
  purchasePrice   Decimal?          @db.Decimal(10, 2) @map("purchase_price")
  warrantyExpiry  DateTime?         @map("warranty_expiry")
  notes           String?
  metadata        Json?

  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  deletedAt       DateTime?         @map("deleted_at")

  // Relations
  tenant          Tenant            @relation("TenantEquipment", fields: [tenantId], references: [id], onDelete: Cascade)
  assignments     AssetAssignment[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, category])
  @@index([tenantId, serialNumber])
  @@map("equipment")
}

// 2. AssetRegistry — Central asset register for tracking all company assets
model AssetRegistry {
  id              String          @id @default(cuid())
  tenantId        String          @map("tenant_id")
  assetTag        String          @map("asset_tag") // Unique internal tag (e.g., "KVN-0042")
  name            String
  description     String?
  category        String          // Free-form category for non-equipment assets
  location        String?
  responsibleId   String?         @map("responsible_id") // Person responsible (not necessarily assigned to)
  acquisitionDate DateTime?       @map("acquisition_date")
  acquisitionCost Decimal?        @db.Decimal(10, 2) @map("acquisition_cost")
  currentValue    Decimal?        @db.Decimal(10, 2) @map("current_value")
  depreciationRate Decimal?       @db.Decimal(5, 2) @map("depreciation_rate") // Annual %
  isActive        Boolean         @default(true) @map("is_active")
  metadata        Json?

  createdById     String          @map("created_by_id")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  // Relations
  tenant          Tenant          @relation("TenantAssetRegistries", fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy       User            @relation("AssetRegistryCreator", fields: [createdById], references: [id])

  @@unique([tenantId, assetTag])
  @@index([tenantId])
  @@index([tenantId, category])
  @@index([tenantId, isActive])
  @@map("asset_registries")
}

// 3. AssetAssignment — Assignment of equipment to employees
model AssetAssignment {
  id              String           @id @default(cuid())
  tenantId        String           @map("tenant_id")
  equipmentId     String           @map("equipment_id")
  assignedToId    String           @map("assigned_to_id")
  status          AssignmentStatus @default(ACTIVE)
  assignedAt      DateTime         @default(now()) @map("assigned_at")
  returnedAt      DateTime?        @map("returned_at")
  expectedReturn  DateTime?        @map("expected_return")
  notes           String?
  condition       AssetCondition   @default(GOOD) @map("condition_at_assignment")

  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  // Relations
  tenant          Tenant           @relation("TenantAssetAssignments", fields: [tenantId], references: [id], onDelete: Cascade)
  equipment       Equipment        @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  assignedTo      User             @relation("AssetAssignee", fields: [assignedToId], references: [id])

  @@index([tenantId])
  @@index([tenantId, equipmentId])
  @@index([tenantId, assignedToId])
  @@index([tenantId, status])
  @@map("asset_assignments")
}

// [KAVEN_MODULE:ASSET_MANAGEMENT END]
