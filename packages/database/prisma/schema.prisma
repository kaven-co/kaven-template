// ===========================
// DOCUMENTS + KNOWLEDGE BASE MODULE
// ===========================
// Gestão documental completa: folders, versionamento, comentários,
// compartilhamento granular, templates e base de conhecimento (KB).
// Multi-tenant isolado via tenantId em todos os models.

// [KAVEN_MODULE:DOCUMENTS_KB BEGIN]

enum DocumentStatus {
  DRAFT
  UNDER_REVIEW
  APPROVED
  PUBLISHED
  ARCHIVED
}

enum DocumentVisibility {
  PRIVATE
  FOLDER_MEMBERS
  TENANT
}

enum SharePermission {
  VIEWER
  COMMENTER
  EDITOR
  ADMIN
}

enum KBArticleStatus {
  DRAFT
  PUBLISHED
  NEEDS_REVIEW
  ARCHIVED
}

enum DocumentCommentStatus {
  OPEN
  RESOLVED
  DELETED
}

enum TemplateCategory {
  LEGAL
  HR
  FINANCE
  MARKETING
  PROJECTS
  CLIENTS
  GENERAL
}

// ----------------------------
// 1. Folder — Hierarchical folder organization
// ----------------------------

model Folder {
  id          String              @id @default(cuid())
  tenantId    String              @map("tenant_id")
  name        String
  description String?
  color       String?
  icon        String?
  parentId    String?             @map("parent_id")
  visibility  DocumentVisibility  @default(FOLDER_MEMBERS)
  ownerId     String              @map("owner_id")
  isSystem    Boolean             @default(false) @map("is_system")
  systemSlug  String?             @map("system_slug")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")
  archivedAt  DateTime?           @map("archived_at")

  // Relations
  tenant    Tenant    @relation("TenantFolders", fields: [tenantId], references: [id], onDelete: Cascade)
  owner     User      @relation("FolderOwner", fields: [ownerId], references: [id])
  parent    Folder?   @relation("FolderChildren", fields: [parentId], references: [id])
  children  Folder[]  @relation("FolderChildren")
  documents Document[]
  shares    FolderShare[]

  @@index([tenantId])
  @@index([tenantId, parentId])
  @@index([tenantId, systemSlug])
  @@map("folders")
}

// ----------------------------
// 2. FolderShare — Explicit folder access permission
// ----------------------------

model FolderShare {
  id         String          @id @default(cuid())
  tenantId   String          @map("tenant_id")
  folderId   String          @map("folder_id")
  userId     String?         @map("user_id")
  groupId    String?         @map("group_id")
  permission SharePermission
  grantedBy  String          @map("granted_by")
  grantedAt  DateTime        @default(now()) @map("granted_at")
  expiresAt  DateTime?       @map("expires_at")

  // Relations
  tenant Tenant @relation("TenantFolderShares", fields: [tenantId], references: [id], onDelete: Cascade)
  folder Folder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@unique([folderId, userId])
  @@unique([folderId, groupId])
  @@index([tenantId, userId])
  @@map("folder_shares")
}

// ----------------------------
// 3. Document — File or rich-text document
// ----------------------------

model Document {
  id               String              @id @default(cuid())
  tenantId         String              @map("tenant_id")
  folderId         String?             @map("folder_id")
  title            String
  description      String?
  status           DocumentStatus      @default(DRAFT)
  visibility       DocumentVisibility  @default(FOLDER_MEMBERS)
  fileKey          String?             @map("file_key")
  fileName         String?             @map("file_name")
  fileSize         Int?                @map("file_size")
  mimeType         String?             @map("mime_type")
  isRichText       Boolean             @default(false) @map("is_rich_text")
  richContent      Json?               @map("rich_content")
  summary          String?
  tags             String[]
  embedding        Unsupported("vector(1536)")?
  linkedModule     String?             @map("linked_module")
  linkedId         String?             @map("linked_id")
  ownerId          String              @map("owner_id")
  currentVersionId String?             @map("current_version_id")
  versionCount     Int                 @default(1) @map("version_count")
  downloadCount    Int                 @default(0) @map("download_count")
  viewCount        Int                 @default(0) @map("view_count")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")
  archivedAt       DateTime?           @map("archived_at")
  deletedAt        DateTime?           @map("deleted_at")

  // Relations
  tenant         Tenant                 @relation("TenantDocuments", fields: [tenantId], references: [id], onDelete: Cascade)
  owner          User                   @relation("DocumentOwner", fields: [ownerId], references: [id])
  folder         Folder?                @relation(fields: [folderId], references: [id])
  versions       DocumentVersion[]
  comments       DocumentComment[]
  shares         DocumentShare[]
  templateUsages DocumentTemplateUsage[]

  @@index([tenantId])
  @@index([tenantId, folderId])
  @@index([tenantId, status])
  @@index([tenantId, linkedModule, linkedId])
  @@index([tenantId, ownerId])
  @@index([tenantId, tags])
  @@map("documents")
}

// ----------------------------
// 4. DocumentVersion — Immutable version snapshot
// ----------------------------

model DocumentVersion {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  documentId    String   @map("document_id")
  versionNumber Int      @map("version_number")
  label         String?
  fileKey       String?  @map("file_key")
  fileSize      Int?     @map("file_size")
  mimeType      String?  @map("mime_type")
  richContent   Json?    @map("rich_content")
  changeLog     String?  @map("change_log")
  createdBy     String   @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")
  summary       String?
  embedding     Unsupported("vector(1536)")?

  // Relations
  tenant   Tenant   @relation("TenantDocumentVersions", fields: [tenantId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, versionNumber])
  @@index([tenantId, documentId])
  @@map("document_versions")
}

// ----------------------------
// 5. DocumentComment — Inline comment with threading
// ----------------------------

model DocumentComment {
  id         String                @id @default(cuid())
  tenantId   String                @map("tenant_id")
  documentId String                @map("document_id")
  parentId   String?               @map("parent_id")
  status     DocumentCommentStatus @default(OPEN)
  content    String
  mentions   String[]
  anchorId   String?               @map("anchor_id")
  anchorText String?               @map("anchor_text")
  authorId   String                @map("author_id")
  resolvedBy String?               @map("resolved_by")
  resolvedAt DateTime?             @map("resolved_at")
  createdAt  DateTime              @default(now()) @map("created_at")
  updatedAt  DateTime              @updatedAt @map("updated_at")
  deletedAt  DateTime?             @map("deleted_at")

  // Relations
  tenant   Tenant           @relation("TenantDocumentComments", fields: [tenantId], references: [id], onDelete: Cascade)
  document Document         @relation(fields: [documentId], references: [id], onDelete: Cascade)
  author   User             @relation("DocumentCommentAuthor", fields: [authorId], references: [id])
  parent   DocumentComment? @relation("CommentReplies", fields: [parentId], references: [id])
  replies  DocumentComment[] @relation("CommentReplies")

  @@index([tenantId, documentId])
  @@index([tenantId, authorId])
  @@map("document_comments")
}

// ----------------------------
// 6. DocumentShare — Document-level sharing
// ----------------------------

model DocumentShare {
  id         String          @id @default(cuid())
  tenantId   String          @map("tenant_id")
  documentId String          @map("document_id")
  userId     String?         @map("user_id")
  groupId    String?         @map("group_id")
  email      String?
  permission SharePermission
  token      String?         @unique
  grantedBy  String          @map("granted_by")
  grantedAt  DateTime        @default(now()) @map("granted_at")
  expiresAt  DateTime?       @map("expires_at")
  accessedAt DateTime?       @map("accessed_at")

  // Relations
  tenant   Tenant   @relation("TenantDocumentShares", fields: [tenantId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, userId])
  @@unique([documentId, groupId])
  @@index([tenantId, userId])
  @@index([token])
  @@map("document_shares")
}

// ----------------------------
// 7. KBArticle — Knowledge base wiki article
// ----------------------------

model KBArticle {
  id            String          @id @default(cuid())
  tenantId      String          @map("tenant_id")
  categoryId    String?         @map("category_id")
  title         String
  slug          String
  status        KBArticleStatus @default(DRAFT)
  content       String
  excerpt       String?
  summary       String?
  tags          String[]
  embedding     Unsupported("vector(1536)")?
  linkedModule  String?         @map("linked_module")
  relatedDocIds String[]        @map("related_doc_ids")
  expertId      String?         @map("expert_id")
  verifiedAt    DateTime?       @map("verified_at")
  expiresAt     DateTime?       @map("expires_at")
  needsReview   Boolean         @default(false) @map("needs_review")
  viewCount     Int             @default(0) @map("view_count")
  likeCount     Int             @default(0) @map("like_count")
  helpfulCount  Int             @default(0) @map("helpful_count")
  version       Int             @default(1)
  publishedAt   DateTime?       @map("published_at")
  ownerId       String          @map("owner_id")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  archivedAt    DateTime?       @map("archived_at")

  // Relations
  tenant   Tenant      @relation("TenantKBArticles", fields: [tenantId], references: [id], onDelete: Cascade)
  owner    User        @relation("KBArticleOwner", fields: [ownerId], references: [id])
  category KBCategory? @relation(fields: [categoryId], references: [id])

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([tenantId, categoryId])
  @@index([tenantId, status])
  @@index([tenantId, tags])
  @@map("kb_articles")
}

// ----------------------------
// 8. KBCategory — Hierarchical KB categories
// ----------------------------

model KBCategory {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  name       String
  slug       String
  description String?
  icon       String?
  color      String?
  parentId   String?  @map("parent_id")
  order      Int      @default(0)
  isSystem   Boolean  @default(false) @map("is_system")
  systemSlug String?  @map("system_slug")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations
  tenant   Tenant       @relation("TenantKBCategories", fields: [tenantId], references: [id], onDelete: Cascade)
  parent   KBCategory?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children KBCategory[] @relation("CategoryChildren")
  articles KBArticle[]

  @@unique([tenantId, slug])
  @@index([tenantId, parentId])
  @@map("kb_categories")
}

// ----------------------------
// 9. DocumentTemplate — Reusable document template
// ----------------------------

model DocumentTemplate {
  id           String           @id @default(cuid())
  tenantId     String?          @map("tenant_id") // null = global system template
  name         String
  description  String?
  category     TemplateCategory
  content      Json
  fileKey      String?          @map("file_key")
  mimeType     String?          @map("mime_type")
  tags         String[]
  previewUrl   String?          @map("preview_url")
  usageCount   Int              @default(0) @map("usage_count")
  isActive     Boolean          @default(true) @map("is_active")
  isSystem     Boolean          @default(false) @map("is_system")
  linkedModule String?          @map("linked_module")
  createdBy    String?          @map("created_by")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  // Relations
  tenant Tenant? @relation("TenantDocumentTemplates", fields: [tenantId], references: [id], onDelete: Cascade)
  usages DocumentTemplateUsage[]

  @@index([tenantId])
  @@index([tenantId, category])
  @@index([tenantId, linkedModule])
  @@map("document_templates")
}

// ----------------------------
// 10. DocumentTemplateUsage — Template usage record
// ----------------------------

model DocumentTemplateUsage {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  templateId String   @map("template_id")
  documentId String   @map("document_id")
  usedBy     String   @map("used_by")
  usedAt     DateTime @default(now()) @map("used_at")

  // Relations
  tenant   Tenant           @relation("TenantDocumentTemplateUsages", fields: [tenantId], references: [id], onDelete: Cascade)
  template DocumentTemplate @relation(fields: [templateId], references: [id])
  document Document         @relation(fields: [documentId], references: [id])

  @@index([tenantId, templateId])
  @@map("document_template_usages")
}

// ----------------------------
// 11. DocumentActivityLog — Audit trail
// ----------------------------

model DocumentActivityLog {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  documentId String?  @map("document_id")
  articleId  String?  @map("article_id")
  actorId    String   @map("actor_id")
  action     String
  metadata   Json?
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  tenant Tenant @relation("TenantDocumentActivityLogs", fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, documentId])
  @@index([tenantId, articleId])
  @@index([tenantId, actorId])
  @@index([tenantId, createdAt])
  @@map("document_activity_logs")
}

// [KAVEN_MODULE:DOCUMENTS_KB END]

// ===========================
// CLIENTS + CRM MODULE
// ===========================
// Gestão de contatos, organizações, lifecycle, segmentação,
// interações, timeline, feedback (NPS/CSAT) e health scoring.
// Multi-tenant isolado via tenantId em todos os models.

// [KAVEN_MODULE:CLIENTS_CRM BEGIN]

enum ContactLifecycleStage {
  LEAD
  MQL
  SQL
  OPPORTUNITY
  ACTIVE_CLIENT
  AT_RISK
  CHURNED
  ADVOCATE
}

enum ContactStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum ContactType {
  PERSON
  COMPANY
  PARTNER
  VENDOR
}

enum HealthCategory {
  HEALTHY
  AT_RISK
  CRITICAL
}

enum TrendDirection {
  UP
  DOWN
  STABLE
}

// ----------------------------
// 1. Contact — Core entity (person/company/partner/vendor)
// ----------------------------

model Contact {
  id             String                 @id @default(cuid())
  tenantId       String                 @map("tenant_id")

  // Identification
  contactType    ContactType            @default(PERSON) @map("contact_type")
  fullName       String                 @map("full_name")
  email          String?
  phone          String?
  phoneAlt       String?                @map("phone_alt")
  linkedinUrl    String?                @map("linkedin_url")
  avatarUrl      String?                @map("avatar_url")

  // Organization (B2B)
  organizationId String?                @map("organization_id")
  jobTitle       String?                @map("job_title")
  department     String?

  // Lifecycle & Status
  lifecycleStage ContactLifecycleStage  @default(LEAD) @map("lifecycle_stage")
  status         ContactStatus          @default(ACTIVE)
  source         String?
  sourceDetail   String?                @map("source_detail")

  // Location
  country        String?                @default("BR")
  state          String?
  city           String?
  address        String?
  postalCode     String?                @map("postal_code")

  // Qualification (lead scoring base)
  leadScore      Int?                   @default(0) @map("lead_score")
  qualifiedAt    DateTime?              @map("qualified_at")
  assignedToId   String?                @map("assigned_to_id")

  // AI Enrichment
  enrichedAt       DateTime?            @map("enriched_at")
  enrichmentData   Json?                @map("enrichment_data")
  enrichmentStatus String?              @map("enrichment_status")

  // Custom fields per industry
  customFields   Json?                  @map("custom_fields")

  // Preferences & Communication
  preferredChannel String?              @map("preferred_channel")
  unsubscribed     Boolean              @default(false)
  unsubscribedAt   DateTime?            @map("unsubscribed_at")
  doNotContact     Boolean              @default(false) @map("do_not_contact")

  // NPS / Satisfaction
  npsScore       Int?                   @map("nps_score")
  npsLastAt      DateTime?              @map("nps_last_at")

  // Internal
  notes          String?
  ownerId        String?                @map("owner_id")

  // Soft delete
  deletedAt      DateTime?              @map("deleted_at")
  deletedById    String?                @map("deleted_by_id")

  createdById    String                 @map("created_by_id")
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")

  // Relations
  tenant           Tenant               @relation("TenantContacts", fields: [tenantId], references: [id], onDelete: Cascade)
  organization     CrmOrganization?     @relation(fields: [organizationId], references: [id])
  assignedTo       User?                @relation("ContactAssignee", fields: [assignedToId], references: [id])
  createdBy        User                 @relation("ContactCreator", fields: [createdById], references: [id])

  interactions     CrmInteraction[]
  timelineEvents   CrmTimelineEvent[]
  contactTags      ContactTag[]
  segments         ContactSegment[]
  feedback         CustomerFeedback[]
  lifecycleHistory LifecycleHistory[]
  healthScores     ClientHealthScore[]
  healthHistory    ClientHealthHistory[]
  sharedContacts    SharedContact[]
  financialEntries  FinancialEntry[]  @relation("FinancialEntryClient")
  projects          Project[]         @relation("ProjectContact")

  // Marketing Module
  campaignEvents          CampaignEvent[]          @relation("ContactCampaignEvents")
  consentRecords          ConsentRecord[]          @relation("ContactConsentRecords")
  leadScoreRecord         LeadScore?               @relation("ContactLeadScore")
  automationEnrollments   AutomationEnrollment[]   @relation("ContactAutomationEnrollments")
  mktFormSubmissions      MktFormSubmission[]       @relation("ContactMktFormSubmissions")
  campaignUtms            CampaignUtm[]            @relation("ContactCampaignUtms")

  @@index([tenantId, lifecycleStage])
  @@index([tenantId, status])
  @@index([tenantId, email])
  @@index([tenantId, leadScore])
  @@index([tenantId, deletedAt])
  @@index([tenantId, contactType])
  @@index([tenantId, assignedToId])
  @@index([tenantId, organizationId])
  @@map("contacts")
}

// ----------------------------
// 2. CrmOrganization — B2B company entity
// ----------------------------

model CrmOrganization {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")

  name           String
  domain         String?
  cnpj           String?
  website        String?
  linkedinUrl    String?  @map("linkedin_url")
  industry       String?
  size           String?
  revenue        String?
  country        String?  @default("BR")
  state          String?
  city           String?

  // AI Enrichment
  enrichedAt     DateTime? @map("enriched_at")
  enrichmentData Json?     @map("enrichment_data")

  // Status
  status         String    @default("active")
  tags           String[]
  customFields   Json?     @map("custom_fields")

  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  // Relations
  tenant         Tenant    @relation("TenantCrmOrganizations", fields: [tenantId], references: [id], onDelete: Cascade)
  contacts       Contact[]

  @@index([tenantId, domain])
  @@index([tenantId, status])
  @@index([tenantId, industry])
  @@map("crm_organizations")
}

// ----------------------------
// 3. Tag — Reusable tags scoped by tenant + area
// ----------------------------

model Tag {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String
  color     String?
  areaSlug  String?  @map("area_slug")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  tenant       Tenant        @relation("TenantTags", fields: [tenantId], references: [id], onDelete: Cascade)
  contacts     ContactTag[]
  campaignTags CampaignTag[] @relation("TagCampaigns")

  @@unique([tenantId, name, areaSlug])
  @@index([tenantId])
  @@map("tags")
}

// ----------------------------
// 4. ContactTag — Many-to-many contact <-> tag
// ----------------------------

model ContactTag {
  contactId String   @map("contact_id")
  tagId     String   @map("tag_id")
  addedAt   DateTime @default(now()) @map("added_at")
  addedById String?  @map("added_by_id")

  // Relations
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
  @@map("contact_tags")
}

// ----------------------------
// 5. Segment — Saved dynamic query (JSON filters)
// ----------------------------

model Segment {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  name            String
  description     String?
  color           String?
  areaSlug        String?   @map("area_slug")
  queryDef        Json      @map("query_def")
  isPublic        Boolean   @default(false) @map("is_public")
  memberCount     Int       @default(0) @map("member_count")
  lastEvaluatedAt DateTime? @map("last_evaluated_at")

  createdById     String    @map("created_by_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  tenant          Tenant           @relation("TenantSegments", fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy       User             @relation("SegmentCreator", fields: [createdById], references: [id])
  contacts        ContactSegment[]
  campaigns       Campaign[]       @relation("CampaignSegment")

  @@index([tenantId, areaSlug])
  @@index([tenantId, createdById])
  @@map("segments")
}

// ----------------------------
// 6. ContactSegment — Materialized segment membership
// ----------------------------

model ContactSegment {
  contactId String   @map("contact_id")
  segmentId String   @map("segment_id")
  addedAt   DateTime @default(now()) @map("added_at")

  // Relations
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  segment   Segment  @relation(fields: [segmentId], references: [id], onDelete: Cascade)

  @@id([contactId, segmentId])
  @@map("contact_segments")
}

// ----------------------------
// 7. CrmInteraction — Communication log
// ----------------------------

model CrmInteraction {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  contactId   String    @map("contact_id")
  userId      String?   @map("user_id")
  agentId     String?   @map("agent_id")

  type        String
  channel     String?
  direction   String?
  subject     String?
  body        String?
  duration    Int?
  outcome     String?

  metadata    Json?
  occurredAt  DateTime  @default(now()) @map("occurred_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  // Relations
  tenant      Tenant    @relation("TenantCrmInteractions", fields: [tenantId], references: [id], onDelete: Cascade)
  contact     Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  user        User?     @relation("CrmInteractionUser", fields: [userId], references: [id])

  @@index([tenantId, contactId])
  @@index([tenantId, type])
  @@index([contactId, occurredAt])
  @@map("crm_interactions")
}

// ----------------------------
// 8. CrmTimelineEvent — Unified cross-module history feed
// ----------------------------

model CrmTimelineEvent {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  contactId   String   @map("contact_id")

  sourceType  String   @map("source_type")
  sourceId    String?  @map("source_id")

  title       String
  description String?
  icon        String?
  metadata    Json?

  occurredAt  DateTime @default(now()) @map("occurred_at")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  tenant      Tenant   @relation("TenantCrmTimelineEvents", fields: [tenantId], references: [id], onDelete: Cascade)
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([tenantId, contactId, occurredAt])
  @@index([tenantId, sourceType])
  @@map("crm_timeline_events")
}

// ----------------------------
// 9. LifecycleHistory — Audit trail for lifecycle stage changes
// ----------------------------

model LifecycleHistory {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  contactId   String    @map("contact_id")
  fromStage   String?   @map("from_stage")
  toStage     String    @map("to_stage")
  changedById String?   @map("changed_by_id")
  reason      String?
  changedAt   DateTime  @default(now()) @map("changed_at")

  // Relations
  tenant      Tenant    @relation("TenantLifecycleHistories", fields: [tenantId], references: [id], onDelete: Cascade)
  contact     Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  changedBy   User?     @relation("LifecycleChangedBy", fields: [changedById], references: [id])

  @@index([tenantId, contactId])
  @@index([tenantId, changedAt])
  @@map("lifecycle_histories")
}

// ----------------------------
// 10. CustomerFeedback — NPS/CSAT native feedback
// ----------------------------

model CustomerFeedback {
  id           String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  contactId    String    @map("contact_id")

  feedbackType String    @map("feedback_type")
  score        Int?
  comment      String?
  sentiment    String?

  triggeredBy  String?   @map("triggered_by")
  sourceId     String?   @map("source_id")

  submittedAt  DateTime? @map("submitted_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  // Relations
  tenant       Tenant    @relation("TenantCustomerFeedbacks", fields: [tenantId], references: [id], onDelete: Cascade)
  contact      Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([tenantId, feedbackType])
  @@index([tenantId, contactId])
  @@map("customer_feedbacks")
}

// ----------------------------
// 11. LifecycleTemplate — Industry-specific lifecycle stages
// ----------------------------

model LifecycleTemplate {
  id        String    @id @default(cuid())
  tenantId  String?   @map("tenant_id")
  industry  String?
  name      String
  stages    Json
  isDefault Boolean   @default(false) @map("is_default")
  createdAt DateTime  @default(now()) @map("created_at")

  // Relations (tenantId nullable = global platform template)
  tenant    Tenant?   @relation("TenantLifecycleTemplates", fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([industry])
  @@map("lifecycle_templates")
}

// ----------------------------
// 12. ClientHealthScore — 5-dimension health scoring
// ----------------------------

model ClientHealthScore {
  id           String         @id @default(cuid())
  tenantId     String         @map("tenant_id")
  contactId    String         @map("contact_id")
  overallScore Int            @map("overall_score")
  dimensions   Json
  category     HealthCategory
  calculatedAt DateTime       @default(now()) @map("calculated_at")
  calculatedBy String?        @map("calculated_by")

  // Relations
  tenant       Tenant         @relation("TenantClientHealthScores", fields: [tenantId], references: [id], onDelete: Cascade)
  contact      Contact        @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([tenantId, contactId])
  @@index([tenantId, category])
  @@index([tenantId, calculatedAt])
  @@map("client_health_scores")
}

// ----------------------------
// 13. ClientHealthHistory — Health score change tracking
// ----------------------------

model ClientHealthHistory {
  id               String          @id @default(cuid())
  tenantId         String          @map("tenant_id")
  contactId        String          @map("contact_id")
  previousScore    Int             @map("previous_score")
  newScore         Int             @map("new_score")
  previousCategory HealthCategory  @map("previous_category")
  newCategory      HealthCategory  @map("new_category")
  delta            Int
  trigger          String
  changedAt        DateTime        @default(now()) @map("changed_at")

  // Relations
  tenant           Tenant          @relation("TenantClientHealthHistories", fields: [tenantId], references: [id], onDelete: Cascade)
  contact          Contact         @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([tenantId, contactId])
  @@index([tenantId, changedAt])
  @@map("client_health_histories")
}

// ----------------------------
// 14. SharedContact — Cross-tenant sharing
// ----------------------------

model SharedContact {
  id                 String          @id @default(cuid())
  tenantId           String          @map("tenant_id")
  contactId          String          @map("contact_id")
  sharedWithTenantId String          @map("shared_with_tenant_id")
  permission         SharePermission
  sharedBy           String          @map("shared_by")
  sharedAt           DateTime        @default(now()) @map("shared_at")
  expiresAt          DateTime?       @map("expires_at")

  // Relations
  tenant             Tenant          @relation("TenantSharedContacts", fields: [tenantId], references: [id], onDelete: Cascade)
  sharedWithTenant   Tenant          @relation("SharedWithTenantContacts", fields: [sharedWithTenantId], references: [id], onDelete: Cascade)
  contact            Contact         @relation(fields: [contactId], references: [id], onDelete: Cascade)
  sharedByUser       User            @relation("SharedContactBy", fields: [sharedBy], references: [id])

  @@unique([contactId, sharedWithTenantId])
  @@index([tenantId, contactId])
  @@index([sharedWithTenantId])
  @@map("shared_contacts")
}

// [KAVEN_MODULE:CLIENTS_CRM END]

// ===========================
// FINANCE MODULE
// ===========================
// Gestao financeira completa: plano de contas, contas bancarias,
// lancamentos com dual-date (caixa/competencia), orcamento,
// recorrencias, parcelamento, relatorios DRE/DFC, KPIs.
// Multi-tenant isolado via tenantId em todos os models.

// [KAVEN_MODULE:FINANCE BEGIN]

enum FinancialEntryStatus {
  SCHEDULED
  PENDING
  CONFIRMED
  RECONCILED
}

enum FinanceProjectStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

// ----------------------------
// 1. ChartOfAccount — Hierarchical chart of accounts
// ----------------------------

model ChartOfAccount {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")

  parentId    String?  @map("parent_id")
  code        String   // "1", "1.1", "1.1.1" — ordering and export
  name        String
  type        String   // 'revenue' | 'fixed_expense' | 'variable_expense' | 'investment' | 'financial_movement'
  subtype     String?  // 'recurring' | 'non_recurring'

  // Report mapping
  appearsInDFC Boolean @default(true) @map("appears_in_dfc")
  appearsInDRE Boolean @default(true) @map("appears_in_dre")

  // Balance sheet (future-proof, nullable)
  bsCategory  String?  @map("bs_category") // 'current_asset' | 'non_current_asset' | 'current_liability' | 'non_current_liability' | 'equity'

  isSystem    Boolean  @default(false) @map("is_system")
  isActive    Boolean  @default(true)  @map("is_active")
  sortOrder   Int      @default(0)     @map("sort_order")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")
  deletedAt   DateTime?               @map("deleted_at")

  // Relations
  tenant      Tenant             @relation("TenantChartOfAccounts", fields: [tenantId], references: [id], onDelete: Cascade)
  parent      ChartOfAccount?    @relation("AccountHierarchy", fields: [parentId], references: [id])
  children    ChartOfAccount[]   @relation("AccountHierarchy")
  entryLines  FinancialEntryLine[]
  budgetLines BudgetLine[]

  @@index([tenantId, type])
  @@index([tenantId, parentId])
  @@index([tenantId, code])
  @@map("chart_of_accounts")
}

// ----------------------------
// 2. BankAccount — Bank accounts and credit cards
// ----------------------------

model BankAccount {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")

  name           String
  bankCode       String?  @map("bank_code")
  bankName       String?  @map("bank_name")
  agency         String?
  accountNumber  String?  @map("account_number")
  type           String   // 'checking' | 'savings' | 'cash' | 'investment' | 'credit_card'
  currency       String   @default("BRL")
  initialBalance Decimal  @db.Decimal(15, 2) @default(0) @map("initial_balance")
  initialDate    DateTime @map("initial_date")
  isActive       Boolean  @default(true) @map("is_active")

  // Credit card specific fields (null for other types)
  creditLimit    Decimal?  @db.Decimal(15, 2) @map("credit_limit")
  closingDay     Int?      @map("closing_day")  // 1-31
  dueDay         Int?      @map("due_day")      // 1-31

  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt      @map("updated_at")

  // Relations
  tenant         Tenant               @relation("TenantBankAccounts", fields: [tenantId], references: [id], onDelete: Cascade)
  entryLines     FinancialEntryLine[]
  statements     CreditCardStatement[]

  @@index([tenantId, type, isActive])
  @@map("bank_accounts")
}

// ----------------------------
// 3. CreditCardStatement — Monthly credit card statement
// ----------------------------

model CreditCardStatement {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  bankAccountId  String   @map("bank_account_id")

  referenceMonth Int      @map("reference_month")  // 1-12
  referenceYear  Int      @map("reference_year")
  closingDate    DateTime @map("closing_date")
  dueDate        DateTime @map("due_date")

  totalAmount    Decimal  @db.Decimal(15, 2) @map("total_amount")
  status         String   @default("open")  // 'open' | 'closed' | 'paid'
  paidAt         DateTime? @map("paid_at")
  paidEntryId    String?  @map("paid_entry_id")

  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt      @map("updated_at")

  // Relations
  tenant         Tenant          @relation("TenantCreditCardStatements", fields: [tenantId], references: [id], onDelete: Cascade)
  bankAccount    BankAccount     @relation(fields: [bankAccountId], references: [id])
  entryLines     FinancialEntryLine[]

  @@unique([tenantId, bankAccountId, referenceYear, referenceMonth])
  @@index([tenantId, status, dueDate])
  @@map("credit_card_statements")
}

// ----------------------------
// 4. CostCenter — Cost/Profit center
// ----------------------------

model CostCenter {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")

  name      String
  type      String   // 'cost' | 'profit'
  isActive  Boolean  @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  // Relations
  tenant     Tenant              @relation("TenantCostCenters", fields: [tenantId], references: [id], onDelete: Cascade)
  entryLines FinancialEntryLine[]

  @@index([tenantId, isActive])
  @@map("cost_centers")
}

// ----------------------------
// 5. FinanceProject — Financial project with lifecycle
// ----------------------------

model FinanceProject {
  id            String               @id @default(cuid())
  tenantId      String               @map("tenant_id")
  name          String
  description   String?
  startDate     DateTime             @map("start_date")
  endDate       DateTime?            @map("end_date")
  status        FinanceProjectStatus @default(ACTIVE)
  budgetAmount  Decimal?             @db.Decimal(15, 2) @map("budget_amount")
  actualAmount  Decimal?             @db.Decimal(15, 2) @map("actual_amount")
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt      @map("updated_at")
  deletedAt     DateTime?            @map("deleted_at")

  // Relations
  tenant    Tenant           @relation("TenantFinanceProjects", fields: [tenantId], references: [id], onDelete: Cascade)
  entries   FinancialEntry[] @relation("EntryFinanceProject")

  @@index([tenantId, status])
  @@index([tenantId, startDate, endDate])
  @@map("finance_projects")
}

// ----------------------------
// 6. FinancialEntry — Root financial event
// ----------------------------

model FinancialEntry {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")

  // Dual-date: cash vs accrual
  dateDFC         DateTime @map("date_dfc")  // when money enters/leaves
  dateDRE         DateTime @map("date_dre")  // when revenue/expense is recognized

  type            String   // 'revenue' | 'expense' | 'investment' | 'financial_movement'

  // Transfer linking
  transferPairId  String?  @map("transfer_pair_id")

  description     String?
  totalAmount     Decimal  @db.Decimal(15, 2) @map("total_amount")
  currency        String   @default("BRL")
  exchangeRate    Decimal? @db.Decimal(10, 6) @map("exchange_rate")
  totalAmountBRL  Decimal? @db.Decimal(15, 2) @map("total_amount_brl")

  // Split payment (tax reform)
  taxRetained     Decimal? @db.Decimal(15, 2) @map("tax_retained")
  netAmount       Decimal? @db.Decimal(15, 2) @map("net_amount")

  // Interest/penalty and partial payments
  interestRate    Decimal? @db.Decimal(5, 4)  @map("interest_rate")
  penaltyAmount   Decimal? @db.Decimal(15, 2) @map("penalty_amount")
  paidAmount      Decimal? @db.Decimal(15, 2) @map("paid_amount")

  // Status
  status          FinancialEntryStatus @default(SCHEDULED)
  dueDate         DateTime?            @map("due_date")
  paidAt          DateTime?            @map("paid_at")

  // Period lock
  periodLocked    Boolean  @default(false) @map("period_locked")

  // Balance sheet type (future-proof)
  balanceSheetType String? @map("balance_sheet_type")

  // Recurrence/installment origin
  recurringEntryId  String? @map("recurring_entry_id")
  installmentPlanId String? @map("installment_plan_id")
  installmentNumber Int?    @map("installment_number")

  // Source (cross-module integration)
  sourceType      String?  @map("source_type")
  sourceId        String?  @map("source_id")

  // OFX import reference
  externalRef     String?  @map("external_ref")
  importedAt      DateTime? @map("imported_at")

  // Links
  clientId        String?  @map("client_id")
  entityId        String?  @map("entity_id")
  projectId       String?  @map("project_id")

  tags            String[]
  attachmentUrl   String?  @map("attachment_url")
  notes           String?

  createdById     String   @map("created_by_id")
  updatedById     String?  @map("updated_by_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt      @map("updated_at")
  deletedAt       DateTime?               @map("deleted_at")

  // Relations
  tenant          Tenant               @relation("TenantFinancialEntries", fields: [tenantId], references: [id], onDelete: Cascade)
  lines           FinancialEntryLine[]
  client          Contact?             @relation("FinancialEntryClient", fields: [clientId], references: [id])
  project         FinanceProject?      @relation("EntryFinanceProject", fields: [projectId], references: [id])
  createdBy       User                 @relation("FinancialEntryCreator", fields: [createdById], references: [id])

  @@index([tenantId, dateDFC])
  @@index([tenantId, dateDRE])
  @@index([tenantId, type, status])
  @@index([tenantId, status, dueDate])
  @@index([tenantId, clientId])
  @@index([tenantId, sourceType, sourceId])
  @@index([tenantId, transferPairId])
  @@index([tenantId, installmentPlanId])
  @@map("financial_entries")
}

// ----------------------------
// 7. FinancialEntryLine — Split entry line
// ----------------------------

model FinancialEntryLine {
  id                String   @id @default(cuid())
  tenantId          String   @map("tenant_id")
  entryId           String   @map("entry_id")

  chartOfAccountId  String   @map("chart_of_account_id")
  bankAccountId     String?  @map("bank_account_id")
  costCenterId      String?  @map("cost_center_id")
  statementId       String?  @map("statement_id")

  amount            Decimal  @db.Decimal(15, 2)
  description       String?

  // Relations
  entry         FinancialEntry       @relation(fields: [entryId], references: [id], onDelete: Cascade)
  chartOfAccount ChartOfAccount     @relation(fields: [chartOfAccountId], references: [id])
  bankAccount   BankAccount?        @relation(fields: [bankAccountId], references: [id])
  costCenter    CostCenter?         @relation(fields: [costCenterId], references: [id])
  statement     CreditCardStatement? @relation(fields: [statementId], references: [id])

  @@index([tenantId, entryId])
  @@index([tenantId, chartOfAccountId])
  @@index([tenantId, bankAccountId])
  @@index([tenantId, statementId])
  @@map("financial_entry_lines")
}

// ----------------------------
// 8. InstallmentPlan — Installment plan template
// ----------------------------

model InstallmentPlan {
  id                String   @id @default(cuid())
  tenantId          String   @map("tenant_id")

  description       String
  totalAmount       Decimal  @db.Decimal(15, 2) @map("total_amount")
  installmentCount  Int      @map("installment_count")
  installmentAmount Decimal  @db.Decimal(15, 2) @map("installment_amount")
  firstDueDate      DateTime @map("first_due_date")
  frequency         String   @default("monthly") // 'weekly' | 'monthly' | 'bimonthly'

  chartOfAccountId  String   @map("chart_of_account_id")
  bankAccountId     String?  @map("bank_account_id")
  clientId          String?  @map("client_id")

  status            String   @default("active") // 'active' | 'completed' | 'cancelled'

  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt      @map("updated_at")

  // Relations
  tenant            Tenant   @relation("TenantInstallmentPlans", fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@map("installment_plans")
}

// ----------------------------
// 9. RecurringEntry — Recurring entry template
// ----------------------------

model RecurringEntry {
  id               String    @id @default(cuid())
  tenantId         String    @map("tenant_id")

  description      String
  type             String    // 'revenue' | 'expense'
  amount           Decimal   @db.Decimal(15, 2)
  chartOfAccountId String    @map("chart_of_account_id")
  bankAccountId    String?   @map("bank_account_id")
  costCenterId     String?   @map("cost_center_id")
  clientId         String?   @map("client_id")
  frequency        String    // 'daily' | 'weekly' | 'monthly' | 'bimonthly' | 'quarterly' | 'annual'
  startDate        DateTime  @map("start_date")
  endDate          DateTime? @map("end_date")

  isActive         Boolean   @default(true) @map("is_active")
  lastGeneratedAt  DateTime? @map("last_generated_at")
  nextDueDate      DateTime? @map("next_due_date")

  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt      @map("updated_at")

  // Relations
  tenant           Tenant    @relation("TenantRecurringEntries", fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isActive, nextDueDate])
  @@map("recurring_entries")
}

// ----------------------------
// 10. Budget — Annual budget with scenarios
// ----------------------------

model Budget {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")

  year      Int
  name      String   @default("Annual Budget")
  scenario  String   @default("base") // 'base' | 'conservative' | 'optimistic'
  isActive  Boolean  @default(true)   @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  // Relations
  tenant    Tenant       @relation("TenantBudgets", fields: [tenantId], references: [id], onDelete: Cascade)
  lines     BudgetLine[]

  @@unique([tenantId, year, name, scenario])
  @@index([tenantId, year, isActive])
  @@map("budgets")
}

// ----------------------------
// 11. BudgetLine — Monthly budget per account
// ----------------------------

model BudgetLine {
  id               String   @id @default(cuid())
  budgetId         String   @map("budget_id")
  tenantId         String   @map("tenant_id")
  chartOfAccountId String   @map("chart_of_account_id")

  month            Int      // 1-12
  amount           Decimal  @db.Decimal(15, 2)

  updatedAt        DateTime @updatedAt @map("updated_at")

  // Relations
  budget           Budget         @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  chartOfAccount   ChartOfAccount @relation(fields: [chartOfAccountId], references: [id])

  @@unique([budgetId, chartOfAccountId, month])
  @@index([tenantId, budgetId])
  @@index([tenantId, chartOfAccountId])
  @@map("budget_lines")
}

// ----------------------------
// 12. FinancialProjection — Strategic 3-5 year projection
// ----------------------------

model FinancialProjection {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")

  name        String
  startYear   Int      @map("start_year")
  endYear     Int      @map("end_year")
  isActive    Boolean  @default(true) @map("is_active")

  assumptions Json     // { revenueGrowthRate, headcountGrowth, fixedCostInflation, marginTarget }
  projections Json     // { "2026": { revenue, ebitda }, "2027": {...} }

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  // Relations
  tenant      Tenant   @relation("TenantFinancialProjections", fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isActive])
  @@map("financial_projections")
}

// ----------------------------
// 13. ClosedPeriod — Closed accounting period
// ----------------------------

model ClosedPeriod {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")

  month       Int      // 1-12
  year        Int
  closedAt    DateTime @default(now()) @map("closed_at")
  closedById  String   @map("closed_by_id")

  // Relations
  tenant      Tenant   @relation("TenantClosedPeriods", fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, year, month])
  @@index([tenantId, year])
  @@map("closed_periods")
}

// ----------------------------
// 14. KPIDefinition — KPI template and custom definitions
// ----------------------------

model KPIDefinition {
  id          String   @id @default(cuid())
  tenantId    String?  @map("tenant_id")  // null = global platform KPI

  name        String
  slug        String
  description String?
  unit        String   // 'percent' | 'currency_brl' | 'days' | 'ratio' | 'count'
  formula     String   // expression in simple DSL
  industry    String?  // 'agency' | 'real_estate' | 'ecommerce' | 'law_firm' | 'saas'

  // Threshold alerts
  thresholdGood    Decimal? @db.Decimal(15, 4) @map("threshold_good")
  thresholdWarning Decimal? @db.Decimal(15, 4) @map("threshold_warning")

  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0)    @map("sort_order")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  // Relations
  tenant      Tenant?  @relation("TenantKPIDefinitions", fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([industry, isActive])
  @@index([tenantId, isActive])
  @@map("kpi_definitions")
}

// [KAVEN_MODULE:FINANCE END]

// ===========================
// PEOPLE + HR MODULE
// ===========================
// Employee management, hiring pipeline (ATS), performance reviews,
// 1:1 meetings, onboarding, HR time tracking, LGPD compliance.
// Cross-module: Employee extends User via 1:1 relation.
// Multi-tenant isolated via tenantId on all models.

// [KAVEN_MODULE:PEOPLE_HR BEGIN]

// ---------- Enums ----------

enum EmploymentType {
  CLT
  PJ
  ESTAGIO
  TEMPORARIO
  AUTONOMO
  SOCIO

  @@map("employment_type")
}

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  SUSPENDED
  TERMINATED
  PROBATION

  @@map("employee_status")
}

enum HiringJobStatus {
  DRAFT
  OPEN
  PAUSED
  CLOSED_HIRED
  CLOSED_CANCELLED

  @@map("hiring_job_status")
}

enum ApplicationStatus {
  APPLIED
  SCREENING
  INTERVIEW
  ASSESSMENT
  OFFER_SENT
  OFFER_ACCEPTED
  HIRED
  REJECTED
  WITHDRAWN

  @@map("application_status")
}

enum InterviewStageType {
  PHONE_SCREEN
  TECHNICAL
  CULTURAL_FIT
  MANAGER
  DIRECTOR
  PANEL
  REFERENCE_CHECK
  CUSTOM

  @@map("interview_stage_type")
}

enum InterviewStageStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW

  @@map("interview_stage_status")
}

enum PerformanceReviewStatus {
  DRAFT
  SELF_REVIEW_PENDING
  MANAGER_REVIEW_PENDING
  CALIBRATION
  PUBLISHED
  ACKNOWLEDGED

  @@map("performance_review_status")
}

enum PerformanceScore {
  BELOW_EXPECTATIONS
  NEEDS_IMPROVEMENT
  MEETS_EXPECTATIONS
  EXCEEDS_EXPECTATIONS
  OUTSTANDING

  @@map("performance_score")
}

enum HrTimeEntryStatus {
  PENDING
  APPROVED
  REJECTED
  ADJUSTED

  @@map("hr_time_entry_status")
}

enum LgpdConsentStatus {
  PENDING
  GRANTED
  REVOKED

  @@map("lgpd_consent_status")
}

enum LgpdDataPurpose {
  PAYROLL
  ESOCIAL
  PERFORMANCE
  BENEFITS
  HEALTH
  RECRUITMENT
  TRAINING

  @@map("lgpd_data_purpose")
}

// ---------- Models ----------

model Employee {
  id              String         @id @default(cuid())
  tenantId        String         @map("tenant_id")
  userId          String         @unique @map("user_id")

  // Personal data (LGPD: purpose = contract + legal obligation)
  fullName        String         @map("full_name")
  birthDate       DateTime?      @map("birth_date")
  gender          String?
  personalEmail   String?        @map("personal_email")
  phone           String?
  emergencyContact Json?         @map("emergency_contact")
  address         Json?

  // Employment
  employmentType  EmploymentType @map("employment_type")
  status          EmployeeStatus @default(PROBATION)
  hireDate        DateTime       @map("hire_date")
  terminationDate DateTime?      @map("termination_date")
  probationEndDate DateTime?     @map("probation_end_date")

  // Position and structure
  jobTitle        String         @map("job_title")
  jobLevel        String?        @map("job_level")
  departmentId    String         @map("department_id")
  managerId       String?        @map("manager_id")

  // Compensation (LGPD: purpose = contract execution)
  salary          Decimal        @db.Decimal(12, 2)
  salaryBasis     String         @default("MONTHLY") @map("salary_basis")
  currency        String         @default("BRL")

  // Benefits and extensibility
  benefitsPackage Json?          @map("benefits_package")
  customFields    Json?          @map("custom_fields")
  metadata        Json?

  // Soft delete + audit
  deletedAt       DateTime?      @map("deleted_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  createdBy       String?        @map("created_by")
  updatedBy       String?        @map("updated_by")

  // Relations
  tenant          Tenant         @relation("TenantEmployees", fields: [tenantId], references: [id], onDelete: Cascade)
  user            User           @relation("EmployeeUser", fields: [userId], references: [id])
  department      Department     @relation("DepartmentEmployees", fields: [departmentId], references: [id])
  manager         Employee?      @relation("EmployeeManager", fields: [managerId], references: [id])
  directReports   Employee[]     @relation("EmployeeManager")

  performanceReviews  PerformanceReview[] @relation("RevieweeEmployee")
  managerReviews      PerformanceReview[] @relation("ReviewerEmployee")
  oneOnOnes           OneOnOne[]          @relation("OneOnOneEmployee")
  managerOneOnOnes    OneOnOne[]          @relation("OneOnOneManager")
  hrTimeEntries       HrTimeEntry[]
  lgpdConsents        LgpdConsent[]
  auditLogs           PeopleAuditLog[]
  applications        Application[]
  onboardingPlans     OnboardingPlan[]
  managedJobs         HiringJob[]         @relation("JobHiringManager")

  // Remote Work Module
  remoteTimeEntries   RemoteTimeEntry[]   @relation("EmployeeRemoteTimeEntries")
  billingRates        BillingRate[]       @relation("EmployeeBillingRates")
  timesheetPeriods    TimesheetPeriod[]   @relation("EmployeeTimesheetPeriods")
  workSchedules       WorkSchedule[]      @relation("EmployeeWorkSchedules")
  meetingFreeBlocks   MeetingFreeBlock[]  @relation("EmployeeMeetingFreeBlocks")
  timezoneConfig      TimezoneConfig?     @relation("EmployeeTimezoneConfig")
  standupResponses    StandupResponse[]   @relation("EmployeeStandupResponses")

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, departmentId])
  @@index([tenantId, managerId])
  @@map("employees")
}

model Department {
  id           String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  name         String
  code         String?
  parentId     String?   @map("parent_id")
  headId       String?   @map("head_id")
  budget       Decimal?  @db.Decimal(12, 2)
  headcount    Int       @default(0)
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  tenant       Tenant       @relation("TenantDepartments", fields: [tenantId], references: [id], onDelete: Cascade)
  parent       Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children     Department[] @relation("DepartmentHierarchy")
  employees    Employee[]   @relation("DepartmentEmployees")
  hiringJobs   HiringJob[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("departments")
}

model HiringJob {
  id              String          @id @default(cuid())
  tenantId        String          @map("tenant_id")
  title           String
  description     String?         @db.Text
  departmentId    String          @map("department_id")
  hiringManagerId String          @map("hiring_manager_id")
  status          HiringJobStatus @default(DRAFT)

  // Job configuration
  location        String?
  isRemote        Boolean         @default(false) @map("is_remote")
  employmentType  EmploymentType  @map("employment_type")
  seniority       String?
  salaryMin       Decimal?        @db.Decimal(12, 2) @map("salary_min")
  salaryMax       Decimal?        @db.Decimal(12, 2) @map("salary_max")
  targetHireDate  DateTime?       @map("target_hire_date")
  headcountTarget Int             @default(1) @map("headcount_target")
  headcountFilled Int             @default(0) @map("headcount_filled")

  // Interview pipeline template
  interviewStageTemplate Json?    @map("interview_stage_template")

  // Extensibility
  customFields    Json?           @map("custom_fields")
  metadata        Json?

  publishedAt     DateTime?       @map("published_at")
  closedAt        DateTime?       @map("closed_at")
  deletedAt       DateTime?       @map("deleted_at")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  createdBy       String?         @map("created_by")

  tenant          Tenant          @relation("TenantHiringJobs", fields: [tenantId], references: [id], onDelete: Cascade)
  department      Department      @relation(fields: [departmentId], references: [id])
  hiringManager   Employee        @relation("JobHiringManager", fields: [hiringManagerId], references: [id])
  applications    Application[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, departmentId])
  @@map("hiring_jobs")
}

model Applicant {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")

  // Personal data
  fullName     String   @map("full_name")
  email        String
  phone        String?
  linkedinUrl  String?  @map("linkedin_url")
  portfolioUrl String?  @map("portfolio_url")
  resumeUrl    String?  @map("resume_url")

  // Source
  source       String?

  // LGPD consent for data storage
  lgpdConsentAt    DateTime? @map("lgpd_consent_at")

  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  tenant       Tenant        @relation("TenantApplicants", fields: [tenantId], references: [id], onDelete: Cascade)
  applications Application[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("applicants")
}

model Application {
  id           String            @id @default(cuid())
  tenantId     String            @map("tenant_id")
  jobId        String            @map("job_id")
  applicantId  String            @map("applicant_id")
  employeeId   String?           @map("employee_id")
  status       ApplicationStatus @default(APPLIED)

  // Evaluation
  recruiterNote  String?  @db.Text @map("recruiter_note")

  // Offer (when status = OFFER_SENT)
  offerSalary    Decimal?  @db.Decimal(12, 2) @map("offer_salary")
  offerStartDate DateTime? @map("offer_start_date")
  offerExpiresAt DateTime? @map("offer_expires_at")
  offerDetails   Json?     @map("offer_details")

  // Rejection (LGPD: rejection reason must be auditable)
  rejectionReason String?  @map("rejection_reason")
  rejectedAt      DateTime? @map("rejected_at")
  rejectedBy      String?   @map("rejected_by")

  appliedAt    DateTime  @default(now()) @map("applied_at")
  hiredAt      DateTime? @map("hired_at")
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  tenant       Tenant          @relation("TenantApplications", fields: [tenantId], references: [id], onDelete: Cascade)
  job          HiringJob       @relation(fields: [jobId], references: [id])
  applicant    Applicant       @relation(fields: [applicantId], references: [id])
  employee     Employee?       @relation(fields: [employeeId], references: [id])
  stages       InterviewStage[]

  @@unique([jobId, applicantId])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, jobId])
  @@map("applications")
}

model InterviewStage {
  id            String               @id @default(cuid())
  tenantId      String               @map("tenant_id")
  applicationId String               @map("application_id")
  type          InterviewStageType
  title         String
  order         Int
  status        InterviewStageStatus @default(SCHEDULED)
  interviewerIds String[]            @map("interviewer_ids")

  scheduledAt   DateTime?            @map("scheduled_at")
  completedAt   DateTime?            @map("completed_at")
  duration      Int?

  // Structured feedback
  feedback      String?   @db.Text
  score         Int?
  recommendation String?

  meetingUrl    String?              @map("meeting_url")

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  createdBy     String?  @map("created_by")

  tenant        Tenant      @relation("TenantInterviewStages", fields: [tenantId], references: [id], onDelete: Cascade)
  application   Application @relation(fields: [applicationId], references: [id])

  @@index([tenantId])
  @@index([applicationId])
  @@map("interview_stages")
}

model OnboardingPlan {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  employeeId      String   @map("employee_id")
  title           String
  startDate       DateTime @map("start_date")
  expectedEndDate DateTime? @map("expected_end_date")
  completedAt     DateTime? @map("completed_at")

  // Checklist tasks (JSONB for flexibility)
  tasks           Json

  // Calculated progress
  progressPct     Int      @default(0) @map("progress_pct")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  createdBy       String?  @map("created_by")

  tenant          Tenant   @relation("TenantOnboardingPlans", fields: [tenantId], references: [id], onDelete: Cascade)
  employee        Employee @relation(fields: [employeeId], references: [id])

  @@index([tenantId])
  @@index([tenantId, employeeId])
  @@map("onboarding_plans")
}

model ReviewCycle {
  id               String   @id @default(cuid())
  tenantId         String   @map("tenant_id")
  title            String
  type             String   @default("ANNUAL")
  periodStart      DateTime @map("period_start")
  periodEnd        DateTime @map("period_end")
  selfReviewDue    DateTime @map("self_review_due")
  managerReviewDue DateTime @map("manager_review_due")
  calibrationDate  DateTime? @map("calibration_date")
  publishDate      DateTime? @map("publish_date")
  status           String   @default("DRAFT")

  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  createdBy        String?  @map("created_by")

  tenant           Tenant             @relation("TenantReviewCycles", fields: [tenantId], references: [id], onDelete: Cascade)
  reviews          PerformanceReview[]

  @@index([tenantId])
  @@map("review_cycles")
}

model PerformanceReview {
  id              String                  @id @default(cuid())
  tenantId        String                  @map("tenant_id")
  revieweeId      String                  @map("reviewee_id")
  reviewerId      String                  @map("reviewer_id")
  cycleId         String?                 @map("cycle_id")
  status          PerformanceReviewStatus @default(DRAFT)

  // Evaluation period
  periodStart     DateTime                @map("period_start")
  periodEnd       DateTime                @map("period_end")
  reviewType      String                  @default("ANNUAL") @map("review_type")

  // Self-evaluation
  selfScore       PerformanceScore?       @map("self_score")
  selfComments    String?  @db.Text       @map("self_comments")
  selfGoals       Json?                   @map("self_goals")

  // Manager evaluation
  managerScore    PerformanceScore?       @map("manager_score")
  managerComments String?  @db.Text       @map("manager_comments")
  managerGoals    Json?                   @map("manager_goals")

  // Final score (post-calibration)
  finalScore      PerformanceScore?       @map("final_score")
  finalComments   String?  @db.Text       @map("final_comments")

  // 9-box position (performance x potential)
  nineBoxPerformance Int?                 @map("nine_box_performance")
  nineBoxPotential   Int?                 @map("nine_box_potential")

  // Process dates
  selfReviewDueAt     DateTime?           @map("self_review_due_at")
  managerReviewDueAt  DateTime?           @map("manager_review_due_at")
  publishedAt         DateTime?           @map("published_at")
  acknowledgedAt      DateTime?           @map("acknowledged_at")

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  createdBy    String?  @map("created_by")

  tenant       Tenant       @relation("TenantPerformanceReviews", fields: [tenantId], references: [id], onDelete: Cascade)
  reviewee     Employee     @relation("RevieweeEmployee", fields: [revieweeId], references: [id])
  reviewer     Employee     @relation("ReviewerEmployee", fields: [reviewerId], references: [id])
  cycle        ReviewCycle? @relation(fields: [cycleId], references: [id])

  @@index([tenantId])
  @@index([tenantId, revieweeId])
  @@index([tenantId, cycleId])
  @@map("performance_reviews")
}

model OneOnOne {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  employeeId   String   @map("employee_id")
  managerId    String   @map("manager_id")

  // Session
  scheduledAt  DateTime @map("scheduled_at")
  completedAt  DateTime? @map("completed_at")
  duration     Int?
  meetingUrl   String?  @map("meeting_url")

  // Content
  agenda        String?  @db.Text
  employeeNotes String?  @db.Text @map("employee_notes")
  managerNotes  String?  @db.Text @map("manager_notes")
  sharedNotes   String?  @db.Text @map("shared_notes")
  actionItems   Json?    @map("action_items")

  isCancelled  Boolean  @default(false) @map("is_cancelled")
  cancelReason String?  @map("cancel_reason")

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant       Tenant   @relation("TenantOneOnOnes", fields: [tenantId], references: [id], onDelete: Cascade)
  employee     Employee @relation("OneOnOneEmployee", fields: [employeeId], references: [id])
  manager      Employee @relation("OneOnOneManager", fields: [managerId], references: [id])

  @@index([tenantId])
  @@index([tenantId, employeeId])
  @@index([tenantId, managerId])
  @@map("one_on_ones")
}

model HrTimeEntry {
  id              String          @id @default(cuid())
  tenantId        String          @map("tenant_id")
  employeeId      String          @map("employee_id")
  date            DateTime        @db.Date
  status          HrTimeEntryStatus @default(PENDING)

  // Clock records
  clockIn         DateTime?       @map("clock_in")
  clockOut        DateTime?       @map("clock_out")
  breakMinutes    Int?            @default(0) @map("break_minutes")
  totalMinutes    Int?            @map("total_minutes")

  // Overtime and bank hours
  expectedMinutes Int?            @map("expected_minutes")
  overtimeMinutes Int?            @map("overtime_minutes")

  // Entry type
  entryType       String          @default("REGULAR") @map("entry_type")
  notes           String?

  // External integration (VR Gente / Ahgora)
  externalId      String?         @map("external_id")
  externalSource  String?         @map("external_source")

  // Approval
  approvedBy      String?         @map("approved_by")
  approvedAt      DateTime?       @map("approved_at")
  rejectedBy      String?         @map("rejected_by")
  rejectedAt      DateTime?       @map("rejected_at")
  rejectionNote   String?         @map("rejection_note")

  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  tenant          Tenant    @relation("TenantHrTimeEntries", fields: [tenantId], references: [id], onDelete: Cascade)
  employee        Employee  @relation(fields: [employeeId], references: [id])

  @@unique([tenantId, employeeId, date])
  @@index([tenantId])
  @@index([tenantId, employeeId])
  @@index([tenantId, date])
  @@index([tenantId, status])
  @@map("hr_time_entries")
}

model LgpdConsent {
  id           String            @id @default(cuid())
  tenantId     String            @map("tenant_id")
  employeeId   String?           @map("employee_id")
  purpose      LgpdDataPurpose
  status       LgpdConsentStatus @default(PENDING)

  // Consent record
  grantedAt    DateTime?         @map("granted_at")
  revokedAt    DateTime?         @map("revoked_at")
  expiresAt    DateTime?         @map("expires_at")
  consentText  String   @db.Text @map("consent_text")
  ipAddress    String?           @map("ip_address")
  userAgent    String?           @map("user_agent")
  channel      String?

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant       Tenant    @relation("TenantLgpdConsents", fields: [tenantId], references: [id], onDelete: Cascade)
  employee     Employee? @relation(fields: [employeeId], references: [id])

  @@index([tenantId])
  @@index([tenantId, employeeId])
  @@index([tenantId, purpose])
  @@map("lgpd_consents")
}

model LgpdRetentionPolicy {
  id              String          @id @default(cuid())
  tenantId        String          @map("tenant_id")
  dataType        String          @map("data_type")
  purpose         LgpdDataPurpose
  retentionDays   Int             @map("retention_days")
  retentionEvent  String          @map("retention_event")
  legalBasis      String          @map("legal_basis")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  tenant          Tenant          @relation("TenantLgpdRetentionPolicies", fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, dataType, purpose])
  @@map("lgpd_retention_policies")
}

model PeopleAuditLog {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  entityType      String   @map("entity_type")
  entityId        String   @map("entity_id")
  action          String
  actorId         String   @map("actor_id")
  actorType       String   @default("USER") @map("actor_type")
  changes         Json?
  sensitiveFields String[] @map("sensitive_fields")
  ipAddress       String?  @map("ip_address")
  userAgent       String?  @map("user_agent")
  reason          String?

  // Immutable — never update this record
  createdAt       DateTime @default(now()) @map("created_at")

  tenant          Tenant   @relation("TenantPeopleAuditLogs", fields: [tenantId], references: [id], onDelete: Cascade)
  employee        Employee? @relation(fields: [entityId], references: [id], map: "audit_employee_fk")

  @@index([tenantId])
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, actorId])
  @@index([createdAt])
  @@map("people_audit_logs")
}

