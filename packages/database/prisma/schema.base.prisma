/// F2.4 Multi-Workspace Ownership Model.
/// Owns N Tenants (up to MAX_TENANTS plan quota) and N Subscriptions (1:N, MVP uses 1:1).
/// Replaces the implicit "1 Tenant = 1 Subscription = 1 Stripe Customer" model.
/// See docs/planning/stories/epic-4-framework/sprint-f2/F2.4-multi-workspace-ownership-model.md
model BillingAccount {
  id               String   @id @default(uuid())

  /// Billing admin / dono desta BillingAccount. Single-owner na v1.
  /// Multi-owner via BillingAccountMember entra em F2.4.6 (deferred).
  /// onDelete: Restrict — owner não pode ser removido enquanto for dono de uma BA
  /// (precisa transferir ownership primeiro, flow implementado em F2.4.6).
  ownerUserId      String   @map("owner_user_id")

  /// Stripe Customer ID. Source of truth após F2.4.2 backfill move de Tenant.
  /// Unique: uma BA mapeia 1:1 para um Customer Stripe.
  stripeCustomerId String?  @unique @map("stripe_customer_id")

  /// Display name / razão social (opcional v1).
  name             String?

  /// F2.4.3.1 — Origin of this BillingAccount record.
  /// 'signup' (default) = created by user signup flow (auth.service.register).
  /// 'backfill_f2_4_2' = created by f2-4-backfill.ts for pre-F2.4 tenants.
  /// Used by f2-4-rollback.sql to distinguish which BAs are safe to delete
  /// without losing signup data. Do NOT filter by created_at for rollback.
  source           String    @default("signup")

  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  // Relations
  owner            User           @relation("BillingAccountOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  tenants          Tenant[]
  subscriptions    Subscription[]

  @@index([ownerUserId])
  @@index([stripeCustomerId])
  @@index([deletedAt])
  @@map("billing_accounts")
}

model User {
  id               String     @id @default(uuid())
  /// @unique -- Global unique email; used as primary login identifier across all tenants
  email            String     @unique
  /// @encrypted — Stored as bcrypt hash (12 salt rounds). See apps/api/src/lib/password.ts
  password         String
  name             String
  phone            String?
  avatar           String? // URL do avatar do usuário
  emailVerified    Boolean    @default(false)
  emailVerifiedAt  DateTime?
  twoFactorEnabled Boolean    @default(false)
