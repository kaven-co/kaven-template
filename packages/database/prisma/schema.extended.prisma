  tenant   Tenant   @relation("TenantCampaignTags", fields: [tenantId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  tag      Tag      @relation("TagCampaigns", fields: [tagId], references: [id], onDelete: Cascade)

