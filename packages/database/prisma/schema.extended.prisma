// Campaigns, automation, lead scoring, consent management, forms,
// UTM tracking, email templates, calendar. Multi-tenant isolated via tenantId.
// Cross-module FKs: contactId → clients.Contact, segmentId → clients.Segment, tagId → clients.Tag

// [KAVEN_MODULE:MARKETING BEGIN]

// ---------- Enums ----------

enum CampaignStatus {
