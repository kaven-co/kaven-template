// ===========================
// SAAS OPERATIONS MODULE (MRR & Churn Core)
// ===========================
// SaaS revenue operations: MRR calculation engine, Stripe webhook
// integration, churn event tracking with dunning, revenue dashboards.
// Builds on existing Subscription, Plan, Payment models.

// [KAVEN_MODULE:SAAS_OPS BEGIN]

// ---------- Enums ----------

enum ChurnType {
  VOLUNTARY
  INVOLUNTARY
  TRIAL_EXPIRED
  DOWNGRADE

  @@map("churn_type")
}

enum ChurnReason {
  PRICE
  FEATURES
  COMPETITOR
  SUPPORT
  NOT_USING
  BUG
  BUSINESS_CLOSED
  OTHER

  @@map("churn_reason")
}

enum ExpansionType {
  PLAN_UPGRADE
  SEAT_EXPANSION
  ADDON
  REACTIVATION

  @@map("expansion_type")
}

enum CustomerHealthCategory {
  HEALTHY
  AT_RISK
  CRITICAL
  CHURNED

  @@map("customer_health_category")
}

// ---------- Models ----------

// 1. MRRSnapshot — Monthly MRR calculation with 5 movements
model MRRSnapshot {
  id                  String   @id @default(cuid())
  tenantId            String   @map("tenant_id")
  snapshotDate        DateTime @map("snapshot_date")
  mrrTotal            Decimal  @db.Decimal(12, 2) @map("mrr_total")
  mrrNewBusiness      Decimal  @db.Decimal(12, 2) @default(0) @map("mrr_new_business")
  mrrExpansion        Decimal  @db.Decimal(12, 2) @default(0) @map("mrr_expansion")
  mrrContraction      Decimal  @db.Decimal(12, 2) @default(0) @map("mrr_contraction")
  mrrChurn            Decimal  @db.Decimal(12, 2) @default(0) @map("mrr_churn")
  mrrReactivation     Decimal  @db.Decimal(12, 2) @default(0) @map("mrr_reactivation")
  recognizedRevenue   Decimal  @db.Decimal(12, 2) @map("recognized_revenue")
  deferredRevenue     Decimal  @db.Decimal(12, 2) @default(0) @map("deferred_revenue")
  arrProjected        Decimal  @db.Decimal(12, 2) @map("arr_projected")
  arpu                Decimal  @db.Decimal(10, 2)
  activeSubscribers   Int      @default(0) @map("active_subscribers")
  currency            String   @default("USD")
  calculatedAt        DateTime @default(now()) @map("calculated_at")
  calculationVersion  String   @default("1") @map("calculation_version")
  metadata            Json?

  // Relations
  tenant              Tenant   @relation("TenantMRRSnapshots", fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, snapshotDate])
  @@index([tenantId, snapshotDate])
  @@index([snapshotDate])
  @@map("mrr_snapshots")
}

// 2. StripeWebhookEvent — Idempotency store for Stripe events
model StripeWebhookEvent {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  eventId         String   @unique @map("event_id")
  eventType       String   @map("event_type")
  payload         Json
  processed       Boolean  @default(false)
  processedAt     DateTime? @map("processed_at")
  error           String?

  createdAt       DateTime @default(now()) @map("created_at")

  // Relations
  tenant          Tenant   @relation("TenantStripeWebhookEvents", fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, eventType])
  @@index([eventId])
  @@index([processed])
  @@map("stripe_webhook_events")
}

// 3. ChurnEvent — Churn tracking with categorized reasons
model ChurnEvent {
  id                    String      @id @default(cuid())
  tenantId              String      @map("tenant_id")
  subscriptionId        String      @map("subscription_id")
  planId                String      @map("plan_id")
  planName              String      @map("plan_name")
  churnType             ChurnType   @map("churn_type")
  churnReason           ChurnReason? @map("churn_reason")
  churnReasonText       String?     @map("churn_reason_text")
  competitor            String?
  mrrLost               Decimal     @db.Decimal(10, 2) @map("mrr_lost")
  arrLost               Decimal     @db.Decimal(10, 2) @map("arr_lost")
  ltv                   Decimal?    @db.Decimal(10, 2)
  subscriptionStartedAt DateTime    @map("subscription_started_at")
  churnedAt             DateTime    @map("churned_at")
  subscriptionAgeInDays Int         @map("subscription_age_in_days")
  lastLoginAt           DateTime?   @map("last_login_at")
  featureUsageScore     Int?        @map("feature_usage_score")
  invoicesOverdue       Int         @default(0) @map("invoices_overdue")
  dunningAttempts       Int         @default(0) @map("dunning_attempts")
  dunningStartedAt      DateTime?   @map("dunning_started_at")
  reactivatedAt         DateTime?   @map("reactivated_at")
  reactivationMRR       Decimal?    @db.Decimal(10, 2) @map("reactivation_mrr")
  sourceSystem          String      @default("internal") @map("source_system")
  metadata              Json?

  createdAt             DateTime    @default(now()) @map("created_at")
  updatedAt             DateTime    @updatedAt @map("updated_at")

  // Relations
  tenant                Tenant      @relation("TenantChurnEvents", fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, churnedAt])
  @@index([churnType, churnedAt])
  @@index([subscriptionId])
  @@index([churnedAt])
  @@map("churn_events")
}

// 4. CohortAnalysis — Cohort retention snapshot
model CohortAnalysis {
  id                  String   @id @default(cuid())
  cohortMonth         DateTime @map("cohort_month")
  cohortSize          Int      @map("cohort_size")
  analysisMonth       DateTime @map("analysis_month")
  monthsElapsed       Int      @map("months_elapsed")
  activeCount         Int      @map("active_count")
  churnedCount        Int      @map("churned_count")
  retentionRate       Decimal  @db.Decimal(5, 4) @map("retention_rate")
  cumulativeChurnRate Decimal  @db.Decimal(5, 4) @map("cumulative_churn_rate")
  mrrCohortEntry      Decimal  @db.Decimal(12, 2) @map("mrr_cohort_entry")
  mrrCurrent          Decimal  @db.Decimal(12, 2) @map("mrr_current")
  nrr                 Decimal  @db.Decimal(5, 4)
  grr                 Decimal  @db.Decimal(5, 4)
  segment             String?
  segmentValue        String?  @map("segment_value")

  calculatedAt        DateTime @default(now()) @map("calculated_at")

  @@unique([cohortMonth, analysisMonth, segment])
  @@index([cohortMonth, monthsElapsed])
  @@index([analysisMonth])
  @@map("cohort_analyses")
}

// 5. FeatureAdoptionLog — Feature usage tracking per tenant
model FeatureAdoptionLog {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  featureKey      String   @map("feature_key")
  featureModule   String   @map("feature_module")
  featureCategory String?  @map("feature_category")
  usageDate       DateTime @map("usage_date")
  eventCount      Int      @default(0) @map("event_count")
  uniqueUsers     Int      @default(0) @map("unique_users")
  avgDurationMs   Int?     @map("avg_duration_ms")
  errorCount      Int      @default(0) @map("error_count")
  p95DurationMs   Int?     @map("p95_duration_ms")
  planName        String?  @map("plan_name")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  tenant          Tenant   @relation("TenantFeatureAdoptionLogs", fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, featureKey, usageDate])
  @@index([tenantId, featureModule, usageDate])
  @@index([featureKey, usageDate])
  @@index([tenantId, usageDate])
  @@map("feature_adoption_logs")
}

// 6. RevenueMetric — Expansion/contraction revenue events
model RevenueMetric {
  id                  String         @id @default(cuid())
  tenantId            String         @map("tenant_id")
  subscriptionId      String         @map("subscription_id")
  expansionType       ExpansionType  @map("expansion_type")
  fromPlanId          String?        @map("from_plan_id")
  fromPlanName        String?        @map("from_plan_name")
  toPlanId            String         @map("to_plan_id")
  toPlanName          String         @map("to_plan_name")
  mrrBefore           Decimal        @db.Decimal(10, 2) @map("mrr_before")
  mrrAfter            Decimal        @db.Decimal(10, 2) @map("mrr_after")
  mrrDelta            Decimal        @db.Decimal(10, 2) @map("mrr_delta")
  triggeredBy         String?        @map("triggered_by")
  featuresThatDrove   Json?          @map("features_that_drove")
  campaignId          String?        @map("campaign_id")
  expandedAt          DateTime       @default(now()) @map("expanded_at")
  metadata            Json?

  // Relations
  tenant              Tenant         @relation("TenantRevenueMetrics", fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, expandedAt])
  @@index([expansionType, expandedAt])
  @@index([subscriptionId])
  @@map("revenue_metrics")
}

// 7. CustomerHealthScore — Tenant health score for churn prediction
model CustomerHealthScore {
  id                    String         @id @default(cuid())
  tenantId              String         @map("tenant_id")
  calculatedAt          DateTime       @default(now()) @map("calculated_at")
  overallScore          Int            @map("overall_score")
  scoreCategory         CustomerHealthCategory @map("score_category")
  usageFrequencyScore   Int            @map("usage_frequency_score")
  featureBreadthScore   Int            @map("feature_breadth_score")
  paymentHealthScore    Int            @map("payment_health_score")
  expansionSignalScore  Int            @map("expansion_signal_score")
  engagementScore       Int            @map("engagement_score")
  previousScore         Int?           @map("previous_score")
  scoreDelta            Int?           @map("score_delta")
  alertsTriggered       Json?          @map("alerts_triggered")
  recommendedActions    Json?          @map("recommended_actions")
  metadata              Json?

  // Relations
  tenant                Tenant         @relation("TenantCustomerHealthScores", fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, calculatedAt])
  @@index([tenantId, calculatedAt])
  @@index([scoreCategory, calculatedAt])
  @@index([overallScore])
  @@map("customer_health_scores")
}

// [KAVEN_MODULE:SAAS_OPS END]

// [KAVEN_MODULE:PROPERTY_MANAGEMENT BEGIN]

// ---------- Enums ----------

enum PropertyType {
  RESIDENTIAL
  COMMERCIAL
  LAND
  MIXED

  @@map("property_type")
}

enum PropertyStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
  UNAVAILABLE

  @@map("property_status")
}

enum UnitType {
  APARTMENT
  HOUSE
  STORE
  OFFICE
  WAREHOUSE
  STUDIO
  GARAGE
  OTHER

  @@map("unit_type")
}

enum LeaseStatus {
  DRAFT
  ACTIVE
  EXPIRING_SOON
  EXPIRED
  TERMINATED
  RENEWED

  @@map("lease_status")
}

enum RentPaymentStatus {
  PENDING
  PAID
  OVERDUE
  PARTIAL
  CANCELLED

  @@map("rent_payment_status")
}

enum GuarantorType {
  GUARANTOR_PERSON
  SURETY_BOND
  CAPITALIZATION
  DEPOSIT
  NONE

  @@map("guarantor_type")
}

enum AdjustmentIndex {
  IGPM
  IPCA
  INPC
  IVAR
  FIXED
  NONE

  @@map("adjustment_index")
}

// ---------- 1. Property ----------

model Property {
  id              String         @id @default(cuid())
  tenantId        String         @map("tenant_id")
  name            String
  type            PropertyType   @default(RESIDENTIAL)
  status          PropertyStatus @default(AVAILABLE)

  // Address
  addressStreet   String         @map("address_street")
  addressNumber   String?        @map("address_number")
  addressComplement String?      @map("address_complement")
  addressNeighborhood String?    @map("address_neighborhood")
  addressCity     String         @map("address_city")
  addressState    String         @map("address_state")
  addressZipCode  String         @map("address_zip_code")
  addressCountry  String         @default("BR") @map("address_country")

  // Details
  area            Float?         // Total area in m²
  marketValue     Float?         @map("market_value")
  registrationNumber String?     @map("registration_number") // Matrícula do imóvel
  iptuNumber      String?        @map("iptu_number")
  notes           String?

  createdById     String         @map("created_by_id")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  deletedAt       DateTime?      @map("deleted_at")

  // Relations
  tenant    Tenant @relation("TenantProperties", fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User   @relation("PropertyCreator", fields: [createdById], references: [id])
  units     PropertyUnit[]
  leases    Lease[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, type])
  @@map("properties")
}

// ---------- 2. PropertyUnit ----------

model PropertyUnit {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  propertyId   String   @map("property_id")
  unitNumber   String   @map("unit_number")
  type         UnitType @default(APARTMENT)
  floor        Int?
  area         Float?   // Area in m²
  bedrooms     Int?
  bathrooms    Int?
  parkingSpots Int?     @map("parking_spots")
  isAvailable  Boolean  @default(true) @map("is_available")
  monthlyRent  Float?   @map("monthly_rent") // Suggested rent value
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  // Relations
  tenant   Tenant   @relation("TenantPropertyUnits", fields: [tenantId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  leases   Lease[]

  @@unique([tenantId, propertyId, unitNumber])
  @@index([tenantId])
  @@index([tenantId, propertyId])
  @@index([tenantId, isAvailable])
  @@map("property_units")
}

// ---------- 3. Renter ----------

model Renter {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  name         String
  email        String?
  phone        String?
  cpf          String?  // Brazilian CPF
  rg           String?  // Brazilian RG
  birthDate    DateTime? @map("birth_date")
  profession   String?
  monthlyIncome Float?  @map("monthly_income")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  // Relations
  tenant     Tenant      @relation("TenantRenters", fields: [tenantId], references: [id], onDelete: Cascade)
  guarantors Guarantor[]
  leases     Lease[]

  @@index([tenantId])
  @@index([tenantId, cpf])
  @@index([tenantId, name])
  @@map("renters")
}

// ---------- 4. Guarantor ----------

model Guarantor {
  id           String        @id @default(cuid())
  tenantId     String        @map("tenant_id")
  renterId     String        @map("renter_id")
  type         GuarantorType @default(GUARANTOR_PERSON)
  name         String
  cpf          String?
  phone        String?
  email        String?
  // For SURETY_BOND / CAPITALIZATION
  policyNumber String?       @map("policy_number")
  insurerName  String?       @map("insurer_name")
  coverageAmount Float?      @map("coverage_amount")
  expiresAt    DateTime?     @map("expires_at")
  notes        String?
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  // Relations
  tenant Tenant @relation("TenantGuarantors", fields: [tenantId], references: [id], onDelete: Cascade)
  renter Renter @relation(fields: [renterId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, renterId])
  @@map("guarantors")
}

// ---------- 5. Lease ----------

model Lease {
  id              String          @id @default(cuid())
  tenantId        String          @map("tenant_id")
  propertyId      String          @map("property_id")
  unitId          String?         @map("unit_id")
  renterId        String          @map("renter_id")
  status          LeaseStatus     @default(DRAFT)

  // Contract terms
  startDate       DateTime        @map("start_date")
  endDate         DateTime        @map("end_date")
  monthlyRent     Float           @map("monthly_rent")
  adjustmentIndex AdjustmentIndex @default(IGPM) @map("adjustment_index")
  adjustmentMonth Int?            @map("adjustment_month") // 1-12, month for annual adjustment
  deposit         Float?          // Caução
  lateFeePercent  Float?          @default(2) @map("late_fee_percent")
  lateFeeDaily    Float?          @default(0.033) @map("late_fee_daily") // Mora diária %

  // Audit
  statusChangedAt DateTime?       @map("status_changed_at")
  statusReason    String?         @map("status_reason")
  renewedFromId   String?         @map("renewed_from_id")

  createdById     String          @map("created_by_id")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  deletedAt       DateTime?       @map("deleted_at")

  // Relations
  tenant       Tenant       @relation("TenantLeases", fields: [tenantId], references: [id], onDelete: Cascade)
  property     Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit         PropertyUnit? @relation(fields: [unitId], references: [id], onDelete: SetNull)
  renter       Renter       @relation(fields: [renterId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("LeaseCreator", fields: [createdById], references: [id])
  renewedFrom  Lease?       @relation("LeaseRenewal", fields: [renewedFromId], references: [id])
  renewals     Lease[]      @relation("LeaseRenewal")
  rentPayments RentPayment[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, propertyId])
  @@index([tenantId, renterId])
  @@index([tenantId, endDate])
  @@map("leases")
}

// ---------- 6. RentPayment ----------

model RentPayment {
  id           String            @id @default(cuid())
  tenantId     String            @map("tenant_id")
  leaseId      String            @map("lease_id")
  dueDate      DateTime          @map("due_date")
  amount       Float             // Expected amount
  paidAmount   Float?            @map("paid_amount")
  paidDate     DateTime?         @map("paid_date")
  status       RentPaymentStatus @default(PENDING)
  lateFee      Float?            @map("late_fee")
  notes        String?
  referenceMonth String?         @map("reference_month") // "2026-03"
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  // Relations
  tenant Tenant @relation("TenantRentPayments", fields: [tenantId], references: [id], onDelete: Cascade)
  lease  Lease  @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, leaseId])
  @@index([tenantId, status])
  @@index([tenantId, dueDate])
  @@map("rent_payments")
}

// [KAVEN_MODULE:PROPERTY_MANAGEMENT END]

// [KAVEN_MODULE:INVENTORY_FULFILLMENT BEGIN]

// ---------- Enums ----------

enum WarehouseType {
  MAIN
  STORE
  VIRTUAL
  TRANSIT

  @@map("warehouse_type")
}

enum StockMovementType {
  IN
  OUT
  RESERVE
  RELEASE
  ADJUST
  TRANSFER
  RETURN_SUPPLIER
  RETURN_CUSTOMER

  @@map("stock_movement_type")
}

enum SalesOrderStatus {
  DRAFT
  CONFIRMED
  PICKING
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED

  @@map("sales_order_status")
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  CONFIRMED
  PARTIAL_RECEIVED
  RECEIVED
  CANCELLED

  @@map("purchase_order_status")
}

// ---------- 1. Warehouse ----------

model Warehouse {
  id          String        @id @default(cuid())
  tenantId    String        @map("tenant_id")
  name        String
  code        String
  type        WarehouseType @default(MAIN)
  address     Json?         // Full address object
  isActive    Boolean       @default(true) @map("is_active")
  isDefault   Boolean       @default(false) @map("is_default")
  createdById String        @map("created_by_id")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  deletedAt   DateTime?     @map("deleted_at")

  // Relations
  tenant     Tenant      @relation("TenantWarehouses", fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy  User        @relation("WarehouseCreator", fields: [createdById], references: [id])
  stockItems StockItem[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@map("warehouses")
}

// ---------- 2. StockItem ----------

model StockItem {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  sku           String
  productId     String?  @map("product_id") // FK to existing Product (nullable for standalone SKUs)
  warehouseId   String   @map("warehouse_id")
  name          String   // Product/SKU name for display
  quantity      Int      @default(0)
  reservedQty   Int      @default(0) @map("reserved_qty")
  reorderPoint  Int?     @map("reorder_point")
  reorderQty    Int?     @map("reorder_qty")
  maxQty        Int?     @map("max_qty")
  location      String?  // Shelf/slot: "A1-B2-C3"
  costPrice     Float?   @map("cost_price") // Weighted average cost
  barcode       String?
  lastCountedAt DateTime? @map("last_counted_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  // Relations
  tenant           Tenant          @relation("TenantStockItems", fields: [tenantId], references: [id], onDelete: Cascade)
  warehouse        Warehouse       @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  movements        StockMovement[]
  salesOrderItems  SalesOrderItem[]
  purchaseOrderItems PurchaseOrderItem[]

  @@unique([tenantId, sku, warehouseId])
  @@index([tenantId])
  @@index([tenantId, warehouseId])
  @@index([tenantId, sku])
  @@map("stock_items")
}

// ---------- 3. StockMovement ----------

model StockMovement {
  id            String           @id @default(cuid())
  tenantId      String           @map("tenant_id")
  stockItemId   String           @map("stock_item_id")
  type          StockMovementType
  quantity      Int              // Always positive; direction implied by type
  reason        String?
  reference     String?          // External ref (PO number, SO number, etc.)
  referenceType String?          @map("reference_type") // "SALES_ORDER", "PURCHASE_ORDER", "MANUAL"
  referenceId   String?          @map("reference_id")
  costPerUnit   Float?           @map("cost_per_unit")
  createdById   String           @map("created_by_id")
  createdAt     DateTime         @default(now()) @map("created_at")

  // Relations — append-only: no updatedAt
  tenant    Tenant    @relation("TenantStockMovements", fields: [tenantId], references: [id], onDelete: Cascade)
  stockItem StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  createdBy User      @relation("StockMovementCreator", fields: [createdById], references: [id])

  @@index([tenantId])
  @@index([tenantId, stockItemId])
  @@index([tenantId, type])
  @@index([tenantId, createdAt])
  @@map("stock_movements")
}

// ---------- 4. SalesOrder ----------

model SalesOrder {
  id             String           @id @default(cuid())
  tenantId       String           @map("tenant_id")
  orderNumber    String           @map("order_number")
  status         SalesOrderStatus @default(DRAFT)
  customerName   String?          @map("customer_name")
  customerEmail  String?          @map("customer_email")
  shippingAddress Json?           @map("shipping_address")
  subtotal       Float            @default(0)
  discount       Float            @default(0)
  shippingCost   Float            @default(0) @map("shipping_cost")
  total          Float            @default(0)
  notes          String?
  statusChangedAt DateTime?       @map("status_changed_at")
  statusHistory  Json?            @map("status_history") // Array of { status, timestamp, userId }
  shippedAt      DateTime?        @map("shipped_at")
  deliveredAt    DateTime?        @map("delivered_at")
  cancelledAt    DateTime?        @map("cancelled_at")
  cancelReason   String?          @map("cancel_reason")
  trackingCode   String?          @map("tracking_code")
  createdById    String           @map("created_by_id")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  deletedAt      DateTime?        @map("deleted_at")

  // Relations
  tenant    Tenant           @relation("TenantSalesOrders", fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User             @relation("SalesOrderCreator", fields: [createdById], references: [id])
  items     SalesOrderItem[]

  @@unique([tenantId, orderNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@map("sales_orders")
}

// ---------- 5. SalesOrderItem ----------

model SalesOrderItem {
  id           String @id @default(cuid())
  tenantId     String @map("tenant_id")
  salesOrderId String @map("sales_order_id")
  stockItemId  String @map("stock_item_id")
  quantity     Int
  unitPrice    Float  @map("unit_price")
  total        Float  @default(0)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  tenant     Tenant     @relation("TenantSalesOrderItems", fields: [tenantId], references: [id], onDelete: Cascade)
  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  stockItem  StockItem  @relation(fields: [stockItemId], references: [id], onDelete: Cascade)

  @@index([tenantId, salesOrderId])
  @@map("sales_order_items")
}

// ---------- 6. PurchaseOrder ----------

model PurchaseOrder {
  id              String              @id @default(cuid())
  tenantId        String              @map("tenant_id")
  orderNumber     String              @map("order_number")
  status          PurchaseOrderStatus @default(DRAFT)
  supplierName    String              @map("supplier_name")
  supplierEmail   String?             @map("supplier_email")
  supplierPhone   String?             @map("supplier_phone")
  expectedDate    DateTime?           @map("expected_date")
  receivedDate    DateTime?           @map("received_date")
  subtotal        Float               @default(0)
  shippingCost    Float               @default(0) @map("shipping_cost")
  total           Float               @default(0)
  notes           String?
  statusChangedAt DateTime?           @map("status_changed_at")
  statusHistory   Json?               @map("status_history")
  createdById     String              @map("created_by_id")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  deletedAt       DateTime?           @map("deleted_at")

  // Relations
  tenant    Tenant              @relation("TenantPurchaseOrders", fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User                @relation("PurchaseOrderCreator", fields: [createdById], references: [id])
  items     PurchaseOrderItem[]

  @@unique([tenantId, orderNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@map("purchase_orders")
}

// ---------- 7. PurchaseOrderItem ----------

model PurchaseOrderItem {
  id               String   @id @default(cuid())
  tenantId         String   @map("tenant_id")
  purchaseOrderId  String   @map("purchase_order_id")
  stockItemId      String   @map("stock_item_id")
  quantity         Int
  unitCost         Float    @map("unit_cost")
  receivedQuantity Int      @default(0) @map("received_quantity")
  total            Float    @default(0)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Relations
  tenant        Tenant        @relation("TenantPurchaseOrderItems", fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  stockItem     StockItem     @relation(fields: [stockItemId], references: [id], onDelete: Cascade)

  @@index([tenantId, purchaseOrderId])
  @@map("purchase_order_items")
}

