// [KAVEN_MODULE:MARKETING END]

// ===========================
// GOVERNANCE MODULE
// ===========================
// OKR management, meetings, decisions, board governance, and strategic planning.
// Multi-tenant isolated via tenantId. Cross-module FKs: Initiative→Project (nullable).

// [KAVEN_MODULE:GOVERNANCE BEGIN]

// ---------- Enums ----------

enum OKRCycleType {
  ANNUAL
  SEMI_ANNUAL
  QUARTERLY
  MONTHLY
  CUSTOM

  @@map("okr_cycle_type")
}

enum OKRCycleStatus {
  PLANNING
  ACTIVE
  REVIEW
  CLOSED

  @@map("okr_cycle_status")
}

enum ObjectiveLevel {
  COMPANY
  DEPARTMENT
  TEAM
  INDIVIDUAL

  @@map("objective_level")
}

enum OKRStatus {
  DRAFT
  ON_TRACK
  AT_RISK
  OFF_TRACK
  COMPLETED
  CANCELLED

  @@map("okr_status")
}

enum OKRPrivacy {
  PUBLIC
  TEAM
  PRIVATE

  @@map("okr_privacy")
}

enum KRType {
  NUMERIC
  PERCENT
  BINARY
  CURRENCY

  @@map("kr_type")
}

enum KRDataSource {
  MANUAL
  FINANCE
  SALES
  PROJECTS
  PEOPLE

  @@map("kr_data_source")
}

enum CheckInConfidence {
  LOW
  MEDIUM
  HIGH

  @@map("check_in_confidence")
}

enum InitiativeStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED

  @@map("initiative_status")
}

enum MeetingType {
  ONE_ON_ONE
  TEAM
  ALL_HANDS
  BOARD
  COMMITTEE
  STANDUP

  @@map("meeting_type")
}

enum MeetingLocation {
  IN_PERSON
  VIRTUAL
  HYBRID

  @@map("meeting_location")
}

enum MeetingStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED

  @@map("meeting_status")
}

enum AgendaItemType {
  INFO
  DISCUSSION
  VOTE
  REPORT
  ACTION

  @@map("agenda_item_type")
}

enum ActionItemStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED

  @@map("action_item_status")
}

enum GovPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL

  @@map("gov_priority")
}

enum DecisionType {
  OPERATIONAL
  STRATEGIC
  FINANCIAL
  POLICY
  TECHNICAL

  @@map("decision_type")
}

enum DecisionOutcome {
  APPROVED
  REJECTED
  DEFERRED
  WITHDRAWN

  @@map("decision_outcome")
}

enum BoardType {
  BOARD
  COMMITTEE
  ADVISORY
  INVESTOR

  @@map("board_type")
}

enum BoardRole {
  CHAIR
  VICE_CHAIR
  SECRETARY
  TREASURER
  MEMBER
  OBSERVER

  @@map("board_role")
}

enum StrategicHorizon {
  SHORT_TERM
  MID_TERM
  LONG_TERM

  @@map("strategic_horizon")
}

// ---------- Models ----------

// 1. OKRCycle — Time-bounded period for objectives (e.g. Q1 2026)
model OKRCycle {
  id          String         @id @default(cuid())
  tenantId    String         @map("tenant_id")
  name        String         // e.g. "Q1 2026"
  description String?
  type        OKRCycleType   @default(QUARTERLY)
  status      OKRCycleStatus @default(PLANNING)
  startDate   DateTime       @map("start_date")
  endDate     DateTime       @map("end_date")
  createdById String         @map("created_by_id")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  // Relations
  tenant     Tenant      @relation("TenantOKRCycles", fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy  User        @relation("OKRCycleCreator", fields: [createdById], references: [id])
  objectives Objective[]

  @@index([tenantId, status])
  @@index([tenantId, startDate])
  @@map("okr_cycles")
}

// 2. Objective — A goal within an OKR cycle, supports hierarchy (parent→child)
model Objective {
  id          String         @id @default(cuid())
  tenantId    String         @map("tenant_id")
  cycleId     String         @map("cycle_id")
  parentId    String?        @map("parent_id")
  title       String
  description String?
  level       ObjectiveLevel @default(COMPANY)
  status      OKRStatus      @default(DRAFT)
  privacy     OKRPrivacy     @default(PUBLIC)
  progress    Float          @default(0) // 0-100, auto-calculated from KRs
  ownerId     String         @map("owner_id")
  deletedAt   DateTime?      @map("deleted_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  // Relations
  tenant     Tenant       @relation("TenantObjectives", fields: [tenantId], references: [id], onDelete: Cascade)
  cycle      OKRCycle     @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  parent     Objective?   @relation("ObjectiveHierarchy", fields: [parentId], references: [id])
  children   Objective[]  @relation("ObjectiveHierarchy")
  owner      User         @relation("ObjectiveOwner", fields: [ownerId], references: [id])
  keyResults KeyResult[]
  initiatives Initiative[]

  @@index([tenantId, cycleId])
  @@index([tenantId, ownerId])
  @@index([tenantId, parentId])
  @@map("objectives")
}

// 3. KeyResult — Measurable outcome for an Objective
model KeyResult {
  id           String       @id @default(cuid())
  tenantId     String       @map("tenant_id")
  objectiveId  String       @map("objective_id")
  title        String
  description  String?
  type         KRType       @default(PERCENT)
  dataSource   KRDataSource @default(MANUAL)
  startValue   Float        @default(0) @map("start_value")
  currentValue Float        @default(0) @map("current_value")
  targetValue  Float        @default(100) @map("target_value")
  unit         String?      // e.g. "BRL", "%", "deals"
  progress     Float        @default(0) // 0-100, auto-calculated
  status       OKRStatus    @default(DRAFT)
  ownerId      String       @map("owner_id")
  deletedAt    DateTime?    @map("deleted_at")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant        @relation("TenantKeyResults", fields: [tenantId], references: [id], onDelete: Cascade)
  objective Objective     @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  owner     User          @relation("KeyResultOwner", fields: [ownerId], references: [id])
  checkIns  OKRCheckIn[]
  initiatives Initiative[]

  @@index([tenantId, objectiveId])
  @@index([tenantId, ownerId])
  @@map("key_results")
}

// 4. OKRCheckIn — Periodic update on a KeyResult's progress
model OKRCheckIn {
  id           String           @id @default(cuid())
  tenantId     String           @map("tenant_id")
  keyResultId  String           @map("key_result_id")
  value        Float            // The new value for the KR
  previousValue Float           @map("previous_value")
  confidence   CheckInConfidence @default(MEDIUM)
  notes        String?
  blockers     String?
  createdById  String           @map("created_by_id")
  createdAt    DateTime         @default(now()) @map("created_at")

  // Relations
  tenant    Tenant    @relation("TenantOKRCheckIns", fields: [tenantId], references: [id], onDelete: Cascade)
  keyResult KeyResult @relation(fields: [keyResultId], references: [id], onDelete: Cascade)
  createdBy User      @relation("OKRCheckInCreator", fields: [createdById], references: [id])

  @@index([tenantId, keyResultId])
  @@index([tenantId, createdAt])
  @@map("okr_check_ins")
}

// 5. Initiative — Links a KeyResult to a Project or standalone action
model Initiative {
  id           String           @id @default(cuid())
  tenantId     String           @map("tenant_id")
  keyResultId  String           @map("key_result_id")
  objectiveId  String           @map("objective_id")
  projectId    String?          @map("project_id") // Cross-module FK → Projects
  title        String
  description  String?
  status       InitiativeStatus @default(TODO)
  priority     GovPriority      @default(MEDIUM)
  ownerId      String           @map("owner_id")
  dueDate      DateTime?        @map("due_date")
  completedAt  DateTime?        @map("completed_at")
  deletedAt    DateTime?        @map("deleted_at")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant    @relation("TenantInitiatives", fields: [tenantId], references: [id], onDelete: Cascade)
  keyResult KeyResult @relation(fields: [keyResultId], references: [id], onDelete: Cascade)
  objective Objective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  owner     User      @relation("InitiativeOwner", fields: [ownerId], references: [id])

  @@index([tenantId, keyResultId])
  @@index([tenantId, objectiveId])
  @@index([tenantId, status])
  @@map("initiatives")
}

// 6. Meeting — Structured meetings with agenda and tracking
model Meeting {
  id            String          @id @default(cuid())
  tenantId      String          @map("tenant_id")
  title         String
  description   String?
  type          MeetingType     @default(TEAM)
  status        MeetingStatus   @default(SCHEDULED)
  location      MeetingLocation @default(VIRTUAL)
  locationUrl   String?         @map("location_url") // Video call link
  scheduledAt   DateTime        @map("scheduled_at")
  startedAt     DateTime?       @map("started_at")
  endedAt       DateTime?       @map("ended_at")
  durationMin   Int?            @map("duration_min")
  boardId       String?         @map("board_id") // Optional: board meeting
  organizerId   String          @map("organizer_id")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  // Relations
  tenant      Tenant               @relation("TenantMeetings", fields: [tenantId], references: [id], onDelete: Cascade)
  organizer   User                 @relation("MeetingOrganizer", fields: [organizerId], references: [id])
  board       Board?               @relation(fields: [boardId], references: [id], onDelete: SetNull)
  agendaItems MeetingAgendaItem[]
  decisions   Decision[]
  actionItems ActionItem[]
  minutes     MeetingMinutes?
  attendees   MeetingAttendee[]

  @@index([tenantId, scheduledAt])
  @@index([tenantId, type])
  @@index([tenantId, boardId])
  @@map("meetings")
}

// 7. MeetingAttendee — Who attends a meeting
model MeetingAttendee {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  meetingId  String   @map("meeting_id")
  userId     String   @map("user_id")
  isRequired Boolean  @default(true) @map("is_required")
  attended   Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  tenant  Tenant  @relation("TenantMeetingAttendees", fields: [tenantId], references: [id], onDelete: Cascade)
  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User    @relation("MeetingAttendeeUser", fields: [userId], references: [id])

  @@unique([meetingId, userId])
  @@index([tenantId, meetingId])
  @@map("meeting_attendees")
}

// 8. MeetingAgendaItem — Agenda item with ordering
model MeetingAgendaItem {
  id          String         @id @default(cuid())
  tenantId    String         @map("tenant_id")
  meetingId   String         @map("meeting_id")
  title       String
  description String?
  type        AgendaItemType @default(DISCUSSION)
  position    Int            @default(0) // Order in agenda
  durationMin Int?           @map("duration_min")
  presenterId String?        @map("presenter_id")
  notes       String?        // Notes taken during meeting
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant  @relation("TenantAgendaItems", fields: [tenantId], references: [id], onDelete: Cascade)
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  presenter User?   @relation("AgendaItemPresenter", fields: [presenterId], references: [id])

  @@index([tenantId, meetingId])
  @@map("meeting_agenda_items")
}

// 9. Decision — Formal decisions made during meetings
model Decision {
  id           String           @id @default(cuid())
  tenantId     String           @map("tenant_id")
  meetingId    String?          @map("meeting_id") // Optional: standalone decisions
  title        String
  context      String?          // Background / what led to this decision
  description  String           // The decision itself
  type         DecisionType     @default(OPERATIONAL)
  outcome      DecisionOutcome? // Result if voted
  votesFor     Int?             @map("votes_for")
  votesAgainst Int?             @map("votes_against")
  abstentions  Int?
  impact       String?          // What changes as a result
  participants String[]         // User IDs who participated
  decidedAt    DateTime         @default(now()) @map("decided_at")
  createdById  String           @map("created_by_id")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant   @relation("TenantDecisions", fields: [tenantId], references: [id], onDelete: Cascade)
  meeting   Meeting? @relation(fields: [meetingId], references: [id], onDelete: SetNull)
  createdBy User     @relation("DecisionCreator", fields: [createdById], references: [id])

  @@index([tenantId, meetingId])
  @@index([tenantId, type])
  @@index([tenantId, decidedAt])
  @@map("decisions")
}

// 10. ActionItem — Tasks arising from meetings or decisions
model ActionItem {
  id          String           @id @default(cuid())
  tenantId    String           @map("tenant_id")
  meetingId   String?          @map("meeting_id")
  title       String
  description String?
  status      ActionItemStatus @default(OPEN)
  priority    GovPriority      @default(MEDIUM)
  assigneeId  String           @map("assignee_id")
  dueDate     DateTime?        @map("due_date")
  completedAt DateTime?        @map("completed_at")
  createdById String           @map("created_by_id")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant  @relation("TenantActionItems", fields: [tenantId], references: [id], onDelete: Cascade)
  meeting   Meeting? @relation(fields: [meetingId], references: [id], onDelete: SetNull)
  assignee  User    @relation("ActionItemAssignee", fields: [assigneeId], references: [id])
  createdBy User    @relation("ActionItemCreator", fields: [createdById], references: [id])

  @@index([tenantId, assigneeId])
  @@index([tenantId, status])
  @@index([tenantId, dueDate])
  @@map("action_items")
}

// 11. MeetingMinutes — Draft/approved minutes for a meeting (1:1 with Meeting)
model MeetingMinutes {
  id         String    @id @default(cuid())
  tenantId   String    @map("tenant_id")
  meetingId  String    @unique @map("meeting_id")
  content    String    // Rich text content
  summary    String?
  isApproved Boolean   @default(false) @map("is_approved")
  approvedAt DateTime? @map("approved_at")
  approvedBy String?   @map("approved_by")
  createdById String   @map("created_by_id")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant  @relation("TenantMeetingMinutes", fields: [tenantId], references: [id], onDelete: Cascade)
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  createdBy User    @relation("MeetingMinutesCreator", fields: [createdById], references: [id])

  @@index([tenantId])
  @@map("meeting_minutes")
}

// 12. Board — Governance body (board of directors, committee, advisory)
model Board {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  name        String
  description String?
  type        BoardType @default(BOARD)
  quorumMin   Int       @default(3) @map("quorum_min") // Minimum members for valid decisions
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  tenant   Tenant        @relation("TenantBoards", fields: [tenantId], references: [id], onDelete: Cascade)
  members  BoardMember[]
  meetings Meeting[]

  @@index([tenantId, type])
  @@map("boards")
}

// 13. BoardMember — Members of a governance board
model BoardMember {
  id        String    @id @default(cuid())
  tenantId  String    @map("tenant_id")
  boardId   String    @map("board_id")
  userId    String    @map("user_id")
  role      BoardRole @default(MEMBER)
  joinedAt  DateTime  @default(now()) @map("joined_at")
  leftAt    DateTime? @map("left_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  // Relations
  tenant Tenant @relation("TenantBoardMembers", fields: [tenantId], references: [id], onDelete: Cascade)
  board  Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user   User   @relation("BoardMemberUser", fields: [userId], references: [id])

  @@unique([boardId, userId])
  @@index([tenantId, boardId])
  @@map("board_members")
}

// 14. StrategicPillar — High-level strategic themes/pillars
model StrategicPillar {
  id          String           @id @default(cuid())
  tenantId    String           @map("tenant_id")
  title       String
  description String?
  horizon     StrategicHorizon @default(MID_TERM)
  color       String?          // Visual color for strategy maps
  position    Int              @default(0)
  isActive    Boolean          @default(true) @map("is_active")
  ownerId     String           @map("owner_id")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  // Relations
  tenant Tenant @relation("TenantStrategicPillars", fields: [tenantId], references: [id], onDelete: Cascade)
  owner  User   @relation("StrategicPillarOwner", fields: [ownerId], references: [id])

  @@index([tenantId, horizon])
  @@map("strategic_pillars")
}

// 15. MissionStatement — Company mission, vision, values
model MissionStatement {
  id        String   @id @default(cuid())
  tenantId  String   @unique @map("tenant_id") // One per tenant
  mission   String?  // Company mission
  vision    String?  // Company vision
  values    String[] // Core values
  purpose   String?  // Company purpose
  updatedById String @map("updated_by_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant @relation("TenantMissionStatement", fields: [tenantId], references: [id], onDelete: Cascade)
  updatedBy User   @relation("MissionStatementUpdater", fields: [updatedById], references: [id])

  @@map("mission_statements")
}

// [KAVEN_MODULE:GOVERNANCE END]

// ===========================
// ADMIN EXTEND MODULE
// ===========================
// Extends Kaven's base admin with groups, invites, webhooks,
// API keys, integrations. Multi-tenant isolated via tenantId.

// [KAVEN_MODULE:ADMIN_EXTEND BEGIN]

// ---------- Enums ----------

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED

  @@map("invite_status")
}

enum SyncStatus {
  IDLE
  SYNCING
  SUCCESS
  ERROR

  @@map("sync_status")
}

enum DeliveryStatus {
  PENDING
  DELIVERED
  FAILED
  RETRYING

  @@map("delivery_status")
}

// ---------- Models ----------

// 1. Group — user groups for bulk RBAC
model Group {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  name        String
  description String?
  color       String?  @default("#6B7280")
  isActive    Boolean  @default(true) @map("is_active")
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant      @relation("TenantGroups", fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User        @relation("GroupCreator", fields: [createdById], references: [id])
  members   GroupMember[]

  @@unique([tenantId, name])
  @@index([tenantId, isActive])
  @@map("groups")
}

// 2. GroupMember — group membership join table
model GroupMember {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  groupId   String   @map("group_id")
  userId    String   @map("user_id")
  addedById String   @map("added_by_id")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  tenant  Tenant @relation("TenantGroupMembers", fields: [tenantId], references: [id], onDelete: Cascade)
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user    User   @relation("GroupMemberUser", fields: [userId], references: [id], onDelete: Cascade)
  addedBy User   @relation("GroupMemberAddedBy", fields: [addedById], references: [id])

  @@unique([groupId, userId])
  @@index([tenantId, groupId])
  @@index([tenantId, userId])
  @@map("group_members")
}

// 3. IntegrationConfig — third-party integration settings
model IntegrationConfig {
  id           String     @id @default(cuid())
  tenantId     String     @map("tenant_id")
  provider     String     // e.g., "slack", "google_workspace", "zapier"
  displayName  String     @map("display_name")
  config       Json       @default("{}") // Encrypted config values
  syncStatus   SyncStatus @default(IDLE) @map("sync_status")
  lastSyncAt   DateTime?  @map("last_sync_at")
  lastError    String?    @map("last_error")
  isEnabled    Boolean    @default(true) @map("is_enabled")
  createdById  String     @map("created_by_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant @relation("TenantIntegrationConfigs", fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User   @relation("IntegrationConfigCreator", fields: [createdById], references: [id])

  @@unique([tenantId, provider])
  @@index([tenantId, isEnabled])
  @@map("integration_configs")
}

// 4. WebhookEndpoint — outbound webhook configuration
model WebhookEndpoint {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  url         String
  description String?
  secret      String   // Shared secret for HMAC signature
  events      String[] // e.g., ["user.created", "member.invited"]
  isActive    Boolean  @default(true) @map("is_active")
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  tenant     Tenant             @relation("TenantWebhookEndpoints", fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy  User               @relation("WebhookEndpointCreator", fields: [createdById], references: [id])
  deliveries WebhookDelivery[]

  @@index([tenantId, isActive])
  @@map("webhook_endpoints")
}

// 5. WebhookDelivery — webhook delivery log
model WebhookDelivery {
  id             String         @id @default(cuid())
  tenantId       String         @map("tenant_id")
  endpointId     String         @map("endpoint_id")
  event          String         // e.g., "user.created"
  payload        Json
  status         DeliveryStatus @default(PENDING)
  httpStatusCode Int?           @map("http_status_code")
  responseBody   String?        @map("response_body")
  attempts       Int            @default(0)
  lastAttemptAt  DateTime?      @map("last_attempt_at")
  completedAt    DateTime?      @map("completed_at")
  createdAt      DateTime       @default(now()) @map("created_at")

  // Relations
  tenant   Tenant          @relation("TenantWebhookDeliveries", fields: [tenantId], references: [id], onDelete: Cascade)
  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([tenantId, endpointId])
  @@index([tenantId, status])
  @@index([createdAt])
  @@map("webhook_deliveries")
}

// 6. ApiKey — tenant-scoped API keys
model ApiKey {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  name        String
  keyHash     String    @unique @map("key_hash") // SHA-256 hash
  keyPrefix   String    @map("key_prefix") // First 8 chars for identification
  permissions String[]  // Scoped permissions
  lastUsedAt  DateTime? @map("last_used_at")
  expiresAt   DateTime? @map("expires_at")
  revokedAt   DateTime? @map("revoked_at")
  createdById String    @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant @relation("TenantApiKeys", fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User   @relation("ApiKeyCreator", fields: [createdById], references: [id])

  @@index([tenantId])
  @@index([keyHash])
  @@index([expiresAt])
  @@map("api_keys")
}

// 7. Invite — member invitation with token
model Invite {
  id          String       @id @default(cuid())
  tenantId    String       @map("tenant_id")
  email       String
  role        String       @default("USER") // Role to assign on acceptance
  status      InviteStatus @default(PENDING)
  tokenHash   String       @unique @map("token_hash") // bcrypt hash of invite token
  message     String?      // Optional invitation message
  expiresAt   DateTime     @map("expires_at")
  acceptedAt  DateTime?    @map("accepted_at")
  revokedAt   DateTime?    @map("revoked_at")
  invitedById String       @map("invited_by_id")
  acceptedById String?     @map("accepted_by_id")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  // Relations
  tenant     Tenant @relation("TenantInvites2", fields: [tenantId], references: [id], onDelete: Cascade)
  invitedBy  User   @relation("InviteCreator", fields: [invitedById], references: [id])
  acceptedBy User?  @relation("InviteAcceptor", fields: [acceptedById], references: [id])

  @@index([tenantId, status])
  @@index([email])
  @@index([expiresAt])
  @@map("invites")
}

// [KAVEN_MODULE:ADMIN_EXTEND END]

// ===========================
// LEGAL MODULE
// ===========================
// Legal entity management with CNPJ validation, contract lifecycle
// with state machine, versioning, obligations, and renewal alerts.
// Multi-tenant isolated via tenantId.

// [KAVEN_MODULE:LEGAL BEGIN]

// ---------- Enums ----------

enum LegalContractStatus {
  DRAFT
  REVIEW
  PENDING_APPROVAL
  APPROVED
  SENT_FOR_SIGN
  SIGNED
  ACTIVE
  EXPIRED
  CANCELLED
  ARCHIVED

  @@map("legal_contract_status")
}

enum LegalEntityStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  CLOSED

  @@map("legal_entity_status")
}

enum ObligationStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  OVERDUE
  CANCELLED

  @@map("obligation_status")
}

enum SignerAuthMethod {
  EMAIL
  SMS
  WHATSAPP
  PIX
  BIOMETRIC
  ICP_BRASIL
  SIMPLE

  @@map("signer_auth_method")
}

// ---------- Models ----------

// 1. LegalEntity — company/person with CNPJ/CPF validation
model LegalEntity {
  id              String            @id @default(cuid())
  tenantId        String            @map("tenant_id")
  type            String            @default("PJ") // PJ or PF
  name            String            // Razao Social
  tradeName       String?           @map("trade_name") // Nome Fantasia
  document        String            // CNPJ or CPF
  documentType    String            @default("CNPJ") @map("document_type")
  status          LegalEntityStatus @default(ACTIVE)

  // Address
  street          String?
  number          String?
  complement      String?
  neighborhood    String?
  city            String?
  state           String?
  zipCode         String?           @map("zip_code")
  country         String            @default("BR")

  // Contact
  email           String?
  phone           String?
  website         String?

  // CNPJ-specific
  cnpjStatus      String?           @map("cnpj_status") // ATIVA, SUSPENSA, INAPTA, BAIXADA
  cnpjLastChecked DateTime?         @map("cnpj_last_checked")
  cnpjData        Json?             @map("cnpj_data") // Full API response cache

  // DPO fields (LGPD)
  dpoName         String?           @map("dpo_name")
  dpoEmail        String?           @map("dpo_email")
  dpoPhone        String?           @map("dpo_phone")
  dpoAppointedAt  DateTime?         @map("dpo_appointed_at")

  // Metadata
  notes           String?
  createdById     String            @map("created_by_id")
  deletedAt       DateTime?         @map("deleted_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  // Relations
  tenant          Tenant            @relation("TenantLegalEntities", fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy       User              @relation("LegalEntityCreator", fields: [createdById], references: [id])
  representatives LegalEntityRepresentative[]
  contractParties ContractParty[]

  @@unique([tenantId, document])
  @@index([tenantId, status])
  @@index([tenantId, documentType])
  @@index([document])
  @@map("legal_entities")
}

// 2. LegalEntityRepresentative — entity legal representatives
model LegalEntityRepresentative {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  entityId      String   @map("entity_id")
  name          String
  document      String?  // CPF
  email         String?
  phone         String?
  role          String   // e.g., "Socio", "Diretor", "Procurador"
  isPrimary     Boolean  @default(false) @map("is_primary")
  validFrom     DateTime? @map("valid_from")
  validUntil    DateTime? @map("valid_until")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  tenant Tenant      @relation("TenantLegalEntityReps", fields: [tenantId], references: [id], onDelete: Cascade)
  entity LegalEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([tenantId, entityId])
  @@map("legal_entity_representatives")
}

// 3. Contract — agreements with state machine lifecycle
model Contract {
  id              String         @id @default(cuid())
  tenantId        String         @map("tenant_id")
  title           String
  description     String?
  contractNumber  String?        @map("contract_number")
  type            String         // e.g., "SERVICE", "NDA", "EMPLOYMENT", "SUPPLY"
  status          LegalContractStatus @default(DRAFT)
  value           Float?
  currency        String         @default("BRL")

  // Dates
  effectiveDate   DateTime?      @map("effective_date")
  expiresAt       DateTime?      @map("expires_at")
  signedAt        DateTime?      @map("signed_at")
  cancelledAt     DateTime?      @map("cancelled_at")

  // Renewal
  autoRenew       Boolean        @default(false) @map("auto_renew")
  renewalPeriodDays Int?         @map("renewal_period_days")
  renewalNoticeDays Int          @default(30) @map("renewal_notice_days")
  lastRenewalAlert DateTime?     @map("last_renewal_alert")

  // Versioning
  version         Int            @default(1)
  parentId        String?        @map("parent_id") // Self-referential for version chain

  // Content
  content         String?        // Rich text or markdown
  summary         String?

  // Metadata
  tags            String[]
  metadata        Json?
  createdById     String         @map("created_by_id")
  deletedAt       DateTime?      @map("deleted_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  // Relations
  tenant          Tenant         @relation("TenantContracts", fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy       User           @relation("ContractCreator", fields: [createdById], references: [id])
  parent          Contract?      @relation("ContractVersions", fields: [parentId], references: [id])
  childVersions   Contract[]     @relation("ContractVersions")
  parties         ContractParty[]
  signers         ContractSigner[]
  obligations     ContractObligation[]
  attachments     ContractAttachment[]
  notes           ContractNote[]
  statusHistory   ContractStatusHistory[]

  @@unique([tenantId, contractNumber])
  @@index([tenantId, status])
  @@index([tenantId, type])
  @@index([expiresAt])
  @@index([parentId])
  @@map("contracts")
}

// 4. ContractParty — parties involved in contract
model ContractParty {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  contractId    String   @map("contract_id")
  entityId      String?  @map("entity_id") // FK to LegalEntity
  role          String   // "CONTRACTOR", "CONTRACTED", "WITNESS", "GUARANTOR"
  name          String   // Denormalized for display
  document      String?  // Denormalized CNPJ/CPF
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  tenant   Tenant       @relation("TenantContractParties", fields: [tenantId], references: [id], onDelete: Cascade)
  contract Contract     @relation(fields: [contractId], references: [id], onDelete: Cascade)
  entity   LegalEntity? @relation(fields: [entityId], references: [id], onDelete: SetNull)

  @@index([tenantId, contractId])
  @@map("contract_parties")
}

// 5. ContractSigner — designated signers with auth method
model ContractSigner {
  id           String          @id @default(cuid())
  tenantId     String          @map("tenant_id")
  contractId   String          @map("contract_id")
  name         String
  email        String
  phone        String?
  authMethod   SignerAuthMethod @default(EMAIL) @map("auth_method")
  signedAt     DateTime?       @map("signed_at")
  signOrder    Int             @default(0) @map("sign_order")
  signatureUrl String?         @map("signature_url")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  // Relations
  tenant   Tenant   @relation("TenantContractSigners", fields: [tenantId], references: [id], onDelete: Cascade)
  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([tenantId, contractId])
  @@map("contract_signers")
}

// 6. ContractObligation — tracked obligations with due dates
model ContractObligation {
  id           String           @id @default(cuid())
  tenantId     String           @map("tenant_id")
  contractId   String           @map("contract_id")
  title        String
  description  String?
  status       ObligationStatus @default(PENDING)
  dueDate      DateTime?        @map("due_date")
  completedAt  DateTime?        @map("completed_at")
  ownerId      String?          @map("owner_id")
  value        Float?
  currency     String           @default("BRL")
  isRecurring  Boolean          @default(false) @map("is_recurring")
  recurringDays Int?            @map("recurring_days")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  // Relations
  tenant   Tenant   @relation("TenantContractObligations", fields: [tenantId], references: [id], onDelete: Cascade)
  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  owner    User?    @relation("ObligationOwner", fields: [ownerId], references: [id])

  @@index([tenantId, contractId])
  @@index([tenantId, status])
  @@index([dueDate])
  @@map("contract_obligations")
}

// 7. ContractAttachment — contract-linked files
model ContractAttachment {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  contractId  String   @map("contract_id")
  fileName    String   @map("file_name")
  fileUrl     String   @map("file_url")
  fileSize    Int?     @map("file_size") // bytes
  mimeType    String?  @map("mime_type")
  uploadedById String  @map("uploaded_by_id")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  tenant     Tenant   @relation("TenantContractAttachments", fields: [tenantId], references: [id], onDelete: Cascade)
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  uploadedBy User     @relation("ContractAttachmentUploader", fields: [uploadedById], references: [id])

  @@index([tenantId, contractId])
  @@map("contract_attachments")
}

// 8. ContractNote — internal notes on contracts
model ContractNote {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  contractId  String   @map("contract_id")
  content     String
  isInternal  Boolean  @default(true) @map("is_internal")
  authorId    String   @map("author_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  tenant   Tenant   @relation("TenantContractNotes", fields: [tenantId], references: [id], onDelete: Cascade)
  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  author   User     @relation("ContractNoteAuthor", fields: [authorId], references: [id])

  @@index([tenantId, contractId])
  @@map("contract_notes")
}

// 9. ContractStatusHistory — immutable state transition audit trail
model ContractStatusHistory {
  id          String         @id @default(cuid())
  tenantId    String         @map("tenant_id")
  contractId  String         @map("contract_id")
  fromStatus  LegalContractStatus @map("from_status")
  toStatus    LegalContractStatus @map("to_status")
  reason      String?
  changedById String         @map("changed_by_id")
  metadata    Json?
  createdAt   DateTime       @default(now()) @map("created_at")

  // Relations
  tenant    Tenant   @relation("TenantContractStatusHistories", fields: [tenantId], references: [id], onDelete: Cascade)
  contract  Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  changedBy User     @relation("ContractStatusChanger", fields: [changedById], references: [id])

  @@index([tenantId, contractId])
  @@index([createdAt])
  @@map("contract_status_history")
}

// [KAVEN_MODULE:LEGAL END]

// ===========================
// CONTENT OPERATIONS MODULE
// ===========================
// Editorial pipeline: calendars, briefs, content pieces, reviews, assets,
// channels, and performance tracking. Multi-tenant isolated via tenantId.

// [KAVEN_MODULE:CONTENT_OPS BEGIN]

// ---------- Enums ----------

enum ContentStatus {
  IDEA
  BRIEF
  IN_CREATION
  IN_REVIEW
  SCHEDULED
  PUBLISHED
  ARCHIVED
  CANCELLED

  @@map("content_status")
}

enum ContentType {
  ARTICLE
  BLOG_POST
  SOCIAL_POST
  VIDEO
  PODCAST
  NEWSLETTER
  INFOGRAPHIC
  EBOOK
  CASE_STUDY
  WEBINAR
  OTHER

  @@map("content_type")
}

enum AssetType {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  SPREADSHEET
  PRESENTATION
  ARCHIVE
  OTHER

  @@map("asset_type")
}

enum ReviewDecision {
  APPROVED
  NEEDS_REVISION
  REJECTED

  @@map("review_decision")
}

enum ChannelPlatform {
  INSTAGRAM
  FACEBOOK
  TWITTER
  LINKEDIN
  YOUTUBE
  TIKTOK
  PINTEREST
  BLOG
  NEWSLETTER
  PODCAST
  WEBSITE
  OTHER

  @@map("channel_platform")
}

enum PerformanceMetricType {
  VIEWS
  IMPRESSIONS
  REACH
  ENGAGEMENT_RATE
  LIKES
  COMMENTS
  SHARES
  SAVES
  CLICKS
  CTR
  WATCH_TIME
  SUBSCRIBERS_GAINED
  OPEN_RATE
  CLICK_RATE
  BOUNCE_RATE
  CONVERSIONS

  @@map("performance_metric_type")
}

// ---------- Models ----------

// 1. ContentCalendar — Editorial calendar container
model ContentCalendar {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  name          String
  description   String?
  color         String?  // Hex color for UI
  isDefault     Boolean  @default(false) @map("is_default")
  leadTimeDays  Int      @default(7) @map("lead_time_days")
  approvalChain Json?    @map("approval_chain") // JSON array: [{userId, order}]
  clientId      String?  @map("client_id") // Optional link to CRM contact
  isActive      Boolean  @default(true) @map("is_active")
  createdById   String   @map("created_by_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant @relation("TenantContentCalendars", fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User   @relation("ContentCalendarCreator", fields: [createdById], references: [id])
  pieces    ContentPiece[]

  @@index([tenantId, isActive])
  @@index([tenantId, clientId])
  @@map("content_calendars")
}

// 2. ContentBrief — Strategic brief with objectives and KPIs
model ContentBrief {
  id                String      @id @default(cuid())
  tenantId          String      @map("tenant_id")
  title             String
  contentType       ContentType @map("content_type")
  objective         String
  targetAudience    String?     @map("target_audience")
  toneOfVoice       String?     @map("tone_of_voice")
  primaryKeyword    String?     @map("primary_keyword")
  secondaryKeywords String[]    @map("secondary_keywords")
  headline          String?
  outline           Json?       // Structured outline (JSON)
  references        Json?       // Reference links/docs (JSON)
  cta               String?     // Call to action
  kpiTargets        Json?       @map("kpi_targets") // {metric: target} pairs
  wordCountTarget   Int?        @map("word_count_target")
  durationTarget    Int?        @map("duration_target") // seconds for video/audio
  notes             String?
  createdById       String      @map("created_by_id")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant @relation("TenantContentBriefs", fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User   @relation("ContentBriefCreator", fields: [createdById], references: [id])
  pieces    ContentPiece[]

  @@index([tenantId, contentType])
  @@index([tenantId, createdById])
  @@map("content_briefs")
}

// 3. ContentPiece — Individual content item with state machine
model ContentPiece {
  id            String        @id @default(cuid())
  tenantId      String        @map("tenant_id")
  calendarId    String        @map("calendar_id")
  briefId       String?       @map("brief_id")
  parentId      String?       @map("parent_id") // For repurposed/derived content
  title         String
  body          String?       // Rich text content
  contentType   ContentType   @map("content_type")
  status        ContentStatus @default(IDEA)
  scheduledAt   DateTime?     @map("scheduled_at")
  publishedAt   DateTime?     @map("published_at")
  embargo       DateTime?     // Do not publish before this date
  assignedToId  String?       @map("assigned_to_id")
  channelId     String?       @map("channel_id")
  tags          String[]
  metadata      Json?         // Flexible metadata (JSON)
  createdById   String        @map("created_by_id")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  // Relations
  tenant     Tenant            @relation("TenantContentPieces", fields: [tenantId], references: [id], onDelete: Cascade)
  calendar   ContentCalendar   @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  brief      ContentBrief?     @relation(fields: [briefId], references: [id], onDelete: SetNull)
  parent     ContentPiece?     @relation("ContentPieceRepurpose", fields: [parentId], references: [id], onDelete: SetNull)
  children   ContentPiece[]    @relation("ContentPieceRepurpose")
  assignedTo User?             @relation("ContentPieceAssignee", fields: [assignedToId], references: [id])
  channel    ContentChannel?   @relation(fields: [channelId], references: [id], onDelete: SetNull)
  createdBy  User              @relation("ContentPieceCreator", fields: [createdById], references: [id])
  reviews    ContentReview[]
  assets     ContentAsset[]
  performance ContentPerformance[]
  statusHistory ContentStatusHistory[]

  @@index([tenantId, status])
  @@index([tenantId, calendarId])
  @@index([tenantId, contentType])
  @@index([tenantId, scheduledAt])
  @@index([tenantId, assignedToId])
  @@map("content_pieces")
}

// 4. ContentReview — Multi-level review/approval entries
model ContentReview {
  id          String         @id @default(cuid())
  tenantId    String         @map("tenant_id")
  pieceId     String         @map("piece_id")
  reviewerId  String         @map("reviewer_id")
  decision    ReviewDecision
  comments    String?
  round       Int            @default(1) // Review round number
  reviewOrder Int            @default(0) @map("review_order") // Position in approval chain
  createdAt   DateTime       @default(now()) @map("created_at")

  // Relations
  tenant   Tenant       @relation("TenantContentReviews", fields: [tenantId], references: [id], onDelete: Cascade)
  piece    ContentPiece @relation(fields: [pieceId], references: [id], onDelete: Cascade)
  reviewer User         @relation("ContentReviewer", fields: [reviewerId], references: [id])

  @@index([tenantId, pieceId])
  @@index([tenantId, reviewerId])
  @@map("content_reviews")
}

// 5. ContentAsset — Media files linked to content
model ContentAsset {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  pieceId     String    @map("piece_id")
  fileName    String    @map("file_name")
  fileSize    Int       @map("file_size") // bytes
  mimeType    String    @map("mime_type")
  assetType   AssetType @map("asset_type")
  storagePath String    @map("storage_path")
  width       Int?      // pixels, for images/video
  height      Int?      // pixels, for images/video
  duration    Int?      // seconds, for video/audio
  metadata    Json?     // Extra metadata (JSON)
  uploadedById String   @map("uploaded_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")

  // Relations
  tenant     Tenant       @relation("TenantContentAssets", fields: [tenantId], references: [id], onDelete: Cascade)
  piece      ContentPiece @relation(fields: [pieceId], references: [id], onDelete: Cascade)
  uploadedBy User         @relation("ContentAssetUploader", fields: [uploadedById], references: [id])

  @@index([tenantId, pieceId])
  @@index([tenantId, assetType])
  @@map("content_assets")
}

// 6. ContentChannel — Publication channel
model ContentChannel {
  id             String          @id @default(cuid())
  tenantId       String          @map("tenant_id")
  name           String
  platform       ChannelPlatform
  accountName    String?         @map("account_name")
  accountUrl     String?         @map("account_url")
  accessConfig   Json?           @map("access_config") // OAuth scaffold (JSON)
  isActive       Boolean         @default(true) @map("is_active")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  // Relations
  tenant      Tenant         @relation("TenantContentChannels", fields: [tenantId], references: [id], onDelete: Cascade)
  pieces      ContentPiece[]
  performance ContentPerformance[]

  @@unique([tenantId, platform, accountName])
  @@index([tenantId, isActive])
  @@map("content_channels")
}

// 7. ContentPerformance — Performance metrics per piece/channel
model ContentPerformance {
  id          String                @id @default(cuid())
  tenantId    String                @map("tenant_id")
  pieceId     String                @map("piece_id")
  channelId   String?               @map("channel_id")
  metricType  PerformanceMetricType @map("metric_type")
  value       Float
  periodStart DateTime              @map("period_start")
  periodEnd   DateTime              @map("period_end")
  recordedAt  DateTime              @default(now()) @map("recorded_at")

  // Relations
  tenant  Tenant          @relation("TenantContentPerformance", fields: [tenantId], references: [id], onDelete: Cascade)
  piece   ContentPiece    @relation(fields: [pieceId], references: [id], onDelete: Cascade)
  channel ContentChannel? @relation(fields: [channelId], references: [id], onDelete: SetNull)

  @@index([tenantId, pieceId])
  @@index([tenantId, metricType])
  @@index([tenantId, periodStart, periodEnd])
  @@map("content_performance")
}

// 8. ContentStatusHistory — Immutable status audit trail
model ContentStatusHistory {
  id        String        @id @default(cuid())
  tenantId  String        @map("tenant_id")
  pieceId   String        @map("piece_id")
  fromStatus ContentStatus? @map("from_status")
  toStatus  ContentStatus @map("to_status")
  changedById String      @map("changed_by_id")
  reason    String?
  createdAt DateTime      @default(now()) @map("created_at")

  // Relations
  tenant    Tenant       @relation("TenantContentStatusHistories", fields: [tenantId], references: [id], onDelete: Cascade)
  piece     ContentPiece @relation(fields: [pieceId], references: [id], onDelete: Cascade)
  changedBy User         @relation("ContentStatusChanger", fields: [changedById], references: [id])

  @@index([tenantId, pieceId])
  @@map("content_status_histories")
}

// [KAVEN_MODULE:CONTENT_OPS END]

// ===========================
// COMPLIANCE & SECURITY MODULE
// ===========================
// Compliance checklists, incident response, insurance tracking,
// and security assessments. Multi-tenant isolated via tenantId.

// [KAVEN_MODULE:COMPLIANCE_SECURITY BEGIN]

// ---------- Enums ----------

enum ComplianceFrameworkType {
  LGPD
  SOC2
  ISO27001
  GDPR
  HIPAA
  PCI_DSS
  CUSTOM

  @@map("compliance_framework_type")
}

enum ComplianceItemStatus {
  NOT_STARTED
  IN_PROGRESS
  IMPLEMENTED
  VERIFIED
  NON_COMPLIANT
  NOT_APPLICABLE

  @@map("compliance_item_status")
}

enum IncidentSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW

  @@map("incident_severity")
}

enum IncidentStatus {
  OPEN
  INVESTIGATING
  MITIGATING
  RESOLVED
  CLOSED
  POST_MORTEM

  @@map("incident_status")
}

enum IncidentTimelineType {
  DETECTION
  NOTIFICATION
  ESCALATION
  ACTION_TAKEN
  MITIGATION
  RESOLUTION
  COMMUNICATION
  POST_MORTEM

  @@map("incident_timeline_type")
}

enum InsurancePolicyType {
  CYBER
  GENERAL_LIABILITY
  PROFESSIONAL_LIABILITY
  DIRECTORS_OFFICERS
  PROPERTY
  WORKERS_COMP
  OTHER

  @@map("insurance_policy_type")
}

enum InsurancePolicyStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PENDING_RENEWAL

  @@map("insurance_policy_status")
}

enum AssessmentType {
  VULNERABILITY_SCAN
  PENETRATION_TEST
  CODE_REVIEW
  INFRASTRUCTURE_AUDIT
  POLICY_REVIEW
  VENDOR_ASSESSMENT
  CUSTOM

  @@map("assessment_type")
}

enum AssessmentStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED

  @@map("assessment_status")
}

enum RiskLevel {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFORMATIONAL

  @@map("risk_level")
}

// ---------- Models ----------

// 1. ComplianceChecklist — Checklist for a specific framework
model ComplianceChecklist {
  id            String                  @id @default(cuid())
  tenantId      String                  @map("tenant_id")
  name          String
  description   String?
  frameworkType ComplianceFrameworkType  @map("framework_type")
  version       String                  @default("1.0")
  isTemplate    Boolean                 @default(false) @map("is_template")
  dueDate       DateTime?               @map("due_date")
  completedAt   DateTime?               @map("completed_at")
  score         Float?                  // Overall compliance score (0-100)
  createdById   String                  @map("created_by_id")
  createdAt     DateTime                @default(now()) @map("created_at")
  updatedAt     DateTime                @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant           @relation("TenantComplianceChecklists", fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User             @relation("ComplianceChecklistCreator", fields: [createdById], references: [id])
  items     ComplianceItem[]
  reports   ComplianceReport[]

  @@index([tenantId, frameworkType])
  @@index([tenantId, isTemplate])
  @@map("compliance_checklists")
}

// 2. ComplianceItem — Individual control/requirement
model ComplianceItem {
  id            String               @id @default(cuid())
  tenantId      String               @map("tenant_id")
  checklistId   String               @map("checklist_id")
  controlRef    String               @map("control_ref") // e.g., "A.5.1" for ISO27001
  title         String
  description   String?
  category      String?              // Logical grouping
  status        ComplianceItemStatus @default(NOT_STARTED)
  weight        Float                @default(1.0) // Weight for scoring
  evidence      Json?                // Evidence references (JSON)
  notes         String?
  assigneeId    String?              @map("assignee_id")
  verifiedAt    DateTime?            @map("verified_at")
  verifiedById  String?              @map("verified_by_id")
  dueDate       DateTime?            @map("due_date")
  order         Int                  @default(0)
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")

  // Relations
  tenant     Tenant              @relation("TenantComplianceItems", fields: [tenantId], references: [id], onDelete: Cascade)
  checklist  ComplianceChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  assignee   User?               @relation("ComplianceItemAssignee", fields: [assigneeId], references: [id])
  verifiedBy User?               @relation("ComplianceItemVerifier", fields: [verifiedById], references: [id])

  @@index([tenantId, checklistId])
  @@index([tenantId, status])
  @@index([tenantId, assigneeId])
  @@map("compliance_items")
}

// 3. ComplianceReport — Generated compliance report
model ComplianceReport {
  id            String                 @id @default(cuid())
  tenantId      String                 @map("tenant_id")
  checklistId   String                 @map("checklist_id")
  title         String
  summary       String?
  overallScore  Float                  @map("overall_score") // 0-100
  totalControls Int                    @map("total_controls")
  compliantCount Int                   @map("compliant_count")
  nonCompliantCount Int                @map("non_compliant_count")
  notApplicableCount Int               @map("not_applicable_count")
  findings      Json?                  // Detailed findings (JSON)
  recommendations Json?               // Recommendations (JSON)
  generatedById String                 @map("generated_by_id")
  createdAt     DateTime               @default(now()) @map("created_at")

  // Relations
  tenant      Tenant              @relation("TenantComplianceReports", fields: [tenantId], references: [id], onDelete: Cascade)
  checklist   ComplianceChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  generatedBy User                @relation("ComplianceReportGenerator", fields: [generatedById], references: [id])

  @@index([tenantId, checklistId])
  @@index([tenantId, createdAt])
  @@map("compliance_reports")
}

// 4. IncidentResponse — Security incident tracking
model IncidentResponse {
  id            String           @id @default(cuid())
  tenantId      String           @map("tenant_id")
  title         String
  description   String
  severity      IncidentSeverity
  status        IncidentStatus   @default(OPEN)
  category      String?          // e.g., "data_breach", "unauthorized_access"
  affectedSystems String[]       @map("affected_systems")
  impactDescription String?      @map("impact_description")
  rootCause     String?          @map("root_cause")
  resolution    String?
  lessonsLearned String?         @map("lessons_learned")
  detectedAt    DateTime         @map("detected_at")
  acknowledgedAt DateTime?       @map("acknowledged_at")
  resolvedAt    DateTime?        @map("resolved_at")
  closedAt      DateTime?        @map("closed_at")
  slaDeadline   DateTime?        @map("sla_deadline") // Response SLA
  reportedById  String           @map("reported_by_id")
  assignedToId  String?          @map("assigned_to_id")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  // Relations
  tenant     Tenant             @relation("TenantIncidentResponses", fields: [tenantId], references: [id], onDelete: Cascade)
  reportedBy User               @relation("IncidentReporter", fields: [reportedById], references: [id])
  assignedTo User?              @relation("IncidentAssignee", fields: [assignedToId], references: [id])
  timeline   IncidentTimeline[]

  @@index([tenantId, severity])
  @@index([tenantId, status])
  @@index([tenantId, detectedAt])
  @@map("incident_responses")
}

// 5. IncidentTimeline — Timeline entries for incident response
model IncidentTimeline {
  id          String               @id @default(cuid())
  tenantId    String               @map("tenant_id")
  incidentId  String               @map("incident_id")
  entryType   IncidentTimelineType @map("entry_type")
  description String
  metadata    Json?                // Extra details (JSON)
  createdById String               @map("created_by_id")
  createdAt   DateTime             @default(now()) @map("created_at")

  // Relations
  tenant    Tenant           @relation("TenantIncidentTimelines", fields: [tenantId], references: [id], onDelete: Cascade)
  incident  IncidentResponse @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  createdBy User             @relation("IncidentTimelineCreator", fields: [createdById], references: [id])

  @@index([tenantId, incidentId])
  @@map("incident_timelines")
}

// 6. InsurancePolicy — Insurance policy tracking
model InsurancePolicy {
  id            String                @id @default(cuid())
  tenantId      String                @map("tenant_id")
  policyNumber  String                @map("policy_number")
  policyType    InsurancePolicyType   @map("policy_type")
  provider      String
  status        InsurancePolicyStatus @default(ACTIVE)
  coverageAmount Float                @map("coverage_amount")
  deductible    Float?
  premiumAmount Float                 @map("premium_amount")
  premiumFrequency String             @map("premium_frequency") // monthly, annual
  startDate     DateTime              @map("start_date")
  endDate       DateTime              @map("end_date")
  renewalDate   DateTime?             @map("renewal_date")
  coverageDetails Json?               @map("coverage_details") // Detailed coverage (JSON)
  contactName   String?               @map("contact_name")
  contactEmail  String?               @map("contact_email")
  contactPhone  String?               @map("contact_phone")
  notes         String?
  createdById   String                @map("created_by_id")
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant @relation("TenantInsurancePolicies", fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User   @relation("InsurancePolicyCreator", fields: [createdById], references: [id])

  @@unique([tenantId, policyNumber])
  @@index([tenantId, policyType])
  @@index([tenantId, status])
  @@index([tenantId, endDate])
  @@map("insurance_policies")
}

// 7. SecurityAssessment — Security assessment/audit tracking
model SecurityAssessment {
  id              String           @id @default(cuid())
  tenantId        String           @map("tenant_id")
  title           String
  description     String?
  assessmentType  AssessmentType   @map("assessment_type")
  status          AssessmentStatus @default(PLANNED)
  riskLevel       RiskLevel?       @map("risk_level")
  scope           String?          // What is being assessed
  methodology     String?          // Assessment methodology
  findings        Json?            // Assessment findings (JSON)
  recommendations Json?            // Recommendations (JSON)
  findingsCount   Int              @default(0) @map("findings_count")
  criticalCount   Int              @default(0) @map("critical_count")
  highCount       Int              @default(0) @map("high_count")
  mediumCount     Int              @default(0) @map("medium_count")
  lowCount        Int              @default(0) @map("low_count")
  scheduledDate   DateTime?        @map("scheduled_date")
  completedDate   DateTime?        @map("completed_date")
  nextAssessment  DateTime?        @map("next_assessment")
  assessorName    String?          @map("assessor_name")
  assessorOrg     String?          @map("assessor_org")
  createdById     String           @map("created_by_id")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant @relation("TenantSecurityAssessments", fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User   @relation("SecurityAssessmentCreator", fields: [createdById], references: [id])

  @@index([tenantId, assessmentType])
  @@index([tenantId, status])
  @@index([tenantId, riskLevel])
  @@map("security_assessments")
}

// [KAVEN_MODULE:COMPLIANCE_SECURITY END]

// ===========================
// ADS MANAGEMENT MODULE
// ===========================
// Cross-platform ad operations: campaigns, ad sets, ads, creatives,
// metrics, rules, attribution. Multi-tenant isolated via tenantId.
// Adapter pattern: Meta, Google, TikTok, LinkedIn abstracted behind AdPlatformAdapter.

// [KAVEN_MODULE:ADS_MANAGEMENT BEGIN]

// ---------- Enums ----------

enum AdPlatform {
  META
  GOOGLE
  TIKTOK
  LINKEDIN

  @@map("ad_platform")
}

enum AdStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
  DELETED
  ERROR

  @@map("ad_status")
}

enum CampaignObjective {
  AWARENESS
  TRAFFIC
  ENGAGEMENT
  LEADS
  APP_PROMOTION
  SALES
  CONVERSIONS

  @@map("campaign_objective")
}

enum RuleConditionType {
  CPA_ABOVE
  CPA_BELOW
  ROAS_ABOVE
  ROAS_BELOW
  CTR_ABOVE
  CTR_BELOW
  SPEND_ABOVE
  SPEND_BELOW
  IMPRESSIONS_ABOVE
  CLICKS_BELOW
  CUSTOM

  @@map("rule_condition_type")
}

enum RuleActionType {
  PAUSE
  ENABLE
  INCREASE_BUDGET
  DECREASE_BUDGET
  SEND_ALERT
  CUSTOM

  @@map("rule_action_type")
}

enum AttributionModel {
  FIRST_TOUCH
  LAST_TOUCH
  LINEAR
  TIME_DECAY
  DATA_DRIVEN

  @@map("attribution_model")
}

// ---------- Models ----------

// 1. AdAccount — connected ad platform account
model AdAccount {
  id              String      @id @default(cuid())
  tenantId        String      @map("tenant_id")
  platform        AdPlatform
  accountName     String      @map("account_name")
  externalId      String      @map("external_id") // Platform account ID
  accessToken     String?     @map("access_token") // Encrypted OAuth token
  refreshToken    String?     @map("refresh_token") // Encrypted refresh token
  tokenExpiresAt  DateTime?   @map("token_expires_at")
  currency        String      @default("USD") // Account currency
  timezone        String      @default("UTC") // Account timezone
  isActive        Boolean     @default(true) @map("is_active")
  lastSyncAt      DateTime?   @map("last_sync_at")
  syncError       String?     @map("sync_error")
  metadata        Json?       // Platform-specific metadata
  createdById     String      @map("created_by_id")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  // Relations
  tenant     Tenant       @relation("TenantAdAccounts", fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy  User         @relation("AdAccountCreator", fields: [createdById], references: [id])
  campaigns  AdCampaign[]
  rules      AdRule[]
  metrics    AdsMetric[]

  @@unique([tenantId, platform, externalId])
  @@index([tenantId, platform])
  @@index([tenantId, isActive])
  @@map("ad_accounts")
}

// 2. AdCampaign — campaign from any platform
model AdCampaign {
  id              String             @id @default(cuid())
  tenantId        String             @map("tenant_id")
  accountId       String             @map("account_id")
  externalId      String?            @map("external_id") // Platform campaign ID
  name            String
  objective       CampaignObjective?
  status          AdStatus           @default(DRAFT)
  dailyBudget     Decimal?           @map("daily_budget") @db.Decimal(12, 2)
  totalBudget     Decimal?           @map("total_budget") @db.Decimal(12, 2)
  startDate       DateTime?          @map("start_date")
  endDate         DateTime?          @map("end_date")
  targetAudience  Json?              @map("target_audience") // Audience targeting config
  metadata        Json?              // Platform-specific fields
  createdById     String             @map("created_by_id")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant    @relation("TenantAdCampaigns", fields: [tenantId], references: [id], onDelete: Cascade)
  account   AdAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdBy User      @relation("AdCampaignCreator", fields: [createdById], references: [id])
  adSets    AdSet[]
  metrics   AdsMetric[]
  rules     AdRule[]

  @@index([tenantId, accountId])
  @@index([tenantId, status])
  @@index([tenantId, objective])
  @@map("ad_campaigns")
}

// 3. AdSet — ad set / ad group
model AdSet {
  id             String    @id @default(cuid())
  tenantId       String    @map("tenant_id")
  campaignId     String    @map("campaign_id")
  externalId     String?   @map("external_id")
  name           String
  status         AdStatus  @default(DRAFT)
  dailyBudget    Decimal?  @map("daily_budget") @db.Decimal(12, 2)
  bidAmount      Decimal?  @map("bid_amount") @db.Decimal(12, 4)
  bidStrategy    String?   @map("bid_strategy")
  targeting      Json?     // Detailed targeting config
  placements     Json?     // Placement config (feed, stories, reels, etc.)
  schedule       Json?     // Scheduling config
  metadata       Json?     // Platform-specific fields
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // Relations
  tenant   Tenant     @relation("TenantAdSets", fields: [tenantId], references: [id], onDelete: Cascade)
  campaign AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  ads      Ad[]

  @@index([tenantId, campaignId])
  @@index([tenantId, status])
  @@map("ad_sets")
}

// 4. Ad — individual ad
model Ad {
  id            String    @id @default(cuid())
  tenantId      String    @map("tenant_id")
  adSetId       String    @map("ad_set_id")
  creativeId    String?   @map("creative_id")
  externalId    String?   @map("external_id")
  name          String
  status        AdStatus  @default(DRAFT)
  headline      String?
  description   String?
  callToAction  String?   @map("call_to_action")
  destinationUrl String?  @map("destination_url")
  metadata      Json?     // Platform-specific fields
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  tenant   Tenant    @relation("TenantAds", fields: [tenantId], references: [id], onDelete: Cascade)
  adSet    AdSet     @relation(fields: [adSetId], references: [id], onDelete: Cascade)
  creative Creative? @relation(fields: [creativeId], references: [id], onDelete: SetNull)
  metrics  AdsMetric[]

  @@index([tenantId, adSetId])
  @@index([tenantId, status])
  @@map("ads")
}

// 5. Creative — creative asset in library
model Creative {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  name            String
  type            String    // image, video, carousel, stories
  fileUrl         String?   @map("file_url")
  thumbnailUrl    String?   @map("thumbnail_url")
  width           Int?
  height          Int?
  durationMs      Int?      @map("duration_ms") // For video
  fileSize        Int?      @map("file_size") // Bytes
  mimeType        String?   @map("mime_type")
  tags            String[]  // Organizational tags
  metadata        Json?     // Extra metadata
  createdById     String    @map("created_by_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant             @relation("TenantCreatives", fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User               @relation("CreativeCreator", fields: [createdById], references: [id])
  ads       Ad[]
  variants  CreativeVariant[]
  performance CreativePerformance[]

  @@index([tenantId, type])
  @@index([tenantId, createdById])
  @@map("creatives")
}

// 6. CreativeVariant — A/B creative variants
model CreativeVariant {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  creativeId  String    @map("creative_id")
  name        String    // e.g., "Version A", "Version B"
  fileUrl     String?   @map("file_url")
  headline    String?
  description String?
  callToAction String?  @map("call_to_action")
  metadata    Json?
  isControl   Boolean   @default(false) @map("is_control") // Is this the control variant?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  tenant   Tenant   @relation("TenantCreativeVariants", fields: [tenantId], references: [id], onDelete: Cascade)
  creative Creative @relation(fields: [creativeId], references: [id], onDelete: Cascade)

  @@index([tenantId, creativeId])
  @@map("creative_variants")
}

// 7. CreativePerformance — per-creative metrics
model CreativePerformance {
  id            String    @id @default(cuid())
  tenantId      String    @map("tenant_id")
  creativeId    String    @map("creative_id")
  platform      AdPlatform
  impressions   Int       @default(0)
  clicks        Int       @default(0)
  conversions   Int       @default(0)
  spend         Decimal   @default(0) @db.Decimal(12, 2)
  ctr           Decimal?  @db.Decimal(8, 4) // Click-through rate
  cpa           Decimal?  @db.Decimal(12, 2) // Cost per acquisition
  roas          Decimal?  @db.Decimal(8, 2)  // Return on ad spend
  score         Decimal?  @db.Decimal(5, 2)  // AI-generated performance score
  scoreDetails  Json?     @map("score_details") // AI scoring breakdown
  periodStart   DateTime  @map("period_start")
  periodEnd     DateTime  @map("period_end")
  createdAt     DateTime  @default(now()) @map("created_at")

  // Relations
  tenant   Tenant   @relation("TenantCreativePerformance", fields: [tenantId], references: [id], onDelete: Cascade)
  creative Creative @relation(fields: [creativeId], references: [id], onDelete: Cascade)

  @@index([tenantId, creativeId, periodStart])
  @@index([tenantId, platform])
  @@map("creative_performance")
}

// 8. AdsMetric — normalized daily metrics
model AdsMetric {
  id            String      @id @default(cuid())
  tenantId      String      @map("tenant_id")
  accountId     String      @map("account_id")
  campaignId    String?     @map("campaign_id")
  adId          String?     @map("ad_id")
  platform      AdPlatform
  date          DateTime    @db.Date
  impressions   Int         @default(0)
  clicks        Int         @default(0)
  conversions   Int         @default(0)
  spend         Decimal     @default(0) @db.Decimal(12, 2)
  revenue       Decimal     @default(0) @db.Decimal(12, 2)
  reach         Int         @default(0)
  cpm           Decimal?    @db.Decimal(12, 4) // Cost per mille
  cpc           Decimal?    @db.Decimal(12, 4) // Cost per click
  ctr           Decimal?    @db.Decimal(8, 4)  // Click-through rate
  cpa           Decimal?    @db.Decimal(12, 2) // Cost per acquisition
  roas          Decimal?    @db.Decimal(8, 2)  // Return on ad spend
  videoViews    Int?        @default(0) @map("video_views")
  engagements   Int?        @default(0)
  metadata      Json?       // Platform-specific extra metrics
  createdAt     DateTime    @default(now()) @map("created_at")

  // Relations
  tenant   Tenant      @relation("TenantAdsMetrics", fields: [tenantId], references: [id], onDelete: Cascade)
  account  AdAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  campaign AdCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  ad       Ad?         @relation(fields: [adId], references: [id], onDelete: SetNull)

  @@index([tenantId, date])
  @@index([tenantId, accountId, date])
  @@index([tenantId, campaignId, date])
  @@index([tenantId, platform, date])
  @@map("ads_metrics")
}

// 9. AdRule — ECA automation rule for ads
model AdRule {
  id            String          @id @default(cuid())
  tenantId      String          @map("tenant_id")
  accountId     String?         @map("account_id")
  campaignId    String?         @map("campaign_id")
  name          String
  description   String?
  isActive      Boolean         @default(true) @map("is_active")
  conditionType RuleConditionType @map("condition_type")
  conditionValue Decimal        @map("condition_value") @db.Decimal(12, 4)
  actionType    RuleActionType  @map("action_type")
  actionValue   Json?           @map("action_value") // e.g., { percentage: 20 } for budget increase
  frequency     String          @default("HOURLY") // HOURLY, DAILY, WEEKLY
  lastEvaluatedAt DateTime?     @map("last_evaluated_at")
  createdById   String          @map("created_by_id")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant      @relation("TenantAdRules", fields: [tenantId], references: [id], onDelete: Cascade)
  account   AdAccount?  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  campaign  AdCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  createdBy User        @relation("AdRuleCreator", fields: [createdById], references: [id])
  executions AdRuleExecution[]

  @@index([tenantId, isActive])
  @@index([tenantId, accountId])
  @@map("ad_rules")
}

// 10. AdRuleExecution — rule execution log
model AdRuleExecution {
  id           String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  ruleId       String    @map("rule_id")
  conditionMet Boolean   @map("condition_met")
  conditionData Json?    @map("condition_data") // Evaluated metric values
  actionTaken  Boolean   @map("action_taken")
  actionResult Json?     @map("action_result") // Result of action execution
  error        String?
  executedAt   DateTime  @default(now()) @map("executed_at")

  // Relations
  tenant Tenant @relation("TenantAdRuleExecutions", fields: [tenantId], references: [id], onDelete: Cascade)
  rule   AdRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([tenantId, ruleId])
  @@index([tenantId, executedAt])
  @@map("ad_rule_executions")
}

// 11. AttributionEvent — conversion attribution tracking
model AttributionEvent {
  id              String           @id @default(cuid())
  tenantId        String           @map("tenant_id")
  eventType       String           @map("event_type") // purchase, lead, signup, etc.
  eventId         String           @unique @map("event_id") // Dedup key (UUID)
  platform        AdPlatform?
  campaignId      String?          @map("campaign_id")
  adId            String?          @map("ad_id")
  model           AttributionModel @default(LAST_TOUCH)
  attributionWeight Decimal        @default(1.0) @map("attribution_weight") @db.Decimal(5, 4)
  revenue         Decimal?         @db.Decimal(12, 2)
  conversionData  Json?            @map("conversion_data") // Extra conversion payload
  sourceUrl       String?          @map("source_url")
  ipHash          String?          @map("ip_hash") // Hashed IP for privacy
  userAgent       String?          @map("user_agent")
  occurredAt      DateTime         @map("occurred_at")
  createdAt       DateTime         @default(now()) @map("created_at")

  // Relations
  tenant Tenant @relation("TenantAttributionEvents", fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, eventType])
  @@index([tenantId, platform])
  @@index([tenantId, campaignId])
  @@index([tenantId, occurredAt])
  @@map("attribution_events")
}

// [KAVEN_MODULE:ADS_MANAGEMENT END]

// ===========================
// AI AUTOMATION MODULE
// ===========================
// Event bus, ECA automation rules, AI telemetry, cost guardrails.
// The "nervous system" — cross-module event bus + AI observability.
// Multi-tenant isolated via tenantId.

// [KAVEN_MODULE:AI_AUTOMATION BEGIN]

// ---------- Enums ----------

enum EventStatus {
  PENDING
  PROCESSING
  DELIVERED
  FAILED
  DEAD_LETTER

  @@map("event_status")
}

enum RuleStatus {
  ACTIVE
  PAUSED
  DRAFT
  ARCHIVED
  ERROR

  @@map("rule_status")
}

enum StepExecutionType {
  SEND_NOTIFICATION
  CREATE_RECORD
  UPDATE_FIELD
  CALL_WEBHOOK
  AI_GENERATION
  AI_AGENT

  @@map("step_execution_type")
}

enum BudgetPeriod {
  DAILY
  WEEKLY
  MONTHLY

  @@map("budget_period")
}

enum TelemetryProvider {
  GEMINI
  OPENAI
  ANTHROPIC
  CUSTOM

  @@map("telemetry_provider")
}

// ---------- Models ----------

// 1. DomainEvent — cross-module event record (transactional outbox)
model DomainEvent {
  id           String      @id @default(cuid())
  tenantId     String      @map("tenant_id")
  eventType    String      @map("event_type") // e.g., "finance.entry.created"
  eventId      String      @unique @map("event_id") // Idempotency key (UUID)
  payload      Json        // Event data
  metadata     Json?       // Extra context (userId, module, correlationId)
  status       EventStatus @default(PENDING)
  retryCount   Int         @default(0) @map("retry_count")
  maxRetries   Int         @default(3) @map("max_retries")
  lastError    String?     @map("last_error")
  processedAt  DateTime?   @map("processed_at")
  scheduledFor DateTime?   @map("scheduled_for") // Delayed events
  createdAt    DateTime    @default(now()) @map("created_at")

  // Relations
  tenant Tenant @relation("TenantDomainEvents", fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, eventType])
  @@index([status, scheduledFor])
  @@index([tenantId, createdAt])
  @@map("domain_events")
}

// 2. TriggerDefinition — catalog of available triggers
model TriggerDefinition {
  id           String   @id @default(cuid())
  tenantId     String?  @map("tenant_id") // null = system-level trigger
  eventType    String   @map("event_type") // e.g., "finance.entry.created"
  name         String
  description  String?
  module       String   // Source module: finance, clients, projects, etc.
  payloadSchema Json?   @map("payload_schema") // JSON Schema for validation
  isSystem     Boolean  @default(false) @map("is_system") // System triggers are read-only
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  tenant Tenant? @relation("TenantTriggerDefinitions", fields: [tenantId], references: [id], onDelete: Cascade)
  rules  AutomationRule[]

  @@unique([eventType])
  @@index([module])
  @@map("trigger_definitions")
}

// 3. ActionDefinition — catalog of available actions
model ActionDefinition {
  id            String   @id @default(cuid())
  tenantId      String?  @map("tenant_id")
  actionKey     String   @unique @map("action_key") // e.g., "send_notification"
  name          String
  description   String?
  executionType StepExecutionType @map("execution_type")
  configSchema  Json?    @map("config_schema") // JSON Schema for action config
  isSystem      Boolean  @default(false) @map("is_system")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  tenant Tenant? @relation("TenantActionDefinitions", fields: [tenantId], references: [id], onDelete: Cascade)
  steps  AutomationRuleStep[]

  @@index([executionType])
  @@map("action_definitions")
}

// 4. AutomationRule — ECA rule definition
model AutomationRule {
  id           String     @id @default(cuid())
  tenantId     String     @map("tenant_id")
  triggerId    String     @map("trigger_id")
  name         String
  description  String?
  status       RuleStatus @default(DRAFT)
  conditions   Json?      // ConditionNode tree (AND/OR/NOT operators)
  priority     Int        @default(0) // Higher = evaluated first
  isEnabled    Boolean    @default(true) @map("is_enabled")
  maxExecutions Int?      @map("max_executions") // null = unlimited
  executionCount Int      @default(0) @map("execution_count")
  cooldownMs   Int?       @map("cooldown_ms") // Min time between executions
  lastFiredAt  DateTime?  @map("last_fired_at")
  createdById  String     @map("created_by_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant             @relation("TenantAutomationRules", fields: [tenantId], references: [id], onDelete: Cascade)
  trigger   TriggerDefinition  @relation(fields: [triggerId], references: [id])
  createdBy User               @relation("AutomationRuleCreator", fields: [createdById], references: [id])
  steps     AutomationRuleStep[]
  runs      AutomationRun[]

  @@index([tenantId, status])
  @@index([tenantId, triggerId])
  @@index([tenantId, isEnabled])
  @@map("automation_rules")
}

// 5. AutomationRuleStep — individual steps within a rule
model AutomationRuleStep {
  id            String            @id @default(cuid())
  tenantId      String            @map("tenant_id")
  ruleId        String            @map("rule_id")
  actionId      String            @map("action_id")
  order         Int               // Execution order
  config        Json?             // Step-specific configuration
  retryOnFail   Boolean           @default(false) @map("retry_on_fail")
  maxRetries    Int               @default(3) @map("max_retries")
  timeoutMs     Int               @default(30000) @map("timeout_ms")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  // Relations
  tenant   Tenant           @relation("TenantAutomationRuleSteps", fields: [tenantId], references: [id], onDelete: Cascade)
  rule     AutomationRule   @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  action   ActionDefinition @relation(fields: [actionId], references: [id])
  stepRuns AutomationStepRun[]

  @@index([tenantId, ruleId])
  @@map("automation_rule_steps")
}

// 6. AutomationRun — rule execution instance
model AutomationRun {
  id            String    @id @default(cuid())
  tenantId      String    @map("tenant_id")
  ruleId        String    @map("rule_id")
  eventId       String?   @map("event_id") // DomainEvent that triggered this run
  status        String    @default("PENDING") // PENDING, RUNNING, COMPLETED, FAILED
  triggerData   Json?     @map("trigger_data") // Event payload snapshot
  error         String?
  startedAt     DateTime  @default(now()) @map("started_at")
  completedAt   DateTime? @map("completed_at")
  durationMs    Int?      @map("duration_ms")
  isDryRun      Boolean   @default(false) @map("is_dry_run")

  // Relations
  tenant   Tenant             @relation("TenantAutomationRuns", fields: [tenantId], references: [id], onDelete: Cascade)
  rule     AutomationRule     @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  stepRuns AutomationStepRun[]

  @@index([tenantId, ruleId])
  @@index([tenantId, status])
  @@index([tenantId, startedAt])
  @@map("automation_runs")
}

// 7. AutomationStepRun — individual step execution log
model AutomationStepRun {
  id            String             @id @default(cuid())
  tenantId      String             @map("tenant_id")
  runId         String             @map("run_id")
  stepId        String             @map("step_id")
  status        String             @default("PENDING") // PENDING, RUNNING, COMPLETED, FAILED, SKIPPED
  inputData     Json?              @map("input_data")
  outputData    Json?              @map("output_data")
  error         String?
  retryAttempt  Int                @default(0) @map("retry_attempt")
  startedAt     DateTime           @default(now()) @map("started_at")
  completedAt   DateTime?          @map("completed_at")
  durationMs    Int?               @map("duration_ms")

  // Relations
  tenant Tenant             @relation("TenantAutomationStepRuns", fields: [tenantId], references: [id], onDelete: Cascade)
  run    AutomationRun      @relation(fields: [runId], references: [id], onDelete: Cascade)
  step   AutomationRuleStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@index([tenantId, runId])
  @@index([tenantId, stepId])
  @@map("automation_step_runs")
}

// 8. AgentTelemetry — AI call telemetry (tokens, cost, latency)
model AgentTelemetry {
  id              String            @id @default(cuid())
  tenantId        String            @map("tenant_id")
  provider        TelemetryProvider
  model           String            // e.g., "gemini-2.5-flash"
  agentId         String?           @map("agent_id") // Logical agent identifier
  module          String?           // Source module (finance, ads, etc.)
  traceId         String?           @map("trace_id") // Distributed tracing
  parentSpanId    String?           @map("parent_span_id")
  inputTokens     Int               @map("input_tokens")
  outputTokens    Int               @map("output_tokens")
  totalTokens     Int               @map("total_tokens")
  estimatedCostUsd Decimal          @map("estimated_cost_usd") @db.Decimal(10, 6)
  latencyMs       Int               @map("latency_ms")
  firstTokenMs    Int?              @map("first_token_ms")
  promptHash      String?           @map("prompt_hash") // SHA-256 of prompt for dedup
  success         Boolean           @default(true)
  error           String?
  metadata        Json?             // Extra context
  createdAt       DateTime          @default(now()) @map("created_at")

  // Relations
  tenant Tenant @relation("TenantAgentTelemetry", fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, provider])
  @@index([tenantId, module])
  @@index([tenantId, agentId])
  @@index([tenantId, createdAt])
  @@index([traceId])
  @@map("agent_telemetry")
}

// 9. AgentAction — AI action audit log
model AgentAction {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  agentId      String   @map("agent_id")
  actionType   String   @map("action_type") // e.g., "generate_copy", "analyze_metrics"
  module       String   // Source module
  entityType   String?  @map("entity_type") // e.g., "AdCampaign", "ContentPiece"
  entityId     String?  @map("entity_id")
  inputSummary String?  @map("input_summary") // Truncated input for audit
  outputSummary String? @map("output_summary") // Truncated output for audit
  telemetryId  String?  @map("telemetry_id") // Link to AgentTelemetry
  userId       String?  @map("user_id") // User who triggered the action
  success      Boolean  @default(true)
  error        String?
  durationMs   Int?     @map("duration_ms")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  tenant Tenant @relation("TenantAgentActions", fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation("AgentActionUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, agentId])
  @@index([tenantId, module])
  @@index([tenantId, actionType])
  @@index([tenantId, createdAt])
  @@map("agent_actions")
}

// 10. CostBudget — monthly AI budget per module
model CostBudget {
  id            String       @id @default(cuid())
  tenantId      String       @map("tenant_id")
  module        String?      // null = global budget
  period        BudgetPeriod @default(MONTHLY)
  budgetUsd     Decimal      @map("budget_usd") @db.Decimal(10, 2)
  spentUsd      Decimal      @default(0) @map("spent_usd") @db.Decimal(10, 2)
  alertThreshold Decimal     @default(0.8) @map("alert_threshold") @db.Decimal(3, 2) // 0.8 = 80%
  alertSentAt   DateTime?    @map("alert_sent_at")
  periodStart   DateTime     @map("period_start")
  periodEnd     DateTime     @map("period_end")
  isActive      Boolean      @default(true) @map("is_active")
  createdById   String       @map("created_by_id")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant @relation("TenantCostBudgets", fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User   @relation("CostBudgetCreator", fields: [createdById], references: [id])

  @@unique([tenantId, module, periodStart])
  @@index([tenantId, isActive])
  @@index([tenantId, periodStart, periodEnd])
  @@map("cost_budgets")
}

// [KAVEN_MODULE:AI_AUTOMATION END]

// ===========================
// CASE/MATTER MANAGEMENT MODULE (Law Firm Vertical)
// ===========================
// Legal case management for law firms: cases, matters, parties,
// tasks (Kanban), deadlines with alerts, time tracking, billing,
// trust accounts. Activated only for law_firm industry template.

// [KAVEN_MODULE:CASE_MATTER BEGIN]

// ---------- Enums ----------

enum CaseStatus {
  INTAKE
  ACTIVE
  ON_HOLD
  CLOSED
  ARCHIVED

  @@map("case_status")
}

enum CaseType {
  LITIGATION
  ADVISORY
  TRANSACTIONAL
  ARBITRATION
  ADMINISTRATIVE

  @@map("case_type")
}

enum CaseBillingType {
  HOURLY
  FLAT_FEE
  CONTINGENCY
  RETAINER
  PRO_BONO

  @@map("case_billing_type")
}

enum PartyRole {
  CLIENT
  OPPOSING
  WITNESS
  EXPERT
  JUDGE
  THIRD_PARTY

  @@map("party_role")
}

enum CaseTaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  REVIEW
  DONE

  @@map("case_task_status")
}

enum CaseTaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT

  @@map("case_task_priority")
}

enum DeadlineType {
  COURT
  FILING
  HEARING
  RESPONSE
  APPEAL
  DISCOVERY
  INTERNAL
  CLIENT_DELIVERY
  REGULATORY
  CONTRACT_EXPIRY

  @@map("deadline_type")
}

enum TimeEntryStatus {
  DRAFT
  PENDING
  BILLED
  INVOICED
  WRITTEN_OFF
  NO_CHARGE

  @@map("time_entry_status")
}

enum TrustTransactionType {
  DEPOSIT
  WITHDRAWAL
  DISBURSEMENT
  REFUND
  TRANSFER
  COURT_DEPOSIT
  COURT_RELEASE

  @@map("trust_transaction_type")
}

// ---------- Models ----------

// 1. Case — Legal case with status machine and audit trail
model Case {
  id                String      @id @default(cuid())
  tenantId          String      @map("tenant_id")
  caseNumber        String?     @map("case_number")
  courtNumber       String?     @map("court_number")
  title             String
  description       String?     @db.Text
  caseType          CaseType    @map("case_type")
  status            CaseStatus  @default(INTAKE)
  billingType       CaseBillingType @default(HOURLY) @map("billing_type")

  // Responsibility
  leadAttorneyId    String?     @map("lead_attorney_id")
  originatingId     String?     @map("originating_id")

  // Internal references
  clientId          String      @map("client_id")
  contactId         String?     @map("contact_id")

  // Court info (BR)
  courtName         String?     @map("court_name")
  courtDistrict     String?     @map("court_district")
  courtCity         String?     @map("court_city")
  courtState        String?     @map("court_state")
  jurisdictionType  String?     @map("jurisdiction_type")
  distributionDate  DateTime?   @map("distribution_date")

  // Financial
  estimatedValue    Decimal?    @db.Decimal(15, 2) @map("estimated_value")
  contingencyPct    Decimal?    @db.Decimal(5, 2) @map("contingency_pct")
  retainerAmount    Decimal?    @db.Decimal(15, 2) @map("retainer_amount")
  flatFeeAmount     Decimal?    @db.Decimal(15, 2) @map("flat_fee_amount")
  hourlyRate        Decimal?    @db.Decimal(10, 2) @map("hourly_rate")
  budgetHours       Decimal?    @db.Decimal(8, 2) @map("budget_hours")
  currency          String      @default("BRL")

  // Dates
  openedAt          DateTime?   @map("opened_at")
  closedAt          DateTime?   @map("closed_at")
  statuteOfLimDate  DateTime?   @map("statute_of_lim_date")

  // Metadata
  tags              String[]    @default([])
  notes             String?     @db.Text
  isConfidential    Boolean     @default(false) @map("is_confidential")

  // Timestamps
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")
  deletedAt         DateTime?   @map("deleted_at")

  // Relations
  tenant            Tenant      @relation("TenantCases", fields: [tenantId], references: [id], onDelete: Cascade)
  leadAttorney      User?       @relation("CaseLeadAttorney", fields: [leadAttorneyId], references: [id], onDelete: SetNull)
  matters           CaseMatter[]
  parties           CaseParty[]
  tasks             CaseTask[]
  deadlines         CaseDeadline[]
  timeEntries       CaseTimeEntry[]
  billableRecords   BillableRecord[]
  trustAccount      TrustAccount?
  statusHistory     CaseStatusHistory[]
  caseDocuments     CaseDocument[]
  caseNotes         CaseNote[]

  @@index([tenantId, status])
  @@index([tenantId, clientId])
  @@index([tenantId, courtNumber])
  @@index([tenantId, leadAttorneyId])
  @@index([tenantId, deletedAt])
  @@map("cases")
}

// 2. CaseMatter — Sub-matter within a case with billing override
model CaseMatter {
  id              String      @id @default(cuid())
  tenantId        String      @map("tenant_id")
  caseId          String      @map("case_id")
  title           String
  description     String?     @db.Text
  billingType     CaseBillingType? @map("billing_type")
  hourlyRate      Decimal?    @db.Decimal(10, 2) @map("hourly_rate")
  status          CaseStatus  @default(INTAKE)
  assignedToId    String?     @map("assigned_to_id")
  estimatedHours  Decimal?    @db.Decimal(8, 2) @map("estimated_hours")
  budgetAmount    Decimal?    @db.Decimal(15, 2) @map("budget_amount")

  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  deletedAt       DateTime?   @map("deleted_at")

  // Relations
  tenant          Tenant      @relation("TenantCaseMatters", fields: [tenantId], references: [id], onDelete: Cascade)
  case            Case        @relation(fields: [caseId], references: [id], onDelete: Cascade)
  timeEntries     CaseTimeEntry[]
  tasks           CaseTask[]
  billableRecords BillableRecord[]

  @@index([tenantId, caseId])
  @@map("case_matters")
}

// 3. CaseStatusHistory — Immutable status change log
model CaseStatusHistory {
  id          String      @id @default(cuid())
  tenantId    String      @map("tenant_id")
  caseId      String      @map("case_id")
  fromStatus  CaseStatus? @map("from_status")
  toStatus    CaseStatus  @map("to_status")
  changedById String      @map("changed_by_id")
  reason      String?

  createdAt   DateTime    @default(now()) @map("created_at")

  // Relations
  tenant      Tenant      @relation("TenantCaseStatusHistories", fields: [tenantId], references: [id], onDelete: Cascade)
  case        Case        @relation(fields: [caseId], references: [id], onDelete: Cascade)
  changedBy   User        @relation("CaseStatusChangedBy", fields: [changedById], references: [id])

  @@index([tenantId, caseId, createdAt])
  @@map("case_status_histories")
}

// 4. CaseParty — Parties involved (client, opposing, witness, etc.)
model CaseParty {
  id                    String    @id @default(cuid())
  tenantId              String    @map("tenant_id")
  caseId                String    @map("case_id")
  role                  PartyRole
  name                  String
  documentType          String?   @map("document_type")
  documentNumber        String?   @map("document_number")
  email                 String?
  phone                 String?
  address               String?   @db.Text
  contactId             String?   @map("contact_id")
  companyId             String?   @map("company_id")
  opposingCounselName   String?   @map("opposing_counsel_name")
  opposingCounselOab    String?   @map("opposing_counsel_oab")
  opposingCounselEmail  String?   @map("opposing_counsel_email")
  notes                 String?   @db.Text

  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  // Relations
  tenant                Tenant    @relation("TenantCaseParties", fields: [tenantId], references: [id], onDelete: Cascade)
  case                  Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([tenantId, caseId, role])
  @@index([tenantId, documentNumber])
  @@map("case_parties")
}

// 5. CaseTask — Tasks with Kanban workflow
model CaseTask {
  id              String          @id @default(cuid())
  tenantId        String          @map("tenant_id")
  caseId          String          @map("case_id")
  matterId        String?         @map("matter_id")
  title           String
  description     String?         @db.Text
  status          CaseTaskStatus  @default(BACKLOG)
  priority        CaseTaskPriority @default(MEDIUM)
  assignedToId    String?         @map("assigned_to_id")
  createdById     String          @map("created_by_id")
  dueDate         DateTime?       @map("due_date")
  startDate       DateTime?       @map("start_date")
  completedAt     DateTime?       @map("completed_at")
  parentTaskId    String?         @map("parent_task_id")
  estimatedMinutes Int?           @map("estimated_minutes")
  deadlineId      String?         @map("deadline_id")
  tags            String[]        @default([])

  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  deletedAt       DateTime?       @map("deleted_at")

  // Relations
  tenant          Tenant          @relation("TenantCaseTasks", fields: [tenantId], references: [id], onDelete: Cascade)
  case            Case            @relation(fields: [caseId], references: [id], onDelete: Cascade)
  matter          CaseMatter?     @relation(fields: [matterId], references: [id], onDelete: SetNull)
  parentTask      CaseTask?       @relation("CaseTaskSubtasks", fields: [parentTaskId], references: [id])
  subtasks        CaseTask[]      @relation("CaseTaskSubtasks")
  createdBy       User            @relation("CaseTaskCreatedBy", fields: [createdById], references: [id])
  timeEntries     CaseTimeEntry[]

  @@index([tenantId, caseId, status])
  @@index([tenantId, assignedToId, dueDate])
  @@index([tenantId, dueDate])
  @@map("case_tasks")
}

// 6. CaseDeadline — Procedural deadlines with alert system
model CaseDeadline {
  id              String        @id @default(cuid())
  tenantId        String        @map("tenant_id")
  caseId          String        @map("case_id")
  title           String
  deadlineType    DeadlineType  @map("deadline_type")
  dueDate         DateTime      @map("due_date")
  alertT7         DateTime?     @map("alert_t7")
  alertT3         DateTime?     @map("alert_t3")
  alertT1         DateTime?     @map("alert_t1")
  responsibleId   String?       @map("responsible_id")
  completedAt     DateTime?     @map("completed_at")
  completedById   String?       @map("completed_by_id")
  isAutoCapture   Boolean       @default(false) @map("is_auto_capture")
  courtUpdateId   String?       @map("court_update_id")
  publicationDate DateTime?     @map("publication_date")
  calendarDays    Int?          @map("calendar_days")
  businessDays    Int?          @map("business_days")
  description     String?       @db.Text
  isFulfilled     Boolean       @default(false) @map("is_fulfilled")
  isCritical      Boolean       @default(false) @map("is_critical")

  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  // Relations
  tenant          Tenant        @relation("TenantCaseDeadlines", fields: [tenantId], references: [id], onDelete: Cascade)
  case            Case          @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([tenantId, caseId, dueDate])
  @@index([tenantId, dueDate, isFulfilled])
  @@index([tenantId, responsibleId, dueDate])
  @@map("case_deadlines")
}

// 7. CaseTimeEntry — Billable time tracking (timer + manual)
model CaseTimeEntry {
  id              String          @id @default(cuid())
  tenantId        String          @map("tenant_id")
  caseId          String          @map("case_id")
  matterId        String?         @map("matter_id")
  taskId          String?         @map("task_id")
  userId          String          @map("user_id")
  startedAt       DateTime        @map("started_at")
  endedAt         DateTime?       @map("ended_at")
  durationMinutes Int?            @map("duration_minutes")
  isBillable      Boolean         @default(true) @map("is_billable")
  billingType     CaseBillingType @default(HOURLY) @map("billing_type")
  hourlyRate      Decimal         @db.Decimal(10, 2) @map("hourly_rate")
  amount          Decimal?        @db.Decimal(15, 2)
  status          TimeEntryStatus @default(DRAFT)
  description     String?         @db.Text
  activityCode    String?         @map("activity_code")
  billableRecordId String?        @map("billable_record_id")
  adjustedAmount  Decimal?        @db.Decimal(15, 2) @map("adjusted_amount")
  adjustmentNote  String?         @map("adjustment_note")
  timerSessionId  String?         @unique @map("timer_session_id")

  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  deletedAt       DateTime?       @map("deleted_at")

  // Relations
  tenant          Tenant          @relation("TenantCaseTimeEntries", fields: [tenantId], references: [id], onDelete: Cascade)
  case            Case            @relation(fields: [caseId], references: [id], onDelete: Cascade)
  matter          CaseMatter?     @relation(fields: [matterId], references: [id], onDelete: SetNull)
  task            CaseTask?       @relation(fields: [taskId], references: [id], onDelete: SetNull)
  user            User            @relation("CaseTimeEntryUser", fields: [userId], references: [id])
  billableRecord  BillableRecord? @relation(fields: [billableRecordId], references: [id], onDelete: SetNull)

  @@index([tenantId, caseId, status])
  @@index([tenantId, userId, startedAt])
  @@index([tenantId, matterId])
  @@index([tenantId, status, isBillable])
  @@map("case_time_entries")
}

// 8. BillableRecord — Grouping of hours for invoicing
model BillableRecord {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  caseId          String    @map("case_id")
  matterId        String?   @map("matter_id")
  clientId        String    @map("client_id")
  periodStart     DateTime  @map("period_start")
  periodEnd       DateTime  @map("period_end")
  totalHours      Decimal   @db.Decimal(8, 2) @map("total_hours")
  totalAmount     Decimal   @db.Decimal(15, 2) @map("total_amount")
  currency        String    @default("BRL")
  status          String    @default("draft") // draft | approved | invoiced | paid | disputed
  financeInvoiceId String?  @map("finance_invoice_id")
  memo            String?   @db.Text
  approvedById    String?   @map("approved_by_id")
  approvedAt      DateTime? @map("approved_at")
  invoicedAt      DateTime? @map("invoiced_at")

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  tenant          Tenant    @relation("TenantBillableRecords", fields: [tenantId], references: [id], onDelete: Cascade)
  case            Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  matter          CaseMatter? @relation(fields: [matterId], references: [id], onDelete: SetNull)
  timeEntries     CaseTimeEntry[]

  @@index([tenantId, caseId, status])
  @@index([tenantId, clientId])
  @@map("billable_records")
}

// 9. TrustAccount — Client trust accounts (IOLTA compliance)
model TrustAccount {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  caseId          String    @unique @map("case_id")
  clientId        String    @map("client_id")
  balance         Decimal   @default(0) @db.Decimal(15, 2)
  currency        String    @default("BRL")
  bankName        String?   @map("bank_name")
  bankAccountNumber String? @map("bank_account_number")
  bankAgency      String?   @map("bank_agency")
  alertThreshold  Decimal?  @db.Decimal(15, 2) @map("alert_threshold")
  lastReconciledAt DateTime? @map("last_reconciled_at")
  lastReconciledById String? @map("last_reconciled_by_id")
  isActive        Boolean   @default(true) @map("is_active")

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  tenant          Tenant    @relation("TenantTrustAccounts", fields: [tenantId], references: [id], onDelete: Cascade)
  case            Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  transactions    TrustTransaction[]

  @@index([tenantId, clientId])
  @@map("trust_accounts")
}

// 10. TrustTransaction — Immutable trust account movements
model TrustTransaction {
  id              String                @id @default(cuid())
  tenantId        String                @map("tenant_id")
  trustAccountId  String                @map("trust_account_id")
  type            TrustTransactionType
  amount          Decimal               @db.Decimal(15, 2)
  direction       String                // "credit" | "debit"
  balanceAfter    Decimal               @db.Decimal(15, 2) @map("balance_after")
  description     String
  reference       String?
  transactionDate DateTime              @map("transaction_date")
  authorizedById  String                @map("authorized_by_id")
  financeEntryId  String?               @map("finance_entry_id")

  createdAt       DateTime              @default(now()) @map("created_at")

  // Relations
  tenant          Tenant                @relation("TenantTrustTransactions", fields: [tenantId], references: [id], onDelete: Cascade)
  trustAccount    TrustAccount          @relation(fields: [trustAccountId], references: [id], onDelete: Cascade)
  authorizedBy    User                  @relation("TrustTransactionAuthorizer", fields: [authorizedById], references: [id])

  @@index([tenantId, trustAccountId, transactionDate])
  @@map("trust_transactions")
}

// 11. CaseDocument — Case documents (metadata, file in documents_kb)
model CaseDocument {
  id                    String    @id @default(cuid())
  tenantId              String    @map("tenant_id")
  caseId                String    @map("case_id")
  title                 String
  documentType          String    @map("document_type") // petition, decision, contract, evidence, correspondence, other
  description           String?
  documentKbId          String?   @map("document_kb_id")
  fileUrl               String?   @map("file_url")
  filedAt               DateTime? @map("filed_at")
  filedBy               String?   @map("filed_by")
  courtProtocolNumber   String?   @map("court_protocol_number")
  isConfidential        Boolean   @default(false) @map("is_confidential")
  uploadedById          String    @map("uploaded_by_id")

  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  deletedAt             DateTime? @map("deleted_at")

  // Relations
  tenant                Tenant    @relation("TenantCaseDocuments", fields: [tenantId], references: [id], onDelete: Cascade)
  case                  Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  uploadedBy            User      @relation("CaseDocumentUploader", fields: [uploadedById], references: [id])

  @@index([tenantId, caseId, documentType])
  @@map("case_documents")
}

// 12. CaseNote — Internal case notes
model CaseNote {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  caseId      String    @map("case_id")
  content     String    @db.Text
  isPinned    Boolean   @default(false) @map("is_pinned")
  isPrivate   Boolean   @default(false) @map("is_private")
  authorId    String    @map("author_id")

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  // Relations
  tenant      Tenant    @relation("TenantCaseNotes", fields: [tenantId], references: [id], onDelete: Cascade)
  case        Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  author      User      @relation("CaseNoteAuthor", fields: [authorId], references: [id])

  @@index([tenantId, caseId, createdAt])
  @@map("case_notes")
}

