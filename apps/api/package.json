{
  "name": "api",
  "version": "0.1.0-alpha.0",
  "description": "Kaven API",
  "main": "src/server.ts",
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "dev:simple": "(fuser -k -9 8000/tcp || true) && tsx watch src/server.ts",
    "build": "tsc && tsc-alias",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 9999",
    "start": "node dist/src/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:security": "vitest run test/security --coverage",
    "grafana:import": "bash ../../scripts/import-grafana-dashboards.sh"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.1034.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^9.3.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.1.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.3",
    "@kaven/shared": "workspace:*",
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^7.7.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@sentry/node": "^10.49.0",
    "@sentry/profiling-node": "^10.49.0",
    "axios": "^1.15.2",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.75.2",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "handlebars": "^4.7.8",
    "ioredis": "^5.10.0",
    "ipaddr.js": "^2.1.0",
    "isomorphic-dompurify": "^3.9.0",
    "jose": "^6.2.2",
    "nodemailer": "^7.0.11",
    "pg": "^8.20.0",
    "postmark": "^4.0.5",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "qs": "^6.15.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.12.2",
    "sharp": "^0.34.5",
    "speakeasy": "^2.0.0",
    "stripe": "^20.4.0",
    "systeminformation": "^5.31.0",
    "validator": "^13.15.26",
    "winston": "^3.19.0",
    "ws": "^8.20.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/handlebars": "^4.1.0",
    "@types/inquirer": "^9.0.9",
    "@types/ioredis": "^5.0.0",
    "@types/node": "^20.11.0",
    "@types/nodemailer": "^7.0.4",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "19.2.3",
    "@types/react-dom": "19.2.3",
    "@types/speakeasy": "^2.0.10",
    "@types/supertest": "^7.2.0",
    "@types/systeminformation": "^3.54.1",
    "@types/validator": "^13.15.10",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "4.1.4",
    "kill-port": "^2.0.1",
    "prisma": "^7.7.0",
    "supertest": "^7.1.4",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.7.0",
