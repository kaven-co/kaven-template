{
  "name": "kaven-boilerplate",
  "version": "0.1.0-alpha.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "predev": "bash scripts/cleanup-dev.sh",
    "postinstall": "pnpm db:generate",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @kaven/database db:generate",
    "db:migrate": "pnpm --filter @kaven/database db:migrate",
    "db:seed": "pnpm --filter @kaven/database db:seed",
    "db:studio": "pnpm --filter @kaven/database db:studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:restart": "docker compose restart",
    "docker:clean": "docker compose down -v",
    "setup": "pnpm install && pnpm docker:up && sleep 5 && pnpm db:migrate && pnpm db:seed",
    "quality": "pnpm lint && pnpm typecheck && pnpm test",
    "test:coverage": "pnpm test --coverage",
    "test:security": "jest apps/api/tests/security --coverage --coverageDirectory=coverage/security",
    "test:gdpr": "jest apps/api/tests/compliance --coverage --coverageDirectory=coverage/gdpr",
    "policy:design-system": "bash scripts/policies/check-design-system.sh",
    "policy:design-system-docs": "bash scripts/policies/check-design-system-docs.sh",
    "report:ui-imports": "bash scripts/migration/ui-import-report.sh",
    "check:ui-migration-clean": "bash scripts/migration/check-ui-migration-clean.sh"
  },
  "devDependencies": {
    "@types/node-cron": "^3.0.11",
    "kill-port": "^2.0.1",
    "prettier": "^3.4.2",
    "prisma": "^5.22.0",
    "turbo": "^2.9.5",
    "typescript": "^6.0.2"
  },
  "packageManager": "pnpm@9.15.4",
  "dependencies": {
    "@prisma/client": "5.22.0",
    "node-cron": "^3.0.3",
    "systeminformation": "^5.31.0"
  },
  "pnpm": {
    "overrides": {
      "preact": "^10.25.0",
      "qs": "^6.14.0",
      "inflight": "^1.0.6"
    }
  }
}
